    def _set_selected_preview(text: str,
                              ranges: Optional[List[Tuple[int, int]]] = None) -> None:
        """Write `text` into the selected-row preview Text widget and tag
        the given character ranges with the yellow `match` background.
        Truncation to _SELECTED_PREVIEW_CHARS is performed here so callers
        pass full strings."""
        _selected_lbl.configure(state="normal")
        try:
            _selected_lbl.delete("1.0", "end")
            # Truncate: prefer keeping the first match in view.
            short = text
            kept_ranges = ranges or []
            if len(short) > _SELECTED_PREVIEW_CHARS:
                if kept_ranges:
                    # Window around the earliest match so the highlight stays visible.
                    s0 = kept_ranges[0][0]
                    half = _SELECTED_PREVIEW_CHARS // 2
                    win_start = max(0, s0 - half)
                    win_end = win_start + _SELECTED_PREVIEW_CHARS
                    if win_end > len(short):
                        win_end = len(short)
                        win_start = max(0, win_end - _SELECTED_PREVIEW_CHARS)
                    short = short[win_start:win_end]
                    kept_ranges = [
                        (max(0, s - win_start), min(_SELECTED_PREVIEW_CHARS, e - win_start))
                        for (s, e) in kept_ranges
                        if e > win_start and s < win_end
                    ]
                else:
                    short = short[:_SELECTED_PREVIEW_CHARS - 1] + "…"
            _selected_lbl.insert("1.0", short)
            for s, e in kept_ranges:
                _selected_lbl.tag_add("match", f"1.{s}", f"1.{e}")
        finally:
            _selected_lbl.configure(state="disabled")

