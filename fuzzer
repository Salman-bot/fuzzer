        # Live hex memory view — shows the actual bytes py_normalize reads
        # on the latest call, with highlighting:
        #   red    = byte will be DROPPED (diacritic / tatweel / superscript-alef)
        #   yellow = byte will be SUBSTITUTED (alef-variant → ا, yeh-variant → ي)
        #   plain  = passes through unchanged
        #
        # The C function classifies by 2-byte UTF-8 codepoint. We mirror its
        # rules below to colorize the input hex dump.
        def _classify(raw: bytes) -> List[str]:
            """Return per-byte tag: 'drop' / 'sub' / '' (one entry per byte)."""
            tags = [""] * len(raw)
            i = 0
            while i < len(raw):
                b = raw[i]
                if b < 0x80:
                    i += 1; continue
                if (b & 0xE0) == 0xC0 and i + 1 < len(raw):
                    cp = ((b & 0x1F) << 6) | (raw[i + 1] & 0x3F)
                    if (0x064B <= cp <= 0x0652) or cp == 0x0670 or cp == 0x0640:
                        tags[i] = tags[i + 1] = "drop"
                    elif cp in (0x0623, 0x0625, 0x0622, 0x0671,
                                0x0649, 0x0626):
                        tags[i] = tags[i + 1] = "sub"
                    i += 2; continue
                if (b & 0xF0) == 0xE0: i += 3; continue
                if (b & 0xF8) == 0xF0: i += 4; continue
                i += 1
            return tags

        def _insert_hex(widget: tk.Text, raw: bytes, tags: List[str]) -> None:
            widget.config(state="normal")
            widget.delete("1.0", "end")
            for idx, b in enumerate(raw[:96]):
                widget.insert("end", f"{b:02x} ", tags[idx] or ())
                if (idx + 1) % 16 == 0:
                    widget.insert("end", "\n")
            if len(raw) > 96:
                widget.insert("end", f"  … (+{len(raw) - 96} B)")
            widget.config(state="disabled")

