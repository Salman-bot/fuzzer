    def _ask_admin(action: str) -> bool:
        return messagebox.askyesno(
            "Permission denied",
            f"Administrator privileges are needed to:\n\n  {action}\n\n"
            "Try again as administrator?",
            icon="warning",
        )

    def _run_elevated(command: str, working_dir: str) -> Tuple[int, str]:
        """Run a command elevated via sudo prompt. Returns (exit_code, combined_output)."""
        import subprocess
        try:
            parts = ["sudo", "--", "sh", "-c", command]
            r = subprocess.run(
                parts, capture_output=True, text=True,
                timeout=120, cwd=working_dir,
            )
            return r.returncode, (r.stdout + r.stderr).strip()
        except Exception as e:
            return 1, str(e)

