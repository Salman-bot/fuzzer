#!/usr/bin/env python3
"""fuzzer — search file contents for words/phrases.

Defaults: case-insensitive, fuzzy matching ON.

Flags:
  -k  case-sensitive
  -e  exact match only (no fuzzy)
  -t  fuzzy threshold 0-100 (default 80)
  -v  show full sentence around each match
  -C  context lines around each match
  -l  filenames only
  -n  no line numbers
  -r  recursive directory search
  -a  AI-powered semantic search (needs ANTHROPIC_API_KEY)
  -o  export results to FILE (.csv .tsv .json .txt .xlsx)
  --no-color
"""
from __future__ import annotations

import argparse
import os
import re
import sys
from pathlib import Path
from typing import Dict, List, NamedTuple, Optional, Tuple

# ── colour ─────────────────────────────────────────────────────────────────────

_BOLD = "\033[1m"
_DIM  = "\033[2m"
_RED  = "\033[31m"
_GRN  = "\033[32m"
_YEL  = "\033[33m"
_MAG  = "\033[35m"
_CYN  = "\033[36m"
_RST  = "\033[0m"

_color_on = True

def _c(*codes: str) -> str:
    return "".join(codes) if _color_on else ""

def _r() -> str:
    return _RST if _color_on else ""

def _err(msg: str) -> None:
    print(f"{_c(_YEL)}warning:{_r()} {msg}", file=sys.stderr)

# ── types ──────────────────────────────────────────────────────────────────────

class Match(NamedTuple):
    filepath: str
    line_num: int   # 1-based
    line: str
    score: int      # 100 = exact substring, <100 = fuzzy %
    page_num: int = 0  # PDF page (1-based); 0 = not a PDF / unknown

# ── text extraction ────────────────────────────────────────────────────────────

def _extract_plain(fp: str) -> Optional[List[str]]:
    try:
        return Path(fp).read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError as e:
        _err(f"{fp}: {e}")
        return None

_pdf_page_map: Dict[str, List[int]] = {}  # fp → page_num per line (1-based)

def _extract_pdf(fp: str) -> Optional[List[str]]:
    # PyMuPDF preserves logical Unicode character order for Arabic text;
    # fall back to pdfplumber if fitz is not installed.
    lines: List[str] = []
    page_nums: List[int] = []
    try:
        import fitz  # PyMuPDF
        doc = fitz.open(fp)
        for page_idx in range(1, len(doc) + 1):
            page = doc[page_idx - 1]
            # sort=True re-orders glyphs by position, fixing ligature order in
            # Arabic PDFs that use non-standard glyph sequences.
            text: str = page.get_text("text", sort=True) or ""  # type: ignore[attr-defined]
            page_lines = text.splitlines()
            lines.extend(page_lines)
            page_nums.extend([page_idx] * len(page_lines))
        doc.close()
        _pdf_page_map[fp] = page_nums
        return lines
    except ImportError:
        pass
    except Exception as e:
        _err(f"{fp}: {e}")
        return None
    try:
        import pdfplumber
    except ImportError:
        _err("PDF support requires pdfplumber or pymupdf — pip install pymupdf")
        return None
    try:
        with pdfplumber.open(fp) as pdf:
            for page_idx, page in enumerate(pdf.pages, start=1):
                text = page.extract_text() or ""
                page_lines = text.splitlines()
                lines.extend(page_lines)
                page_nums.extend([page_idx] * len(page_lines))
        _pdf_page_map[fp] = page_nums
        return lines
    except Exception as e:
        _err(f"{fp}: {e}")
        return None

def _extract_docx(fp: str) -> Optional[List[str]]:
    try:
        from docx import Document
    except ImportError:
        _err("DOCX support requires python-docx — pip install python-docx")
        return None
    try:
        doc = Document(fp)
        return [p.text for p in doc.paragraphs if p.text.strip()]
    except Exception as e:
        _err(f"{fp}: {e}")
        return None

_EXT_MAP = {
    ".pdf":  _extract_pdf,
    ".docx": _extract_docx,
    ".doc":  _extract_docx,
    ".txt":  _extract_plain,
    ".md":   _extract_plain,
    ".rst":  _extract_plain,
    ".csv":  _extract_plain,
    ".tsv":  _extract_plain,
    ".log":  _extract_plain,
    ".json": _extract_plain,
    ".xml":  _extract_plain,
    ".html": _extract_plain,
    ".htm":  _extract_plain,
}

def read_lines(fp: str) -> Optional[List[str]]:
    ext = Path(fp).suffix.lower()
    fn = _EXT_MAP.get(ext, _extract_plain)
    return fn(fp)

# ── Arabic text normalization ──────────────────────────────────────────────────

_AR_DIACRITICS = re.compile(r"[ً-ْٰـ]")  # short vowels + tatweel (kashida)
_ALEF_VARIANTS = str.maketrans({"أ": "ا", "إ": "ا", "آ": "ا", "ٱ": "ا"})
_YEH_VARIANTS = str.maketrans({"ى": "ي", "ئ": "ي"})

def _normalize_arabic(s: str) -> str:
    """Strip tatweel, diacritics, and normalize alef/yeh variants for fuzzy
    matching. Leaves non-Arabic chars untouched."""
    s = _AR_DIACRITICS.sub("", s)
    s = s.translate(_ALEF_VARIANTS).translate(_YEH_VARIANTS)
    return s

_TOKEN_RE = re.compile(r"[؀-ۿa-zA-Z0-9]+")

def _tokenize(s: str, min_len: int = 2) -> set:
    """Tokenize a string into normalized words ≥ min_len chars."""
    return {t for t in _TOKEN_RE.findall(_normalize_arabic(s)) if len(t) >= min_len}

# ── sentence extraction ────────────────────────────────────────────────────────

_SENTENCE_END = re.compile(r"(?<=[.!?])\s+")

def extract_sentence(full_text: str, char_offset: int) -> str:
    """Return the sentence that contains char_offset in full_text."""
    # find start: last sentence-end before offset
    start = 0
    for m in _SENTENCE_END.finditer(full_text):
        if m.start() < char_offset:
            start = m.end()
        else:
            break
    # find end: next sentence-end after offset
    end_match = _SENTENCE_END.search(full_text, char_offset)
    end = end_match.start() + 1 if end_match else len(full_text)
    sentence = full_text[start:end].strip()
    return sentence or full_text[max(0, char_offset - 120): char_offset + 120].strip()

# ── fuzzy matching ─────────────────────────────────────────────────────────────

def _levenshtein(a: str, b: str) -> int:
    if len(a) > len(b):
        a, b = b, a
    row = list(range(len(a) + 1))
    for c2 in b:
        prev, row[0] = row[0], row[0] + 1
        for j, c1 in enumerate(a):
            prev, row[j + 1] = row[j + 1], min(
                row[j + 1] + 1, row[j] + 1, prev + (c1 != c2)
            )
    return row[-1]

def _builtin_ratio(a: str, b: str) -> int:
    dist = _levenshtein(a, b)
    total = len(a) + len(b)
    return int((1 - dist / total) * 100) if total else 100

def fuzzy_score(pattern: str, line: str) -> int:
    """Best similarity score (0-100) of pattern against tokens in line."""
    try:
        from thefuzz import fuzz
        ratio_fn = fuzz.ratio
        partial_fn = fuzz.partial_ratio
        token_fn = fuzz.token_set_ratio
    except ImportError:
        ratio_fn = _builtin_ratio  # type: ignore[assignment]
        partial_fn = None
        token_fn = None

    words = line.split()
    pw = pattern.split()
    n = len(pw)
    best = 0

    if n == 1:
        for w in words:
            best = max(best, ratio_fn(pattern, w))
    else:
        for i in range(max(1, len(words) - n + 1)):
            window = " ".join(words[i: i + n])
            best = max(best, ratio_fn(pattern, window))
        if partial_fn:
            best = max(best, partial_fn(pattern, line))
        if token_fn:
            best = max(best, token_fn(pattern, line))

    return best

# ── core search ────────────────────────────────────────────────────────────────

def search_file(
    fp: str,
    pattern: str,
    *,
    case_sensitive: bool,
    exact_only: bool,
    threshold: int,
) -> Tuple[List[str], List[Match]]:
    lines = read_lines(fp)
    if lines is None:
        return [], []

    pat = pattern if case_sensitive else pattern.lower()
    matches: List[Match] = []
    _pages = _pdf_page_map.get(fp, [])

    for i, line in enumerate(lines, start=1):
        cmp = line if case_sensitive else line.lower()
        pg = _pages[i - 1] if i - 1 < len(_pages) else 0
        if pat in cmp:
            matches.append(Match(fp, i, line, 100, pg))
            continue
        if not exact_only:
            sc = fuzzy_score(pat, cmp)
            if sc >= threshold:
                matches.append(Match(fp, i, line, sc, pg))

    return lines, matches

# ── AI search ─────────────────────────────────────────────────────────────────

def ai_search_file(fp: str, query: str, log_fn=None,
                   api_key: str = "") -> Tuple[List[str], List[Match]]:
    """Use Claude to find semantically relevant passages.
    log_fn(tag, prefix, text) is called (thread-safe via root.after) to show
    the query and response in the GUI chat panel.
    api_key overrides ANTHROPIC_API_KEY env var (used by GUI when key is stored in state)."""
    def _log(tag: str, prefix: str, text: str) -> None:
        if log_fn:
            log_fn(tag, prefix, text)

    try:
        import anthropic
    except ImportError:
        _err("AI mode requires anthropic — pip install anthropic")
        return [], []

    key = api_key or os.environ.get("ANTHROPIC_API_KEY", "")
    if not key:
        _err("AI mode needs ANTHROPIC_API_KEY environment variable set")
        _log("err", "error", "No API key. Set one via 'API Key…' button.")
        return [], []

    lines = read_lines(fp)
    if not lines:
        return [], []

    # Keep ~20 000 chars (~5 000 tokens) to stay well under free-tier rate limits.
    # Number lines BEFORE truncating so line numbers stay accurate.
    numbered_lines = [f"{i+1}: {l}" for i, l in enumerate(lines)]
    numbered = "\n".join(numbered_lines)
    truncated = False
    if len(numbered) > 20_000:
        numbered = numbered[:20_000]
        truncated = True

    client = anthropic.Anthropic(api_key=key)
    prompt = (
        f'You are a search assistant. Find every line in the document below that is '
        f'relevant to the query: "{query}"\n\n'
        f"Return ONLY a JSON array of objects, each with:\n"
        f'  "line": the 1-based line number (integer)\n'
        f'  "reason": one short phrase explaining relevance\n\n'
        f"If nothing is relevant, return []\n\n"
        f"Document:\n{numbered}"
    )

    fname = os.path.basename(fp)
    _log("you", "AI search", f'"{query}" in {fname}')
    if truncated:
        _log("sys", "note", "Document truncated to ~20 000 chars to fit rate limits")
    _log("sys", "claude", f"Searching {fname}…")

    try:
        resp = client.messages.create(
            model="claude-sonnet-4-6",
            max_tokens=2048,
            messages=[{"role": "user", "content": prompt}],
        )
        import json
        from anthropic.types import TextBlock as _TextBlock
        raw = next(
            (b.text for b in resp.content if isinstance(b, _TextBlock)), ""
        ).strip()
        raw = re.sub(r"^```[a-z]*\n?", "", raw)
        raw = re.sub(r"\n?```$", "", raw)
        hits = json.loads(raw)
        matches: List[Match] = []
        _pg_map = _pdf_page_map.get(fp, [])
        for h in hits:
            ln = int(h["line"])
            if 1 <= ln <= len(lines):
                _pg_num = _pg_map[ln - 1] if _pg_map and ln - 1 < len(_pg_map) else 0
                matches.append(Match(fp, ln, lines[ln - 1], -1, _pg_num))
        summary = (
            f"Found {len(matches)} match(es) in {fname}" if matches
            else f"No matches in {fname}"
        )
        _log("claude", "claude", summary)
        if matches:
            for m in matches[:5]:
                reason = next(
                    (h.get("reason", "") for h in hits if int(h["line"]) == m.line_num),
                    ""
                )
                _log("claude", "  →", f"line {m.line_num}: {reason}")
        return lines, matches
    except Exception as e:
        err_str = str(e)
        if "rate_limit" in err_str or "429" in err_str:
            msg = "Rate limit hit — wait a minute and try again, or use a smaller file."
        else:
            msg = f"AI search failed: {err_str[:120]}"
        _err(f"AI search failed for {fp}: {e}")
        _log("err", "error", msg)
        return lines, []

# ── output ─────────────────────────────────────────────────────────────────────

def _highlight(line: str, pattern: str, case_sensitive: bool) -> str:
    pat = pattern if case_sensitive else pattern.lower()
    cmp = line if case_sensitive else line.lower()
    idx = cmp.find(pat)
    if idx == -1:
        return line
    end = idx + len(pat)
    return line[:idx] + _c(_RED, _BOLD) + line[idx:end] + _r() + line[end:]

def _score_tag(score: int) -> str:
    if score == 100:
        return ""
    if score == -1:
        return f" {_c(_CYN)}[AI]{_r()}"
    return f" {_c(_YEL)}[~{score}%]{_r()}"

def print_results(
    results: Dict[str, Tuple[List[str], List[Match]]],
    *,
    pattern: str,
    case_sensitive: bool,
    files_only: bool,
    show_nums: bool,
    context_lines: int,
    verbose: bool,
    ai_mode: bool,
) -> int:
    total = 0
    for fp, (lines, matches) in results.items():
        if not matches:
            continue
        total += len(matches)
        print(_c(_MAG, _BOLD) + fp + _r())
        if files_only:
            continue

        full_text = "\n".join(lines)
        shown: set = set()

        for m in matches:
            ln = m.line_num
            tag = _score_tag(m.score)

            if verbose:
                # find sentence containing this line
                # compute char offset of this line's start
                offset = sum(len(l) + 1 for l in lines[:ln - 1])
                sentence = extract_sentence(full_text, offset + max(0, len(m.line) // 2))
                if case_sensitive:
                    hl = re.sub(re.escape(pattern),
                                _c(_RED, _BOLD) + r"\g<0>" + _r(),
                                sentence)
                else:
                    hl = re.sub(re.escape(pattern), _c(_RED, _BOLD) + r"\g<0>" + _r(),
                                sentence, flags=re.IGNORECASE)
                num = (_c(_GRN) + f"{ln}:" + _r() + " ") if show_nums else ""
                print(f"  {num}{hl}{tag}")

            elif context_lines > 0:
                lo = max(1, ln - context_lines)
                hi = min(len(lines), ln + context_lines)
                if shown and min(k for k in range(lo, hi + 1) if k not in shown) > lo:
                    print(_c(_DIM) + "--" + _r())
                for ctx in range(lo, hi + 1):
                    if ctx in shown:
                        continue
                    shown.add(ctx)
                    ctx_line = lines[ctx - 1]
                    if ctx == ln:
                        num = (_c(_GRN) + f"{ctx}:" + _r()) if show_nums else ""
                        print(f"{num}{_highlight(ctx_line, pattern, case_sensitive)}{tag}")
                    else:
                        num = (_c(_DIM) + f"{ctx}-" + _r()) if show_nums else ""
                        print(f"{num}{_c(_DIM)}{ctx_line}{_r()}")
            else:
                num = (_c(_GRN) + f"{ln}:" + _r()) if show_nums else ""
                if ai_mode:
                    print(f"{num}{m.line}{tag}")
                else:
                    print(f"{num}{_highlight(m.line, pattern, case_sensitive)}{tag}")

    return total

# ── export ─────────────────────────────────────────────────────────────────────

def _build_rows(
    results: Dict[str, Tuple[List[str], List[Match]]],
    *,
    verbose: bool,
) -> List[Dict[str, object]]:
    rows: List[Dict[str, object]] = []
    for fp, (lines, matches) in results.items():
        full_text = "\n".join(lines)
        for m in matches:
            if m.score == 100:
                match_type = "exact"
                score_val: object = 100
            elif m.score == -1:
                match_type = "ai"
                score_val = ""
            else:
                match_type = "fuzzy"
                score_val = m.score

            row: Dict[str, object] = {
                "file": fp,
                "line": m.line_num,
                "page": m.page_num if m.page_num else "",
                "match_type": match_type,
                "score": score_val,
                "content": m.line,
            }
            if verbose:
                offset = sum(len(l) + 1 for l in lines[:m.line_num - 1])
                row["sentence"] = extract_sentence(
                    full_text, offset + max(0, len(m.line) // 2)
                )
            rows.append(row)
    return rows


def export_results(
    results: Dict[str, Tuple[List[str], List[Match]]],
    out_path: str,
    *,
    verbose: bool,
) -> None:
    rows = _build_rows(results, verbose=verbose)
    ext = Path(out_path).suffix.lower()

    if ext in (".csv", ".tsv"):
        import csv
        delim = "\t" if ext == ".tsv" else ","
        fields = list(rows[0].keys()) if rows else \
            ["file", "line", "match_type", "score", "content"]
        with open(out_path, "w", encoding="utf-8", newline="") as f:
            w = csv.DictWriter(f, fieldnames=fields, delimiter=delim)
            w.writeheader()
            w.writerows(rows)

    elif ext == ".json":
        import json
        with open(out_path, "w", encoding="utf-8") as f:
            json.dump(rows, f, ensure_ascii=False, indent=2)

    elif ext in (".xlsx", ".xls"):
        try:
            from openpyxl import Workbook
            from openpyxl.styles import Font
        except ImportError:
            _err("Excel export requires openpyxl — pip install openpyxl")
            return
        from openpyxl.utils import get_column_letter
        wb = Workbook()
        ws = wb.active
        assert ws is not None
        ws.title = "fuzzer results"
        fields = list(rows[0].keys()) if rows else \
            ["file", "line", "match_type", "score", "content"]
        ws.append(fields)
        for cell in ws[1]:
            cell.font = Font(bold=True)
        for row in rows:
            ws.append([row.get(k, "") for k in fields])
        for col_idx, name in enumerate(fields, start=1):
            max_len = max(
                [len(str(name))] + [len(str(r.get(name, ""))) for r in rows]
            )
            ws.column_dimensions[get_column_letter(col_idx)].width = min(max_len + 2, 80)
        wb.save(out_path)

    else:
        # plain text — mirror the console layout, no colours
        with open(out_path, "w", encoding="utf-8") as f:
            current_file: Optional[str] = None
            for r in rows:
                if r["file"] != current_file:
                    current_file = str(r["file"])
                    f.write(f"\n{current_file}\n")
                tag = ""
                if r["match_type"] == "fuzzy":
                    tag = f" [~{r['score']}%]"
                elif r["match_type"] == "ai":
                    tag = " [AI]"
                f.write(f"  {r['line']}: {r['content']}{tag}\n")
                if verbose and "sentence" in r:
                    f.write(f"     {r['sentence']}\n")

    print(_c(_CYN) + f"exported {len(rows)} rows to {out_path}" + _r(),
          file=sys.stderr)

# ── file collection ────────────────────────────────────────────────────────────

def collect_files(paths: List[str], recursive: bool) -> List[str]:
    out: List[str] = []
    for p in paths:
        path = Path(p)
        if path.is_dir():
            if recursive:
                for f in sorted(path.rglob("*")):
                    if f.is_file() and f.suffix.lower() in _EXT_MAP:
                        out.append(str(f))
            else:
                _err(f"{p} is a directory — use -r to search recursively")
        elif path.is_file():
            out.append(str(path))
        else:
            _err(f"{p}: not found")
    return out

# ── GUI ────────────────────────────────────────────────────────────────────────

def run_gui() -> int:
    try:
        import tkinter as tk
        from tkinter import ttk, filedialog, messagebox
    except ImportError:
        print("error: tkinter is not available in this Python.\n"
              "  macOS Homebrew: brew install python-tk\n"
              "  Debian/Ubuntu:  sudo apt install python3-tk",
              file=sys.stderr)
        return 2

    import json as _json
    import queue
    import threading

    _STATE_FILE = Path.home() / ".fuzzer_gui_state.json"

    def _load_state() -> Dict[str, object]:
        try:
            return _json.loads(_STATE_FILE.read_text())
        except Exception:
            return {}

    def _save_state(data: Dict[str, object]) -> None:
        try:
            _STATE_FILE.write_text(_json.dumps(data))
        except Exception:
            pass

    _gui_state = _load_state()

    # Clean up old highlighted PDFs from previous sessions (>1 day old)
    try:
        import time as _time
        _tmp_dir = Path.home() / ".fuzzer_tmp"
        if _tmp_dir.is_dir():
            _now = _time.time()
            for _f in _tmp_dir.glob("fuzzer_*.pdf"):
                try:
                    if _now - _f.stat().st_mtime > 86400:  # 24h
                        _f.unlink()
                except Exception:
                    pass
    except Exception:
        pass


    # tkinter Treeview cells are always LTR containers, so we need
    # bidi.get_display() to reorder Arabic words for correct visual order.
    # On macOS, CoreText handles letter-level shaping (connecting glyphs)
    # from raw Unicode, so arabic_reshaper is NOT needed and would fight
    # CoreText. On other platforms both reshaper + bidi are required.
    import platform as _platform

    # macOS: pre-set Preview's saved window frame so PDFs open directly at
    # 1000x720 with no resize flash. Uses `defaults write` against Preview's
    # main PDF window frame key.
    if _platform.system() == "Darwin":
        try:
            import subprocess as _sp
            _frame = "120 80 1000 720 0 0 1920 1080 "
            _sp.run(
                ["defaults", "write", "com.apple.Preview",
                 "NSWindow Frame PVMainPDFWindow", _frame],
                capture_output=True, check=False,
            )
        except Exception:
            pass

    _bidi_display = None
    _arabic_reshaper = None
    try:
        from bidi.algorithm import get_display as _bidi_display  # type: ignore[assignment]
    except ImportError:
        pass
    try:
        import arabic_reshaper as _arabic_reshaper  # type: ignore[assignment]
    except ImportError:
        pass

    _WS_RUN = re.compile(r"\s+")
    _HAS_ARABIC = re.compile(r"[؀-ۿ]")
    # Mirror pairs — bidi RTL rendering flips these visually. Pre-swap them in
    # the logical string so the rendered output reads correctly left-to-right.
    _BIDI_MIRROR = str.maketrans({"(": ")", ")": "(", "[": "]", "]": "[",
                                  "{": "}", "}": "{", "<": ">", ">": "<"})
    # Some Arabic PDFs encode the definite article ال as ا+م+ل (positions 1-2
    # swapped). Detect at word start and swap back. ا (0x627) is matched, but
    # not أ/إ/آ — those are different alef variants for which "أم"/"إم" are
    # legitimate word starts.
    _AL_SWAP = re.compile(r"(?<![ء-ي])امل")

    def _fix_arabic(text: str) -> str:
        if not text:
            return text
        # Collapse runs of whitespace — PyMuPDF sort=True often inserts
        # huge stretches of spaces between visually-separated segments,
        # which creates ugly leading gaps in the Treeview content column.
        text = _WS_RUN.sub(" ", text).strip()
        # Fix broken-encoding ا+م+ل → ا+ل+م at word starts
        text = _AL_SWAP.sub("الم", text)
        if _platform.system() == "Darwin":
            # PyMuPDF returns logical-order Unicode; CoreText + Geeza Pro
            # handles RTL shaping and bidi rendering natively in tkinter.
            # For mixed Arabic text, pre-swap mirror pairs so brackets read
            # visually correct after bidi mirroring.
            if _HAS_ARABIC.search(text):
                text = text.translate(_BIDI_MIRROR)
            return text
        else:
            reshaped = _arabic_reshaper.reshape(text) if _arabic_reshaper else text
            return _bidi_display(reshaped, base_dir='R') if _bidi_display else reshaped

    def _line_context(line: str, query: str, around: int = 6) -> str:
        """Return a snippet of `line` centered on the token best matching
        `query`. PyMuPDF's sort=True extraction can lump text from many
        visual lines into one logical line; this trims the displayed
        content down to the matched word plus N tokens on each side."""
        from difflib import SequenceMatcher as _SM
        if not line:
            return line
        tokens = line.split()
        if not tokens:
            return line
        q_norm = _normalize_arabic((query or "").strip())
        if not q_norm:
            return " ".join(tokens)
        best_idx, best_score = 0, 0.0
        for i, t in enumerate(tokens):
            s = _SM(None, q_norm, _normalize_arabic(t)).ratio()
            if s > best_score:
                best_idx, best_score = i, s
        if best_score < 0.4:
            # No clear match — fall back to a leading chunk
            return " ".join(tokens[: around * 2 + 1]) + (" …" if len(tokens) > around * 2 + 1 else "")
        lo = max(0, best_idx - around)
        hi = min(len(tokens), best_idx + around + 1)
        snippet = " ".join(tokens[lo:hi])
        if lo > 0:
            snippet = "… " + snippet
        if hi < len(tokens):
            snippet = snippet + " …"
        return snippet

