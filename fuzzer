    def _set_selected_preview_from_iid(iid: str) -> None:
        vals = tree.item(iid, "values")
        if not vals:
            selected_var.set("")
            return

        filepath = _row_paths.get(iid, "")
        filename = os.path.basename(filepath) if filepath else str(
            vals[0]) if len(vals) > 0 else ""

        # values order: (file, line, page, match, score, content)
        try:
            line_num = int(vals[1])
        except Exception:
            line_num = 1

        page_text = str(vals[2]) if len(vals) > 2 else ""
        match_type = str(vals[3]) if len(vals) > 3 else ""
        score_text = str(vals[4]) if len(vals) > 4 else ""
        content = str(vals[5]) if len(vals) > 5 else ""

        score_suffix = ""
        if match_type == "fuzzy" and score_text:
            score_suffix = f" {score_text}%"

        page_suffix = f" (page {page_text})" if page_text else ""

        short = content.strip().replace("\n", " ")
        if len(short) > 160:
            short = short[:157] + "…"

        selected_var.set(
            f"{filename}:{line_num} {match_type}{score_suffix}{page_suffix} — {short}"
        )

