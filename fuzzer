        try:
            # type: ignore[arg-type]
            export_results(results, path)
            status_var.set(f"Exported to {path}")
            _log_activity(f"Exported to {os.path.basename(path)}")
        except Exception as e:
            messagebox.showerror("fuzzer", f"Export failed: {e}")
            _log_activity(f"Export failed: {e}")

    _editor_exts = {'.txt', '.md', '.py', '.js', '.ts', '.jsx', '.tsx',
                    '.json', '.xml', '.html', '.htm', '.rst', '.csv',
                    '.log', '.yaml', '.yml', '.toml', '.ini', '.cfg'}

    def open_selected(event: object = None) -> None:
        # The single-click already selected the row; use that as primary source.
        # identify_row is unreliable on Windows (DPI scaling, scrolled views).
        sel = tree.selection()
        iid = str(sel[0]) if sel else ""
        if not iid and event is not None and hasattr(event, "y"):
            # type: ignore[attr-defined]
            iid = tree.identify_row(event.y) or ""
        if not iid:
            return

        filepath = _row_paths.get(iid, "")
        if not filepath:
            return

        vals = tree.item(iid, "values")
        # values order: (file, line, page, match, score, content)
        try:
            line_num = int(vals[1])
        except (ValueError, IndexError):
            line_num = 1
        try:
            page_num = int(vals[2]) if vals[2] else 0
        except (ValueError, IndexError):
            page_num = 0

        import shutil
        import subprocess
        ext = Path(filepath).suffix.lower()

        def _open_default(path: str) -> None:
            subprocess.Popen(["open", path])

        try:
            if ext == ".pdf":
                open_page = page_num or 1
                # Use the pre-built highlighted copy from populate(); fall back
                # to original if not available (e.g. fitz not installed).
                _tmp_path = _highlighted_pdfs.get(filepath, filepath)
                hl_note = "" if _tmp_path != filepath else " (no highlight — fitz missing?)"

                _esc = _tmp_path.replace("\\", "\\\\").replace('"', '\\"')
                # Open + resize + navigate via ⌘⌥G keyboard shortcut
                _script = "\n".join([
                    'tell application "Preview"',
                    '  activate',
                    f'  open POSIX file "{_esc}"',
                    'end tell',
                    'delay 0.35',
                    'try',
                    '  tell application "System Events"',
                    '    tell process "Preview"',
                    '      tell front window',
                    '        if value of attribute "AXMinimized" is true then',
                    '          set value of attribute "AXMinimized" to false',
                    '        end if',
                    '        set position to {120, 80}',
                    '        set size to {1000, 720}',
                    '      end tell',
                    '    end tell',
                    '  end tell',
                    'end try',
                    f'if {open_page} > 1 then',
                    '  tell application "System Events"',
                    '    tell process "Preview"',
                    '      keystroke "g" using {command down, option down}',
                    '      set n to 0',
                    '      repeat',
                    '        delay 0.06',
                    '        set n to n + 1',
                    '        if n > 30 then exit repeat',
                    '        try',
                    '          tell sheet 1 of front window',
                    f'            set value of text field 1 to "{open_page}"',
                    '            click button "OK"',
                    '          end tell',
                    '          exit repeat',
                    '        end try',
                    '      end repeat',
                    '    end tell',
                    '  end tell',
                    'end if',
                ])
                _as_proc = subprocess.run(
                    ["osascript", "-e", _script],
                    capture_output=True, text=True
                )
                if _as_proc.returncode != 0:
                    _as_err = (_as_proc.stderr or _as_proc.stdout).strip()
                    status_var.set(f"Open failed — {_as_err[:80]}")
                    messagebox.showerror(
                        "fuzzer – open PDF", f"AppleScript error: {_as_err}")
                    return

                status_var.set(
                    f"Opened page {open_page} — {os.path.basename(filepath)}{hl_note}")
                _log_activity(f"Opened PDF '{os.path.basename(filepath)}' page {open_page}"
                              + (" (highlighted)" if _tmp_path != filepath else " (no highlight)"))

            elif ext in _editor_exts:
                if shutil.which("code"):
                    subprocess.Popen(
                        ["code", "--goto", f"{filepath}:{line_num}"])
                elif shutil.which("cursor"):
                    subprocess.Popen(
                        ["cursor", "--goto", f"{filepath}:{line_num}"])
                elif shutil.which("subl"):
                    subprocess.Popen(["subl", f"{filepath}:{line_num}"])
                else:
                    _open_default(filepath)
                status_var.set(
                    f"Opened line {line_num} — {os.path.basename(filepath)}")
                _log_activity(
                    f"Opened '{os.path.basename(filepath)}' line {line_num}")
            else:
                _open_default(filepath)
                status_var.set(f"Opened {os.path.basename(filepath)}")
                _log_activity(f"Opened '{os.path.basename(filepath)}'")
        except Exception as _ex:
            status_var.set(f"Open failed: {_ex}")
            messagebox.showerror("fuzzer", f"Could not open:\n{_ex}")

    # tk.Label has no "command" attribute — wire click manually and gate it on
