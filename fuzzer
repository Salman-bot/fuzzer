    _hover_tip: List[Optional[tk.Toplevel]] = [None]
    _hover_label: List[Optional[ttk.Label]] = [None]
    _hover_iid: List[str] = [""]

    def _hide_hover_tooltip() -> None:
        if _hover_tip[0] is not None:
            with contextlib.suppress(Exception):
                _hover_tip[0].destroy()
            _hover_tip[0] = None
            _hover_label[0] = None
        _hover_iid[0] = ""

    def _ensure_hover_tip() -> None:
        if _hover_tip[0] is not None:
            return
        _hover_tip[0] = tk.Toplevel(root)
        _hover_tip[0].wm_overrideredirect(True)
        _hover_tip[0].attributes("-topmost", True)
        _hover_label[0] = ttk.Label(
            _hover_tip[0],
            background=_T["TIP_BG"],
            foreground=_T["TIP_FG"],
            relief="solid",
            borderwidth=1,
            padding=(6, 3),
            wraplength=720,
        )
        _hover_label[0].pack(fill="both", expand=True)

    def _on_tree_motion(event: object = None) -> None:
        if event is None:
            return
        # Treeview x/y are widget-relative
        x = getattr(event, "x", 0)
        y = getattr(event, "y", 0)

        col = tree.identify_column(x)  # e.g. "#6"
        # content column index is 6 (("file","line","page","match","score","content"))
        if col != "#6":
            _hide_hover_tooltip()
            return

        iid = tree.identify_row(y)
        if not iid:
            _hide_hover_tooltip()
            return

        text = _row_full_lines.get(iid, "")
        if not text:
            _hide_hover_tooltip()
            return

        if _hover_tip[0] is None:
            _ensure_hover_tip()

        if iid != _hover_iid[0]:
            _hover_iid[0] = iid
            # Build a source header so the user knows where this snippet came
            # from without selecting the row. Format: "<basename>  ·  line 42
            # · page 7" (page omitted for non-PDF files).
            src_path = _row_paths.get(iid, "")
            vals = tree.item(iid, "values")
            try:
                _line_no = str(vals[1])
            except (IndexError, TypeError):
                _line_no = ""
            try:
                _page_no = str(vals[2]) if vals[2] else ""
            except (IndexError, TypeError):
                _page_no = ""
            _src_bits = []
            if src_path:
                _src_bits.append(os.path.basename(src_path))
            if _line_no:
                _src_bits.append(f"line {_line_no}")
            if _page_no:
                _src_bits.append(f"page {_page_no}")
            header = "  ·  ".join(_src_bits)
            tip_text = f"{header}\n\n{text}" if header else text
            if _hover_label[0] is not None:
                _hover_label[0].config(text=tip_text)

        # position tooltip near cursor
        tip_x = tree.winfo_rootx() + x + 16
        tip_y = tree.winfo_rooty() + y + 20
        if _hover_tip[0] is not None:
            _hover_tip[0].wm_geometry(f"+{tip_x}+{tip_y}")

    def _on_tree_leave(_event: object = None) -> None:
        _hide_hover_tooltip()

    tree.bind("<Motion>", _on_tree_motion, add="+")
    tree.bind("<Leave>", _on_tree_leave, add="+")

    tree.bind("<Double-1>", open_selected)
    tree.bind("<Return>", open_selected)
    # Selected-result line opens the file on click (mirrors double-click on tree).
    _sel_w = _selected_widget_ref[0]
    if _sel_w is not None:
        _sel_w.bind("<Button-1>", lambda _e: open_selected())
        _sel_w.configure(cursor="hand2")
    pattern_entry.bind("<Return>", lambda _e: start_search())
    files_entry.bind("<Return>", lambda _e: start_search())

    # ── top menu: Mode → Debug toggle ────────────────────────────────────────
    # Wired here (rather than near root.title) so dbg_frame already exists and
    # the toggle can pack/forget it directly.
    mode_menu = tk.Menu(menubar, tearoff=False)

    def _toggle_theme(_event: object = None) -> None:
        new = "dark" if _theme_name[0] == "light" else "light"
        _theme_name[0] = new
        _T.update(_DARK_PAL if new == "dark" else _LIGHT_PAL)
        _gui_state["theme"] = new
        _configure_ttk_styles(_T)
        _apply_raw_colors(_T)
        _moon_label = "☀  Light mode" if new == "dark" else "🌙  Dark mode"
        with contextlib.suppress(Exception):
            mode_menu.entryconfigure(0, label=_moon_label)
        status_var.set(f"{'Dark 🌙' if new == 'dark' else 'Light ☀'} mode")

    _moon_label_init = "☀  Light mode" if _theme_name[0] == "dark" else "🌙  Dark mode"
    mode_menu.add_command(
        label=_moon_label_init,
        accelerator="Ctrl+Shift+D",
        command=_toggle_theme,
    )
    root.bind_all("<Control-Shift-d>", _toggle_theme)
    root.bind_all("<Command-Shift-d>", _toggle_theme)
    mode_menu.add_separator()

    debug_mode_var = tk.BooleanVar(value=_DEBUG_NATIVE)

    def _toggle_debug_mode() -> None:
        enable = bool(debug_mode_var.get())
        _set_debug_native(enable)
        if enable:
            dbg_frame.pack(fill="x", side="bottom", padx=10, pady=(2, 2))
            status_var.set("Debug mode ON — native call inspector visible")
        else:
            dbg_frame.pack_forget()
            status_var.set("Debug mode OFF — normal view")
        _gui_state["debug_mode"] = enable
        _save_state(_gui_state)

    mode_menu.add_checkbutton(
        label="Debug mode",
        variable=debug_mode_var,
        command=_toggle_debug_mode,
        accelerator="⌘D",
    )
    mode_menu.add_separator()
    mode_menu.add_command(label="Normal mode",
                          command=lambda: (debug_mode_var.set(False),
                                           _toggle_debug_mode()))

    def _clear_saved_data() -> None:
        if not messagebox.askyesno(
            "Clear saved data",
            "This will clear all saved state:\n"
            "  • Search history\n"
            "  • Last pattern and files\n"
            "  • Window size and option toggles\n\n"
            "Continue?",
            icon="warning",
        ):
            return
        with contextlib.suppress(Exception):
            _STATE_FILE.unlink()
        _gui_state.clear()
        pattern_var.set("")
        files_var.set("")
        _search_history.clear()
        pattern_entry.config(values=[])
        case_var.set(False)
        recursive_var.set(False)
        rga_var.set(False)
        threshold_var.set(80)
        debug_mode_var.set(False)
        _toggle_debug_mode()
        status_var.set("Saved data cleared.")
        _log_activity("Saved data cleared")

    mode_menu.add_separator()
    mode_menu.add_command(label="Clear saved data…", command=_clear_saved_data)
    menubar.add_cascade(label="Mode", menu=mode_menu)

    def _kbd_toggle(_e: object = None) -> str:
        debug_mode_var.set(not debug_mode_var.get())
        _toggle_debug_mode()
        return "break"

    root.bind_all("<Command-d>", _kbd_toggle)
    root.bind_all("<Control-d>", _kbd_toggle)

    pattern_entry.focus_set()

    def _on_close() -> None:
        with contextlib.suppress(Exception):
            _gui_state["window_geometry"] = root.geometry()
            _gui_state["window_state"] = root.state()
            _save_state(_gui_state)
        # PyMuPDF's C++ global destructor segfaults under Python 3.14 + Tcl/Tk 9
        # at process exit (fz_flush_warnings → unicode_decode_utf8 on a freed
        # context). Skip Python's atexit chain by hard-exiting after state is
        # flushed to disk.
        os._exit(0)

    root.protocol("WM_DELETE_WINDOW", _on_close)
    # macOS Cmd+Q routes through tk::mac::Quit, NOT WM_DELETE_WINDOW. Hook it
    # so the os._exit short-circuit also runs there (otherwise Python proceeds
    # to atexit and triggers the PyMuPDF destructor crash).
    with contextlib.suppress(Exception):
        root.createcommand("tk::mac::Quit", _on_close)

    # Restore window state (maximized / normal). Apply after geometry so the
    # restore size is set before zooming — deiconify then zoom on Windows.
    # When NOT maximizing, also auto-fit (so the chat panel isn't clipped) and
    # center on screen.
    def _open_layout() -> None:
        with contextlib.suppress(Exception):
            if _saved_geom:
                # User has a saved size — honor it exactly. No auto-fit
                # (would override the user's chosen size).
                pass
            elif _saved_state == "zoomed":
                # Legacy-saved zoomed state without geometry: unzoom and use default.
                root.state("normal")
                root.geometry(_default_geometry())
            # else: _default_geometry() already applied above.

    root.after(10, _open_layout)

    # Apply initial theme. ttk styles above were configured with light-mode
    # constants — reapply with the active palette so a saved dark theme takes
    # effect on startup, not just after toggling.
    _configure_ttk_styles(_T)
    _apply_raw_colors(_T)

    # Land focus on the search input as soon as the window is realized, and
    # re-focus it whenever the window comes back from the background with no
    # specific widget owning focus. Feels like a search bar (open → type →
    # search) rather than having to click first. `after_idle` waits until Tk
    # has finished mapping widgets so focus_set sticks reliably on macOS.
    root.after_idle(lambda: pattern_entry.focus_set())

    def _refocus_on_window_activate(_e: object) -> None:
        # Widget-specific bind (not bind_all) → only fires when root itself
        # is the FocusIn target, which is the macOS signal that the window
        # was just activated. Guard against stealing focus from a child the
        # user has already clicked into.
        with contextlib.suppress(Exception):
            cur = root.focus_get()
            if cur in (None, root):
                pattern_entry.focus_set()
    root.bind("<FocusIn>", _refocus_on_window_activate)

    root.after(100, poll_queue)
    root.mainloop()
    return 0

# ── CLI ────────────────────────────────────────────────────────────────────────


if __name__ == "__main__":
    sys.exit(run_gui())


