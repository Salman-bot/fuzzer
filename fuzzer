    def _tool_list_results() -> str:
        results = state.get("results", {})  # type: ignore[assignment]
        if not results:
            return ("No search results loaded. Run a search first "
                    "(the user can do this; you cannot trigger it).")
        out = []
        for fp, (_lines, matches) in results.items():  # type: ignore[misc]
            sample = []
            for m in matches[:5]:
                pg = f" p.{m.page_num}" if m.page_num else ""
                sample.append(f"L{m.line_num}{pg} (score={m.score}): "
                              f"{m.line.strip()[:120]}")
            out.append({
                "path": fp,
                "match_count": len(matches),
                "samples": sample,
            })
        import json as _json
        return _json.dumps(out, ensure_ascii=False, indent=2)

    def _tool_search_in_context(query: str, exact: bool = False,
                                threshold: int = _CHAT_SEARCH_DEFAULT_THRESHOLD,
                                max_results: int = _CHAT_SEARCH_DEFAULT_MAX,
                                whole_word: bool = False) -> str:
        """Fuzzy-search the user's loaded files. Reuses search_file() so the
        results match what the user sees in the GUI."""
        if not query:
            return "error: query is required"
        paths = chat_state.get("context_files", []) or []
        if not paths:
            return ("No files loaded into context. Ask the user to add paths "
                    "to the Files/folders entry above.")
        max_results = max(
            1, min(int(max_results or _CHAT_SEARCH_DEFAULT_MAX), 500))
        threshold = max(
            0, min(int(threshold or _CHAT_SEARCH_DEFAULT_THRESHOLD), 100))
        hits: List[str] = []
        per_file_counts: Dict[str, int] = {}
        for fp in paths:  # type: ignore[union-attr]
            _lines, matches = search_file(
                fp, query,
                case_sensitive=False,
                threshold=threshold,
            )
            per_file_counts[fp] = len(matches)
            for m in matches:
                tag = (f"[p.{m.page_num} L{m.line_num}]"
                       if m.page_num else f"[L{m.line_num}]")
                snippet = m.line.strip()[:200]
                hits.append(
                    f"{os.path.basename(fp)} {tag} (score {m.score}): {snippet}")
                if len(hits) >= max_results:
                    break
            if len(hits) >= max_results:
                break
        total_matches = sum(per_file_counts.values())
        files_with_hits = sum(1 for c in per_file_counts.values() if c)
        if not hits:
            return (f"no matches for {query!r} "
                    f"(threshold={threshold}, exact={bool(exact)}, "
                    f"whole_word={bool(whole_word)}) "
                    f"across {len(paths)} loaded file(s)")
        truncated_note = ""
        if total_matches > len(hits):
            truncated_note = (f"\n… (+{total_matches - len(hits)} more matches "
                              f"not shown — raise max_results or narrow query)")
        header = (f"{len(hits)} of {total_matches} match(es) across "
                  f"{files_with_hits} file(s):\n")
        return header + "\n".join(hits) + truncated_note

    def _tool_read_chunk(path: str, start_line: int = 1, max_lines: int = 200) -> str:
        if not path:
            return "error: path is required"
        max_lines = max(1, min(int(max_lines or 200), 1000))
        start_line = max(1, int(start_line or 1))
        try:
            with open(path, encoding="utf-8", errors="replace") as f:
                all_lines = f.readlines()
        except Exception as e:
            return f"error reading {path}: {type(e).__name__}: {e}"
        chunk = all_lines[start_line - 1: start_line - 1 + max_lines]
        if not chunk:
            return (f"(empty — file has {len(all_lines)} lines, "
                    f"requested start_line={start_line})")
        body = "".join(f"{start_line + i}: {ln}" for i, ln in enumerate(chunk))
        suffix = ""
        if start_line - 1 + max_lines < len(all_lines):
            suffix = f"\n… (file has {len(all_lines)} lines total)"
        return body + suffix

    def _resolve_tool_path(path: str) -> str:
        """Resolve a relative path the chat tools were given against the
        project directory (/Users/salman/bin). Absolute paths and ~-paths
        are honored as-is."""
        if not path:
            return path
        p = Path(path).expanduser()
        if not p.is_absolute():
            p = _PROJECT_DIR / p
        return str(p)

    def _tool_write(path: str, content: str, append: bool = False) -> str:
        if not path:
            return "error: path is required"
        path = _resolve_tool_path(path)
        mode = "a" if append else "w"
        verb = "appended" if append else "wrote"
        try:
            Path(path).parent.mkdir(parents=True, exist_ok=True)
            with open(path, mode, encoding="utf-8") as f:
                f.write(content)
            return f"{verb} {len(content)} chars to {path}"
        except PermissionError:
            if _ask_admin(f"{'append to' if append else 'write'} {path}"):
                import tempfile
                tmp = tempfile.mktemp(suffix=".txt")
                try:
                    Path(tmp).write_text(content, encoding="utf-8")
                    import subprocess
                    subprocess.run(
                        ["sudo", "cp" if not append else "sh", tmp, path],
                        timeout=60,
                    )
                    return f"{verb} {len(content)} chars to {path} (as admin)"
                except Exception as e:
                    return f"error (elevated): {e}"
                finally:
                    with contextlib.suppress(OSError):
                        Path(tmp).unlink()
            return f"error: permission denied writing {path}"
        except Exception as e:
            return f"error writing {path}: {type(e).__name__}: {e}"

    def _tool_create_dir(path: str) -> str:
        if not path:
            return "error: path is required"
        path = _resolve_tool_path(path)
        try:
            Path(path).mkdir(parents=True, exist_ok=True)
            return f"created directory: {path}"
        except PermissionError:
            if _ask_admin(f"create directory {path}"):
                import subprocess
                subprocess.run(["sudo", "mkdir", "-p", path], timeout=60)
                return f"created directory (as admin): {path}"
            return f"error: permission denied creating {path}"
        except Exception as e:
            return f"error: {type(e).__name__}: {e}"

    def _tool_delete(path: str, recursive: bool = False) -> str:
        if not path:
            return "error: path is required"
        path = _resolve_tool_path(path)
        p = Path(path)
        try:
            if p.is_dir():
                if recursive:
                    import shutil
                    shutil.rmtree(path)
                else:
                    p.rmdir()
            else:
                p.unlink()
            return f"deleted: {path}"
        except PermissionError:
            if _ask_admin(f"delete {path}"):
                import subprocess
                cmd = ["sudo", "rm", "-rf" if recursive else "-f", path]
                subprocess.run(cmd, timeout=60)
                return f"deleted (as admin): {path}"
            return f"error: permission denied deleting {path}"
        except Exception as e:
            return f"error: {type(e).__name__}: {e}"

    def _tool_copy(src: str, dst: str) -> str:
        if not src or not dst:
            return "error: src and dst are required"
        src = _resolve_tool_path(src)
        dst = _resolve_tool_path(dst)
        import shutil
        try:
            if Path(src).is_dir():
                shutil.copytree(src, dst)
            else:
                Path(dst).parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(src, dst)
            return f"copied {src} → {dst}"
        except Exception as e:
            return f"error: {type(e).__name__}: {e}"

    def _tool_move(src: str, dst: str) -> str:
        if not src or not dst:
            return "error: src and dst are required"
        src = _resolve_tool_path(src)
        dst = _resolve_tool_path(dst)
        import shutil
        try:
            Path(dst).parent.mkdir(parents=True, exist_ok=True)
            shutil.move(src, dst)
            return f"moved {src} → {dst}"
        except PermissionError:
            if _ask_admin(f"move {src} → {dst}"):
                import subprocess
                subprocess.run(["sudo", "mv", src, dst], timeout=60)
                return f"moved (as admin): {src} → {dst}"
            return f"error: permission denied moving {src}"
        except Exception as e:
            return f"error: {type(e).__name__}: {e}"

    def _tool_run_command(
        command: str,
        working_dir: str = "",
        timeout: int = 60,
        as_admin: bool = False,
    ) -> str:
        if not command:
            return "error: command is required"
        import subprocess
        cwd = working_dir or str(Path(_script_dir))
        timeout = max(1, min(int(timeout or 60), 300))
        if as_admin:
            if not _ask_admin(f"run: {command}"):
                return "cancelled: user declined admin access"
            code, out = _run_elevated(command, cwd)
            return out or f"(exited {code})"
        try:
            r = subprocess.run(
                command,
                shell=True,
                capture_output=True,
                text=True,
                timeout=timeout,
                cwd=cwd,
                encoding="utf-8",
                errors="replace",
            )
            out = (r.stdout + r.stderr).strip()
            if r.returncode != 0 and "denied" in out.lower():
                if _ask_admin(f"run: {command}"):
                    code, out2 = _run_elevated(command, cwd)
                    return out2 or f"(exited {code})"
            return out or f"(exited {r.returncode})"
        except subprocess.TimeoutExpired:
            return f"error: command timed out after {timeout}s"
        except Exception as e:
            return f"error: {type(e).__name__}: {e}"

    def _dispatch_tool(name: str, args: dict) -> str:
        if name == "list_results":
            return _tool_list_results()
        if name == "read_file_chunk":
            return _tool_read_chunk(
                args.get("path", ""),
                args.get("start_line", 1),
                args.get("max_lines", 200),
            )
        if name == "search_in_context":
            return _tool_search_in_context(
                args.get("query", ""),
                bool(args.get("exact", False)),
                int(args.get("threshold", _CHAT_SEARCH_DEFAULT_THRESHOLD)),
                int(args.get("max_results", _CHAT_SEARCH_DEFAULT_MAX)),
                whole_word=bool(args.get("whole_word", False)),
            )
        if name == "write_file":
            return _tool_write(args.get("path", ""), args.get("content", ""),
                               append=False)
        if name == "append_to_file":
            return _tool_write(args.get("path", ""), args.get("content", ""),
                               append=True)
        if name == "create_directory":
            return _tool_create_dir(args.get("path", ""))
        if name == "delete_path":
            return _tool_delete(args.get("path", ""),
                                bool(args.get("recursive", False)))
        if name == "copy_file":
            return _tool_copy(args.get("src", ""), args.get("dst", ""))
        if name == "move_file":
            return _tool_move(args.get("src", ""), args.get("dst", ""))
        if name == "run_command":
            return _tool_run_command(
                args.get("command", ""),
                args.get("working_dir", ""),
                int(args.get("timeout", 60)),
                bool(args.get("as_admin", False)),
            )
        return f"unknown tool: {name}"

    def _update_chat_state() -> None:
        _set_chat_entry_state("normal")
        chat_send_btn.config(state="normal")
        chat_reset_btn.config(state="normal")

    def _append_chat(tag: str, prefix: str, text: str) -> None:
        chat_log.config(state="normal")
        start = chat_log.index("end-1c")
        chat_log.insert("end", f"{prefix}: {text}\n", tag)
        chat_log.see("end")
        chat_log.config(state="disabled")
        _scan_chat_paths(start)
        _scan_chat_markdown(start)

    # Cumulative token usage for this session — written by the chat worker,
    # rendered after each Claude turn by _show_chat_usage().
    _chat_session_usage: Dict[str, int] = {
        "input": 0, "output": 0, "cache_read": 0, "cache_create": 0,
        "turns": 0,
    }

    def _show_chat_usage(turn: dict, session: dict) -> None:
        """Append a small italic 'usage' line after a Claude turn ends.
        Shows this turn's token spend plus running session totals so the
        user can keep an eye on rate-limit pressure."""
        def _fmt(d: dict) -> str:
            parts = [f"in {d.get('input', 0):,}",
                     f"out {d.get('output', 0):,}"]
            if d.get("cache_read"):
                parts.append(f"cache {d['cache_read']:,} read")
            if d.get("cache_create"):
                parts.append(f"cache {d['cache_create']:,} new")
            return "  ·  ".join(parts)

        line = (f"📊  this turn: {_fmt(turn)}  tok"
                f"   ·   session ({session.get('turns', 0)} turns): "
                f"{_fmt(session)}  tok\n")
        chat_log.config(state="normal")
        chat_log.insert("end", line, "usage")
        chat_log.see("end")
        chat_log.config(state="disabled")

    # Inline streaming helpers: write a prefix once, then append deltas, then
    # finish with newline. Lets text appear character-by-character while
    # Claude is still generating. _turn_start tracks where the current turn
    # began so we can scan the whole turn for clickable paths at end.
    _turn_start: Dict[str, str] = {}

    def _chat_begin_turn(tag: str, prefix: str) -> None:
        chat_log.config(state="normal")
        _turn_start[tag] = chat_log.index("end-1c")
        chat_log.insert("end", f"{prefix}: ", tag)
        chat_log.see("end")
        chat_log.config(state="disabled")

    def _chat_append_text(tag: str, text: str) -> None:
        chat_log.config(state="normal")
        chat_log.insert("end", text, tag)
        chat_log.see("end")
        chat_log.config(state="disabled")

    def _chat_end_turn(tag: str) -> None:
        chat_log.config(state="normal")
        chat_log.insert("end", "\n", tag)
        chat_log.see("end")
        chat_log.config(state="disabled")
        start = _turn_start.pop(tag, None)
        if start is not None:
            _scan_chat_paths(start)
            _scan_chat_markdown(start)

    # Animated "claude is thinking…" indicator. Insert returns a handle; pass
    # it back to _stop_thinking() to remove the line when the response lands.
    _thinking_handles: Dict[str, dict] = {}

    _thinking_counter = [0]

    def _start_thinking(label: str = "claude is thinking") -> str:
        _thinking_counter[0] += 1
        handle_id = f"thk_{_thinking_counter[0]}"
        chat_log.config(state="normal")
        start_idx = chat_log.index("end-1c")
        chat_log.insert("end", f"{label}\n", "thinking")
        chat_log.config(state="disabled")
        chat_log.see("end")
        info = {"start": start_idx, "label": label, "alive": True, "dots": 0}
        _thinking_handles[handle_id] = info

        def _tick():
            if not info["alive"]:
                return
            info["dots"] = (info["dots"] + 1) % 4
            dots = "." * info["dots"] + " " * (3 - info["dots"])
            chat_log.config(state="normal")
            line_end = f"{info['start']} lineend"
            chat_log.delete(info["start"], line_end)
            chat_log.insert(info["start"], f"{label}{dots}", "thinking")
            chat_log.config(state="disabled")
            root.after(350, _tick)

        root.after(350, _tick)
        return handle_id

    def _stop_thinking(handle_id: str) -> None:
        info = _thinking_handles.pop(handle_id, None)
        if not info:
            return
        info["alive"] = False
        try:
            chat_log.config(state="normal")
            # Remove the entire line (the indicator + its trailing newline).
            chat_log.delete(info["start"], f"{info['start']} lineend +1c")
            chat_log.config(state="disabled")
        except Exception:
            pass

    def _update_chat_context_label() -> None:
        included = chat_state["context_files"]  # type: ignore[index]
        chars = int(chat_state["context_chars"])  # type: ignore[arg-type]
        if included:
            names = ", ".join(os.path.basename(p)
                              # type: ignore[union-attr]
                              for p in included[:3])
            if len(included) > 3:  # type: ignore[arg-type]
                # type: ignore[arg-type]
                names += f" + {len(included) - 3} more"
            chat_context_var.set(
                f"Context: {names}  ·  {chars/1000:.1f}k chars")
        else:
            chat_context_var.set(
                "Context: (none — add files above to ground answers)")

    def _build_chat_context(paths: List[str], recursive: bool
                            ) -> Tuple[str, List[str], int, int]:
        """Build a *manifest* of the user's selected files — just paths,
        sizes, and a one-line preview. Claude reads actual content on demand
        via the search_in_context and read_file_chunk tools, which keeps the
        per-turn input small enough for low rate-limit tiers.
        Returns (manifest, included_paths, total_chars, total_files)."""
        files = collect_files(paths, recursive)
        total = len(files)
        entries: List[str] = []
        included: List[str] = []
        used = 0
        for fp in files:
            if used >= _CHAT_CONTEXT_BUDGET:
                break
            lines = read_lines(fp)
            if not lines:
                continue
            pg_map = _pdf_page_map.get(fp, [])
            n_lines = len(lines)
            n_pages = max(pg_map) if pg_map else 0
            # First non-empty line as a preview
            preview = next((ln.strip() for ln in lines[:20] if ln.strip()), "")
            if len(preview) > 140:
                preview = preview[:140] + "…"
            meta_bits = [f"{n_lines} lines"]
            if n_pages:
                meta_bits.append(f"{n_pages} pages")
            entry = (
                f"- {os.path.basename(fp)} "
                f"({', '.join(meta_bits)})\n"
                f"  path: {fp}\n"
                f"  preview: {preview}\n"
            )
            if used + len(entry) > _CHAT_CONTEXT_BUDGET:
                break
            entries.append(entry)
            included.append(fp)
            used += len(entry)
        return "".join(entries), included, used, total

    def _reset_chat(_event: object = None) -> None:
        chat_state["messages"] = []
        chat_state["files_sig"] = ""
        chat_state["context_files"] = []
        chat_state["context_chars"] = 0
        _show_chat_welcome()
        _chat_welcome_shown[0] = True
        _update_chat_context_label()
        _chat_history_clear()
        _log_activity("Chat conversation reset")

    def _send_chat(_event: object = None) -> str:
        msg = chat_entry.get("1.0", "end-1c").strip()
        if not msg:
            return "break"
        api_key = str(_gui_state.get("api_key")
                      or os.environ.get("ANTHROPIC_API_KEY") or "")
        if not api_key:
            _clear_chat_welcome_if_needed()
            _append_chat("err", "error",
                         "No API key — click 'API Key…' to set your Anthropic key.")
            _log_activity("Chat blocked — no API key")
            return "break"
        _clear_chat_welcome_if_needed()
        if msg in _chat_input_history:
            _chat_input_history.remove(msg)
        _chat_input_history.insert(0, msg)
        del _chat_input_history[_CHAT_INPUT_HISTORY_CAP:]
        _gui_state["chat_input_history"] = _chat_input_history
        _chat_history_state["idx"] = -1
        _chat_history_state["draft"] = ""
        chat_entry.delete("1.0", "end")
        _user_turn_start = chat_log.index("end-1c")
        _append_chat("you", "you", msg)
        _chat_history_add(msg, _user_turn_start)
        _log_activity(f"Chat sent: {msg[:80]}{'…' if len(msg) > 80 else ''}")
        _set_chat_entry_state("disabled")
        chat_send_btn.config(state="disabled")
        chat_reset_btn.config(state="disabled")

        # If the Files/folders selection changed (or this is the first turn
        # with files), rebuild file context and reset the conversation.
        paths = parse_files_field(files_var.get())
        sig = "\0".join(sorted(paths))
        if paths and sig != chat_state["files_sig"]:
            _append_chat("sys", "system", "Loading files into context…")
            body, included, used, total_found = _build_chat_context(
                paths, recursive_var.get())
            chat_state["files_sig"] = sig
            chat_state["context_files"] = included
            chat_state["context_chars"] = used
            if body:
                chat_state["messages"] = [
                    {
                        "role": "user",
                        "content": (
                            "I'll ask you questions about my files. Below is a "
                            "manifest of what's loaded — paths, sizes, and a "
                            "one-line preview. To answer, use the "
                            "search_in_context tool to find relevant lines, "
                            "then read_file_chunk to read more around a hit. "
                            "Cite line tags like [L42] or [p.3 L42] when "
                            "quoting passages.\n\n"
                            "MANIFEST:\n"
                            + body
                        ),
                    },
                    {
                        "role": "assistant",
                        "content": (
                            f"Manifest received: {len(included)} file(s). "
                            f"I'll search and read on demand using tools "
                            f"instead of loading full content. Ask away."
                        ),
                    },
                ]
                # Manifest is small (paths + previews only) so this rarely
                # trips, but warn if the user selected enough files to overflow.
                approx_tokens = used // 4
                files_skipped = max(0, total_found - len(included))
                if used >= _CHAT_CONTEXT_BUDGET:
                    _append_chat("err", "warning",
                                 f"Manifest budget full "
                                 f"({used:,}/{_CHAT_CONTEXT_BUDGET:,} chars, "
                                 f"~{approx_tokens:,} tokens) — "
                                 f"{files_skipped} file(s) not listed. "
                                 f"Claude can still reach them by exact path "
                                 f"via read_file_chunk if you mention them.")
                elif used >= _CHAT_CONTEXT_WARN:
                    pct = used * 100 // _CHAT_CONTEXT_BUDGET
                    _append_chat("sys", "note",
                                 f"Large manifest: {used:,} chars "
                                 f"(~{approx_tokens:,} tokens, {pct}% of budget). "
                                 f"Content is still fetched lazily.")
            else:
                chat_state["messages"] = []
            _update_chat_context_label()

        # Build the request payload (cap history but always keep the leading
        # context turn pair so file content stays available across many turns).
        history = list(chat_state["messages"])  # type: ignore[arg-type]
        if chat_state["context_files"]:
            head = history[:2]
            tail = history[2:][-_CHAT_MAX_HISTORY:]
            messages = head + tail + [{"role": "user", "content": msg}]
        else:
            tail = history[-_CHAT_MAX_HISTORY:]
            messages = tail + [{"role": "user", "content": msg}]

        def _worker() -> None:
            try:
                import anthropic as _ant
                client = _ant.Anthropic(api_key=api_key)
                system_prompt = (
                    "You are a research assistant embedded in a file-search tool.\n\n"
                    "FILE ACCESS — IMPORTANT:\n"
                    "When the user loads files, you receive a MANIFEST (paths, "
                    "line counts, one-line previews) — NOT the file content. "
                    "Read content lazily, on demand, using tools. This keeps "
                    "the per-turn input small enough for tight API rate limits.\n\n"
                    "Strategy:\n"
                    "  1. Use search_in_context FIRST to find relevant lines "
                    "across all loaded files (cheap and broad).\n"
                    "  2. Use read_file_chunk to read a focused range around "
                    "any hit that needs more context.\n"
                    "  3. Cite line tags like [L42] or [p.3 L42] when quoting "
                    "passages so the user can jump to them.\n"
                    "  4. Avoid reading whole files. Pull only what you need.\n\n"
                    "Tools available:\n"
                    "  • search_in_context — fuzzy search across loaded files (start here)\n"
                    "  • read_file_chunk — read a specific line range from one file\n"
                    "  • list_results — see files the user's last (non-AI) search hit\n"
                    "  • write_file / append_to_file — produce summaries, extracts, scripts\n"
                    "  • create_directory / delete_path / copy_file / move_file — file ops\n"
                    "  • run_command — run shell commands\n\n"
                    f"OUTPUT DIRECTORY: When you write files, save them under "
                    f"{_PROJECT_DIR} by default. Use a plain filename or a "
                    "relative path (e.g. `notes.md`, `out/summary.txt`) — the "
                    "tool resolves it against that directory automatically. "
                    "Only use an absolute path when the user explicitly asks "
                    "you to write somewhere else.\n\n"
                    "If the user asks a general question that doesn't need their "
                    "files, answer directly without calling tools."
                )

                current = list(messages)
                final_text_parts: List[str] = []
                turn_usage = {"input": 0, "output": 0,
                              "cache_read": 0, "cache_create": 0}
                # mutable so the lambda below can read it
                think_box = {"id": None}

                def _begin_think(label: str) -> None:
                    think_box["id"] = _start_thinking(label)

                def _end_think() -> None:
                    if think_box["id"]:
                        _stop_thinking(think_box["id"])
                        think_box["id"] = None

                for _round in range(_CHAT_TOOL_ROUNDS):
                    label = ("claude is thinking" if _round == 0
                             else f"claude is working (round {_round + 1})")
                    root.after(0, _begin_think, label)

                    # Streaming state for this round
                    text_for_round: List[str] = []
                    text_turn_open = [False]
                    thinking_turn_open = [False]

                    def _close_open_turns() -> None:
                        if thinking_turn_open[0]:
                            _chat_end_turn("thinking")
                            thinking_turn_open[0] = False
                        if text_turn_open[0]:
                            _chat_end_turn("claude")
                            text_turn_open[0] = False

                    # Try with extended thinking enabled (interleaved with tools,
                    # via beta header). If the API rejects it on enter, fall
                    # back to a plain streaming call.
                    def _open_stream(with_thinking: bool):
                        model_id = str(_gui_state.get("claude_model")
                                       or "claude-sonnet-4-6")
                        kwargs = dict(
                            model=model_id,
                            max_tokens=_CHAT_MAX_TOKENS,
                            system=system_prompt,
                            tools=_CHAT_TOOLS,
                            messages=current,
                        )
                        if with_thinking:
                            kwargs["thinking"] = {
                                "type": "enabled",
                                "budget_tokens": _CHAT_THINKING_BUDGET}
                            kwargs["extra_headers"] = {
                                "anthropic-beta": "interleaved-thinking-2025-05-14"
                            }
                        return client.messages.stream(**kwargs)

                    def _capture_ratelimit(stream_obj) -> None:
                        """Pull anthropic-ratelimit-* headers off the live
                        stream's response and push a one-line summary to the
                        chat header. Best-effort; the SDK exposes the response
                        via a few different attributes depending on version."""
                        try:
                            resp = (getattr(stream_obj, "response", None)
                                    or getattr(stream_obj, "_response", None))
                            if resp is None:
                                return
                            h = getattr(resp, "headers", None) or {}
                            def _g(k: str) -> str:
                                v = h.get(k) if hasattr(h, "get") else None
                                return str(v) if v is not None else ""
                            in_rem = _g("anthropic-ratelimit-input-tokens-remaining")
                            in_lim = _g("anthropic-ratelimit-input-tokens-limit")
                            out_rem = _g("anthropic-ratelimit-output-tokens-remaining")
                            out_lim = _g("anthropic-ratelimit-output-tokens-limit")
                            req_rem = _g("anthropic-ratelimit-requests-remaining")

                            def _fmt(n: str) -> str:
                                try:
                                    v = int(n)
                                    if v >= 1_000_000:
                                        return f"{v/1_000_000:.1f}M"
                                    if v >= 1000:
                                        return f"{v/1000:.1f}k"
                                    return str(v)
                                except (TypeError, ValueError):
                                    return n or "?"
                            parts = []
                            if in_rem and in_lim:
                                parts.append(f"in {_fmt(in_rem)}/{_fmt(in_lim)}")
                            if out_rem and out_lim:
                                parts.append(f"out {_fmt(out_rem)}/{_fmt(out_lim)}")
                            if req_rem:
                                parts.append(f"req {_fmt(req_rem)}")
                            label = " · ".join(parts)
                            if label:
                                root.after(0,
                                           lambda lbl=label:
                                               _chat_ratelimit_var.set(lbl))
                        except Exception:
                            pass

                    def _consume_stream(with_thinking: bool):
                        text_for_round.clear()
                        with _open_stream(with_thinking=with_thinking) as _s:
                            for event in _s:
                                etype = getattr(event, "type", None)
                                if etype == "content_block_start":
                                    cb = getattr(event, "content_block", None)
                                    cbt = getattr(cb, "type", None)
                                    if cbt == "thinking":
                                        root.after(0, _end_think)
                                        root.after(0, _chat_begin_turn,
                                                   "thinking", "💭 thinking")
                                        thinking_turn_open[0] = True
                                    elif cbt == "text":
                                        root.after(0, _end_think)
                                        if thinking_turn_open[0]:
                                            root.after(
                                                0, _chat_end_turn, "thinking")
                                            thinking_turn_open[0] = False
                                        root.after(0, _chat_begin_turn,
                                                   "claude", "claude")
                                        text_turn_open[0] = True
                                elif etype == "content_block_delta":
                                    delta = getattr(event, "delta", None)
                                    dtype = getattr(delta, "type", None)
                                    if dtype == "text_delta":
                                        t = delta.text or ""
                                        text_for_round.append(t)
                                        root.after(
                                            0, _chat_append_text, "claude", t)
                                    elif dtype == "thinking_delta":
                                        t = getattr(
                                            delta, "thinking", "") or ""
                                        root.after(
                                            0, _chat_append_text, "thinking", t)
                                elif etype == "content_block_stop":
                                    if thinking_turn_open[0]:
                                        root.after(
                                            0, _chat_end_turn, "thinking")
                                        thinking_turn_open[0] = False
                            _capture_ratelimit(_s)
                            return _s.get_final_message()

                    try:
                        try:
                            final_msg = _consume_stream(with_thinking=True)
                        except Exception as e:
                            err_text = str(e).lower()
                            if "thinking" in err_text or "beta" in err_text:
                                root.after(0, lambda: _append_chat(
                                    "sys", "system",
                                    "(extended thinking not available — "
                                    "retrying without)"))
                                # Close any partial blocks before retry
                                root.after(0, _close_open_turns)
                                root.after(0, _begin_think,
                                           "claude is working")
                                final_msg = _consume_stream(
                                    with_thinking=False)
                            else:
                                raise
                    finally:
                        root.after(0, _end_think)
                        root.after(0, _close_open_turns)

                    # Tally token usage for this round.
                    _u = getattr(final_msg, "usage", None)
                    if _u is not None:
                        turn_usage["input"] += int(
                            getattr(_u, "input_tokens", 0) or 0)
                        turn_usage["output"] += int(
                            getattr(_u, "output_tokens", 0) or 0)
                        turn_usage["cache_read"] += int(
                            getattr(_u, "cache_read_input_tokens", 0) or 0)
                        turn_usage["cache_create"] += int(
                            getattr(_u, "cache_creation_input_tokens", 0) or 0)

                    # Reconstruct assistant block list for the next round's request.
                    tool_uses: List[object] = []
                    assistant_blocks: List[dict] = []
                    for b in final_msg.content:
                        btype = getattr(b, "type", None)
                        if btype == "text":
                            assistant_blocks.append(
                                {"type": "text", "text": b.text})
                        elif btype == "tool_use":
                            tool_uses.append(b)
                            assistant_blocks.append({
                                "type": "tool_use",
                                "id": b.id,
                                "name": b.name,
                                "input": b.input,
                            })
                        elif btype == "thinking":
                            # Required by the API to be echoed back in subsequent
                            # turns when interleaved thinking is in use.
                            assistant_blocks.append({
                                "type": "thinking",
                                "thinking": getattr(b, "thinking", ""),
                                "signature": getattr(b, "signature", ""),
                            })

                    full_text = "".join(text_for_round).strip()
                    if full_text:
                        final_text_parts.append(full_text)

                    if getattr(final_msg, "stop_reason", "") == "max_tokens":
                        root.after(0, lambda: _append_chat(
                            "err", "warning",
                            f"Response hit max_tokens cap ({_CHAT_MAX_TOKENS:,}) — "
                            f"reply may be cut off. Ask Claude to continue, or "
                            f"narrow the question."))

                    if final_msg.stop_reason != "tool_use" or not tool_uses:
                        break

                    # Execute tools and feed results back. Show each call AND
                    # a brief preview of its result so the user can see progress.
                    current.append(
                        {"role": "assistant", "content": assistant_blocks})
                    tool_results = []
                    for tu in tool_uses:
                        tu_input = getattr(tu, "input", {}) or {}
                        preview_args = ", ".join(
                            f"{k}={str(v)[:60]!r}" +
                            ("…" if len(str(v)) > 60 else "")
                            for k, v in tu_input.items()
                        )
                        root.after(0, lambda n=tu.name, p=preview_args:
                                   _append_chat("tool", "→ tool", f"{n}({p})"))
                        try:
                            result = _dispatch_tool(tu.name, tu_input)
                        except Exception as te:
                            result = f"error in tool {tu.name}: {type(te).__name__}: {te}"
                        # First-line preview for the chat; full result still goes to Claude.
                        first_line = result.splitlines(
                        )[0] if result else "(empty)"
                        preview = first_line[:160] + \
                            ("…" if len(first_line) > 160 else "")
                        if "\n" in result:
                            preview += f"  (+{result.count(chr(10))} more lines)"
                        root.after(0, lambda r=preview:
                                   _append_chat("tool_result", "← result", r))
                        # Cap tool output so we don't blow context.
                        if len(result) > _CHAT_TOOL_RESULT_CAP:
                            dropped = len(result) - _CHAT_TOOL_RESULT_CAP
                            result = result[:_CHAT_TOOL_RESULT_CAP] + \
                                f"\n… (+{dropped:,} chars dropped — tool output capped)"
                            root.after(0, lambda d=dropped, n=tu.name:
                                       _append_chat("sys", "warning",
                                                    f"Tool {n} output truncated by {d:,} chars."))
                        tool_results.append({
                            "type": "tool_result",
                            "tool_use_id": tu.id,
                            "content": result,
                        })
                    current.append({"role": "user", "content": tool_results})
                else:
                    root.after(0, _end_think)
                    root.after(0, lambda: _append_chat(
                        "sys", "system",
                        f"(stopped after {_CHAT_TOOL_ROUNDS} tool rounds)"))

                final_reply = "\n\n".join(final_text_parts)
                _reply_preview = final_reply[:80].replace(
                    "\n", " ") + ("…" if len(final_reply) > 80 else "")
                root.after(0, lambda _r=_reply_preview: _log_activity(
                    f"Chat reply: {_r}"))

                # Update session token totals and show a per-turn summary.
                _sess = _chat_session_usage
                for _k in ("input", "output", "cache_read", "cache_create"):
                    _sess[_k] += turn_usage[_k]
                _sess["turns"] += 1
                root.after(0, _show_chat_usage,
                           dict(turn_usage), dict(_sess))

                def _commit() -> None:
                    # type: ignore[arg-type]
                    msgs = list(chat_state["messages"])
                    msgs.append({"role": "user", "content": msg})
                    msgs.append(
                        {"role": "assistant", "content": final_reply or "(no text reply)"})
                    chat_state["messages"] = msgs

                root.after(0, _commit)
            except Exception as exc:
                err_text = str(exc)
                root.after(0, lambda e=err_text: _append_chat("err", "error", e))
            finally:
                root.after(0, _update_chat_state)

        threading.Thread(target=_worker, daemon=True).start()

    def _chat_history_up(_event: object = None) -> str:
        # Only intercept when the cursor is on the FIRST visual line; otherwise
        # let the default Text behavior move the cursor up within the message.
        cur_line = int(str(chat_entry.index("insert")).split('.', 1)[0])
        if cur_line > 1:
            return ""
        if not _chat_input_history:
            return "break"
        idx = int(_chat_history_state["idx"])  # type: ignore[arg-type]
        if idx == -1:
            _chat_history_state["draft"] = chat_entry.get("1.0", "end-1c")
            new_idx = 0
        else:
            new_idx = min(idx + 1, len(_chat_input_history) - 1)
        _chat_history_state["idx"] = new_idx
        chat_entry.delete("1.0", "end")
        chat_entry.insert("1.0", _chat_input_history[new_idx])
        chat_entry.mark_set("insert", "end-1c")
        return "break"

    def _chat_history_down(_event: object = None) -> str:
        # Only intercept on the LAST visual line; otherwise let default fire.
        cur_line = int(str(chat_entry.index("insert")).split('.', 1)[0])
        last_line = int(str(chat_entry.index("end-1c")).split('.', 1)[0])
        if cur_line < last_line:
            return ""
        idx = int(_chat_history_state["idx"])  # type: ignore[arg-type]
        if idx < 0:
            return "break"
        if idx == 0:
            _chat_history_state["idx"] = -1
            chat_entry.delete("1.0", "end")
            chat_entry.insert("1.0", str(_chat_history_state["draft"]))
            chat_entry.mark_set("insert", "end-1c")
            _chat_history_state["draft"] = ""
            return "break"
        new_idx = idx - 1
        _chat_history_state["idx"] = new_idx
        chat_entry.delete("1.0", "end")
        chat_entry.insert("1.0", _chat_input_history[new_idx])
        chat_entry.mark_set("insert", "end-1c")
        return "break"

