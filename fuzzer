    root.bind_all("<Command-d>", _kbd_toggle)
    root.bind_all("<Control-d>", _kbd_toggle)

    pattern_entry.focus_set()

    def _on_close() -> None:
        with contextlib.suppress(Exception):
            _gui_state["window_geometry"] = root.geometry()
            _gui_state["window_state"] = root.state()
            _save_state(_gui_state)
        # PyMuPDF's C++ global destructor segfaults under Python 3.14 + Tcl/Tk 9
        # at process exit (fz_flush_warnings → unicode_decode_utf8 on a freed
        # context). Skip Python's atexit chain by hard-exiting after state is
        # flushed to disk.
        os._exit(0)

    root.protocol("WM_DELETE_WINDOW", _on_close)
    # macOS Cmd+Q routes through tk::mac::Quit, NOT WM_DELETE_WINDOW. Hook it
    # so the os._exit short-circuit also runs there (otherwise Python proceeds
    # to atexit and triggers the PyMuPDF destructor crash).
    if _platform.system() == "Darwin":
        with contextlib.suppress(Exception):
            root.createcommand("tk::mac::Quit", _on_close)

    # Restore window state (maximized / normal). Apply after geometry so the
    # restore size is set before zooming — deiconify then zoom on Windows.
    # When NOT maximizing, also auto-fit (so the chat panel isn't clipped) and
    # center on screen.
    def _open_layout() -> None:
        with contextlib.suppress(Exception):
            if _saved_geom:
                # User has a saved size — honor it exactly. No auto-fit
                # (would override the user's chosen size).
                pass
            elif _saved_state == "zoomed":
                # Legacy-saved zoomed state without geometry: unzoom and use default.
                root.state("normal")
                root.geometry(_default_geometry())
            # else: _default_geometry() already applied above.

    root.after(10, _open_layout)

    # Apply initial theme. ttk styles above were configured with light-mode
    # constants — reapply with the active palette so a saved dark theme takes
    # effect on startup, not just after toggling.
    _configure_ttk_styles(_T)
    _apply_raw_colors(_T)

    root.after(100, poll_queue)
    root.mainloop()
    return 0

# ── CLI ────────────────────────────────────────────────────────────────────────


def main(argv: Optional[List[str]] = None) -> int:
    global _color_on

    raw_argv = sys.argv[1:] if argv is None else argv
    if not raw_argv or "--gui" in raw_argv:
        return run_gui()

    print(
        "warning: the CLI is no longer maintained — "
        "development is focused on the GUI.\n"
        "         Run `fuzzer` with no arguments to launch the GUI instead.",
        file=sys.stderr,
    )

    ap = argparse.ArgumentParser(
        prog="fuzzer",
        description=(
            "Search file contents for a word or phrase.\n"
            "Case-insensitive and fuzzy matching are ON by default.\n"
            "Supported: .txt .md .pdf .docx .doc .csv .log .json .xml .html .rst"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  fuzzer "climate change" report.pdf
  fuzzer -v "global warming" thesis.pdf          full sentence around match
  fuzzer -k "CaseSensitive" notes.txt            case-sensitive mode
  fuzzer -e "exact phrase" notes.txt             exact match (no fuzzy)
  fuzzer -t 70 "aproximate" *.txt                lower fuzzy threshold
  fuzzer -C 2 "keyword" chapter.txt              2 lines of context
  fuzzer -r "topic" ./docs/                      recursive search
  fuzzer -a "renewable energy trends" paper.pdf  AI semantic search
  fuzzer -o hits.csv  "topic" *.pdf              export to CSV
  fuzzer -o hits.xlsx "topic" *.pdf              export to Excel
  fuzzer -o hits.json "topic" *.pdf              export to JSON
  fuzzer --gui                                   launch graphical interface
  fuzzer --test                                  GUI + live native-call inspector
  fuzzer                                         (no args also launches the GUI)
""",
    )
    ap.add_argument("pattern", help="word or phrase to search for")
    ap.add_argument("files", nargs="+", metavar="FILE",
                    help="files or directories to search")

    grp = ap.add_argument_group("matching options")
    grp.add_argument("-k", "--case-sensitive", action="store_true",
                     help="case-sensitive search (default: ignore case)")
    grp.add_argument("-e", "--exact", action="store_true",
                     help="strict whole-word match, no fuzzy fallback "
                          "('asic' will NOT match 'basic'); implies --whole-word")
    grp.add_argument("-w", "--whole-word", action="store_true",
                     help="whole-word match for score-100 hits (regex \\b "
                          "boundaries); fuzzy fallback still applies")
    grp.add_argument("-t", "--threshold", type=int, default=80, metavar="N",
                     help="fuzzy similarity threshold 0-100 (default: 80)")
    grp.add_argument("-a", "--ai", action="store_true",
                     help="AI semantic search via Claude (needs ANTHROPIC_API_KEY)")
    grp.add_argument("--rga", action="store_true",
                     help="use ripgrep-all (rga) backend: extends file coverage "
                          "to docx/epub/xlsx/sqlite/etc. (substring-only)")

    grp2 = ap.add_argument_group("output options")
    grp2.add_argument("-v", "--verbose", action="store_true",
                      help="show full sentence containing each match")
    grp2.add_argument("-C", "--context", type=int, default=0, metavar="N",
                      help="lines of context around each match (default: 0)")
    grp2.add_argument("-l", "--files-only", action="store_true",
                      help="print only filenames with matches")
    grp2.add_argument("-n", "--no-line-numbers", action="store_true",
                      help="suppress line numbers")
    grp2.add_argument("-r", "--recursive", action="store_true",
                      help="recurse into directories")
    grp2.add_argument("--no-color", action="store_true",
                      help="disable coloured output")
    grp2.add_argument("-o", "--output", metavar="FILE",
                      help="export results to FILE "
                           "(format auto-detected: .csv .tsv .json .txt .xlsx)")

    args = ap.parse_args(argv)

    if not 0 <= args.threshold <= 100:
        ap.error("--threshold must be 0-100")

    _color_on = not args.no_color and sys.stdout.isatty()

    files = collect_files(args.files, args.recursive)
    if not files:
        print("error: no files to search", file=sys.stderr)
        return 2

    results: Dict[str, Tuple[List[str], List[Match]]] = {}

    if args.rga and not _RGA_PATH:
        print("warning: --rga requested but `rga` is not on PATH; "
              "falling back to fuzzer's native engine.\n"
              "         install: brew install ripgrep-all",
              file=sys.stderr)

    for fp in files:
        if args.ai:
            lines, matches = ai_search_file(fp, args.pattern)
        elif args.rga and _RGA_PATH:
            lines, matches = rga_search_file(
                fp, args.pattern,
                case_sensitive=args.case_sensitive,
                exact_only=args.exact,
                threshold=args.threshold,
                whole_word=args.whole_word,
            )
        else:
            lines, matches = search_file(
                fp, args.pattern,
                case_sensitive=args.case_sensitive,
                exact_only=args.exact,
                threshold=args.threshold,
                whole_word=args.whole_word,
            )
        if matches:
            results[fp] = (lines, matches)

    if not results:
        print(f"{_c(_YEL)}no matches found{_r()}", file=sys.stderr)
        return 1

    total = print_results(
        results,
        pattern=args.pattern,
        case_sensitive=args.case_sensitive,
        files_only=args.files_only,
        show_nums=not args.no_line_numbers,
        context_lines=args.context,
        verbose=args.verbose,
        ai_mode=args.ai,
    )

    if args.output:
        export_results(results, args.output, verbose=args.verbose)

    n_files = len(results)
    summary = (
        f"\n{total} match{'es' if total != 1 else ''} "
        f"in {n_files} file{'s' if n_files != 1 else ''}"
    )
    print(_c(_CYN) + summary + _r(), file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())


