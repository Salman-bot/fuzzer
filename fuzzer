    def _open_chat_path(path: str) -> None:
        """Open a path from a chat link with the OS default handler."""
        import subprocess
        try:
            if not os.path.exists(path):
                _append_chat("err", "error", f"Path no longer exists: {path}")
                return
            subprocess.Popen(["open", path])
            _log_activity(f"Opened from chat: {os.path.basename(path)}")
        except Exception as exc:
            _append_chat("err", "error", f"Open failed: {exc}")

    def _scan_chat_paths(start_idx: str) -> None:
        """Find absolute file paths after start_idx in chat_log and tag them
        as clickable. Each match gets a fresh per-instance tag bound to its
        own path so duplicates don't collide."""
        try:
            text = chat_log.get(start_idx, "end-1c")
        except Exception:
            return
        for m in _PATH_RE.finditer(text):
            path = m.group(1) or m.group(2)
            if not path or not os.path.isabs(path):
                continue
            grp = 1 if m.group(1) else 2
            char_start, char_end = m.start(grp), m.end(grp)
            try:
                idx_a = chat_log.index(f"{start_idx}+{char_start}c")
                idx_b = chat_log.index(f"{start_idx}+{char_end}c")
            except Exception:
                continue
            _chat_path_counter[0] += 1
            tag_name = f"path_{_chat_path_counter[0]}"
            chat_log.tag_add("path", idx_a, idx_b)
            chat_log.tag_add(tag_name, idx_a, idx_b)
            _chat_path_links[tag_name] = path
            chat_log.tag_bind(
                tag_name, "<Button-1>",
                lambda _e, p=path: _open_chat_path(p))
            chat_log.tag_bind(
                tag_name, "<Enter>",
                lambda _e: chat_log.config(cursor="hand2"))
            chat_log.tag_bind(
                tag_name, "<Leave>",
                lambda _e: chat_log.config(cursor=""))

    # Light markdown rendering applied after each turn ends. Tags `md_*` are
    # configured in _apply_chat_log_tags; we just stamp them over the right
    # text ranges so the styling tracks the theme.
    _MD_CODE_BLOCK = re.compile(r"```[A-Za-z0-9_+-]*\n?(.*?)```", re.DOTALL)
    _MD_INLINE_CODE = re.compile(r"`([^`\n]+)`")
    _MD_BOLD = re.compile(r"\*\*([^*\n]+?)\*\*")
    _MD_ITALIC = re.compile(r"(?<![\*_\w])\*([^*\n]+?)\*(?!\*)")
    _MD_HEADER = re.compile(r"^(#{1,3})[ \t]+(.+?)[ \t]*$", re.MULTILINE)

    def _tag_range(start_idx: str, char_a: int, char_b: int, tag: str) -> None:
        try:
            ia = chat_log.index(f"{start_idx}+{char_a}c")
            ib = chat_log.index(f"{start_idx}+{char_b}c")
            chat_log.tag_add(tag, ia, ib)
        except Exception:
            pass

    def _scan_chat_markdown(start_idx: str) -> None:
        """Stamp markdown tags onto chat_log content from start_idx to end."""
        try:
            text = chat_log.get(start_idx, "end-1c")
        except Exception:
            return
        chat_log.config(state="normal")
        try:
            # Code blocks first — strip later patterns from matching inside.
            code_block_spans: List[Tuple[int, int]] = []
            for m in _MD_CODE_BLOCK.finditer(text):
                _tag_range(start_idx, m.start(1), m.end(1), "md_code_block")
                code_block_spans.append((m.start(), m.end()))

            def _outside_code(i: int) -> bool:
                return all(not (a <= i < b) for a, b in code_block_spans)

            for m in _MD_INLINE_CODE.finditer(text):
                if _outside_code(m.start()):
                    _tag_range(start_idx, m.start(1), m.end(1), "md_code_inline")
            for m in _MD_BOLD.finditer(text):
                if _outside_code(m.start()):
                    _tag_range(start_idx, m.start(1), m.end(1), "md_bold")
            for m in _MD_ITALIC.finditer(text):
                if _outside_code(m.start()):
                    _tag_range(start_idx, m.start(1), m.end(1), "md_italic")
            for m in _MD_HEADER.finditer(text):
                if _outside_code(m.start()):
                    level = len(m.group(1))
                    _tag_range(start_idx, m.start(2), m.end(2), f"md_h{level}")
        finally:
            chat_log.config(state="disabled")

