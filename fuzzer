    # crowded out by the status/selected strips. Enforced two ways:
    #   • initial sashpos placed so chat starts at ~38 % of window height
    #   • on every <Configure> we clamp the sash so chat ≥ _CHAT_PANE_MIN_PX
    # User drags are honored as long as they leave at least the floor.
    # Min height guarantees the chat input row (~3 lines) + status/selected
    # strip (~2 lines) + a few rows of log are always visible. Initial fraction
    # leans toward chat (44% rather than 38%) since the empty log otherwise
    # reads as wasted real estate.
    _CHAT_PANE_MIN_PX = 260
    _sash_inited = [False]

    def _ensure_chat_pane_visible(_e: object = None) -> None:
        with contextlib.suppress(Exception):
            h = main_paned.winfo_height()
            if h < _CHAT_PANE_MIN_PX + 80:
                return  # Window too tiny — let widgets size themselves.
            if not _sash_inited[0]:
                target_chat = max(_CHAT_PANE_MIN_PX, int(h * 0.44))
                main_paned.sashpos(0, h - target_chat)
                _sash_inited[0] = True
                return
            pos = main_paned.sashpos(0)
            chat_h = h - pos
            if chat_h < _CHAT_PANE_MIN_PX:
                main_paned.sashpos(0, max(80, h - _CHAT_PANE_MIN_PX))

    main_paned.bind("<Configure>", _ensure_chat_pane_visible)

