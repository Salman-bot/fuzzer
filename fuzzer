        def _render() -> None:
            """Repaint hex panes + stats line based on pause/pin state."""
            pin = _dbg_pin[0]
            if pin is not None:
                raw_in, raw_out, label = pin
                dbg_stats_var.set(
                    f"calls={len(_NORM_CALLS)}   "
                    f"PINNED: {label}   "
                    f"in {len(raw_in)}B → out {len(raw_out)}B   "
                    f"Δ={len(raw_out) - len(raw_in):+d}B"
                )
            elif _NORM_CALLS:
                ts, inp, out, dt = _NORM_CALLS[-1]
                raw_in = inp.encode("utf-8")
                raw_out = out.encode("utf-8")
                state = "PAUSED" if _dbg_paused[0] else "live"
                dbg_stats_var.set(
                    f"calls={len(_NORM_CALLS)}   last={dt:.1f}µs   "
                    f"in@0x{id(inp):x} ({len(raw_in)}B) → "
                    f"out@0x{id(out):x} ({len(raw_out)}B)   "
                    f"Δ={len(raw_out) - len(raw_in):+d}B   {state}"
                )
            else:
                dbg_stats_var.set("calls=0   waiting for first call…   live")
                raw_in = raw_out = b""
            _insert_hex(dbg_in_hex, raw_in, _classify(raw_in))
            _insert_hex(dbg_out_hex, raw_out, [""] * len(raw_out))

        def _refill_listbox() -> None:
            """Repopulate the listbox to reflect the latest _NORM_CALLS slice."""
            dbg_list.delete(0, "end")
            recent = _NORM_CALLS[-12:]
