# ── colour ─────────────────────────────────────────────────────────────────────

_BOLD = "\033[1m"
_DIM = "\033[2m"
_RED = "\033[31m"
_GRN = "\033[32m"
_YEL = "\033[33m"
_MAG = "\033[35m"
_CYN = "\033[36m"
_RST = "\033[0m"

_color_on = True


def _c(*codes: str) -> str:
    return "".join(codes) if _color_on else ""


def _r() -> str:
    return _RST if _color_on else ""


def _err(msg: str) -> None:
    print(f"{_c(_YEL)}warning:{_r()} {msg}", file=sys.stderr)

# ── types ──────────────────────────────────────────────────────────────────────


class Match(NamedTuple):
    filepath: str
    line_num: int  # 1-based
    line: str
    score: int  # 100 = exact substring, <100 = fuzzy %
    page_num: int = 0  # PDF page (1-based); 0 = not a PDF / unknown

# ── text extraction ────────────────────────────────────────────────────────────


def _extract_plain(fp: str) -> Optional[List[str]]:
    try:
        return Path(fp).read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError as e:
        _err(f"{fp}: {e}")
        return None


_pdf_page_map: Dict[str, List[int]] = {}  # fp → page_num per line (1-based)


def _extract_pdf_pymupdf(fp: str, lines: List[str], page_nums: List[int]) -> List[str]:
    import fitz  # PyMuPDF
    doc = fitz.open(fp)
    for page_idx in range(1, len(doc) + 1):
        page = doc[page_idx - 1]
        # sort=True re-orders glyphs by position, fixing ligature order in
        # Arabic PDFs that use non-standard glyph sequences.
        # type: ignore[attr-defined]
        text: str = page.get_text("text", sort=True) or ""  # type: ignore
        page_lines = text.splitlines()
        lines.extend(page_lines)
        page_nums.extend([page_idx] * len(page_lines))
    doc.close()
    _pdf_page_map[fp] = page_nums
    return lines


def _extract_pdf(fp: str) -> Optional[List[str]]:
    # PyMuPDF preserves logical Unicode character order for Arabic text;
    # fall back to pdfplumber if fitz is not installed.
    lines: List[str] = []
    page_nums: List[int] = []
    try:
        return _extract_pdf_pymupdf(fp, lines, page_nums)
    except ImportError:
        pass
    except Exception as e:
        _err(f"{fp}: {e}")
        return None
    try:
        import pdfplumber
    except ImportError:
        _err("PDF support requires pdfplumber or pymupdf — pip install pymupdf")
        return None
    try:
        with pdfplumber.open(fp) as pdf:
            for page_idx, page in enumerate(pdf.pages, start=1):
                text = page.extract_text() or ""
                page_lines = text.splitlines()
                lines.extend(page_lines)
                page_nums.extend([page_idx] * len(page_lines))
        _pdf_page_map[fp] = page_nums
        return lines
    except Exception as e:
        _err(f"{fp}: {e}")
        return None


def _extract_docx(fp: str) -> Optional[List[str]]:
    try:
        from docx import Document
    except ImportError:
        _err("DOCX support requires python-docx — pip install python-docx")
        return None
    try:
        doc = Document(fp)
        return [p.text for p in doc.paragraphs if p.text.strip()]
    except Exception as e:
        _err(f"{fp}: {e}")
        return None


_EXT_MAP = {
    ".pdf": _extract_pdf,
    ".docx": _extract_docx,
    ".doc": _extract_docx,
    ".txt": _extract_plain,
    ".md": _extract_plain,
    ".rst": _extract_plain,
    ".csv": _extract_plain,
    ".tsv": _extract_plain,
    ".log": _extract_plain,
    ".json": _extract_plain,
    ".xml": _extract_plain,
    ".html": _extract_plain,
    ".htm": _extract_plain,
}

# ── Extraction cache (SQLite, keyed by path + mtime) ──────────────────────────

_CACHE_DB = Path.home() / ".fuzzer_cache.sqlite"
_cache_conn = None  # type: ignore[var-annotated]


def _get_cache():
    global _cache_conn
    if _cache_conn is None:
        _cache_conn = sqlite3.connect(str(_CACHE_DB), check_same_thread=False)
        _cache_conn.executescript("""
            CREATE TABLE IF NOT EXISTS files (
                path TEXT PRIMARY KEY, mtime REAL, n_lines INT
            );
            CREATE TABLE IF NOT EXISTS lines (
                path TEXT, line_no INT, page_num INT, text TEXT,
                PRIMARY KEY (path, line_no)
            );
            CREATE INDEX IF NOT EXISTS lines_path ON lines(path);
        """)
    return _cache_conn


def _cache_get(fp: str):
    try:
        mtime = os.path.getmtime(fp)
    except OSError:
        return None
    conn = _get_cache()
    row = conn.execute(
        "SELECT mtime FROM files WHERE path = ?", (fp,)).fetchone()
    if not row or row[0] != mtime:
        return None
    rows = conn.execute(
        "SELECT page_num, text FROM lines WHERE path = ? ORDER BY line_no",
        (fp,),
    ).fetchall()
    return [r[1] for r in rows], [r[0] for r in rows]


def _cache_put(fp: str, lines: List[str], page_nums: List[int]) -> None:
    try:
        mtime = os.path.getmtime(fp)
    except OSError:
        return
    conn = _get_cache()
    with contextlib.suppress(Exception):
        with conn:
            conn.execute("DELETE FROM files WHERE path = ?", (fp,))
            conn.execute("DELETE FROM lines WHERE path = ?", (fp,))
            conn.execute("INSERT INTO files VALUES (?, ?, ?)",
                         (fp, mtime, len(lines)))
            conn.executemany(
                "INSERT INTO lines VALUES (?, ?, ?, ?)",
                [(fp, i + 1,
                  page_nums[i] if i < len(page_nums) else 0,
                  lines[i]) for i in range(len(lines))],
            )


def read_lines(fp: str) -> Optional[List[str]]:
    # Try cache first. For PDFs we also require real page numbers — old cache
    # entries from before page-tracking landed have page_nums = [0, 0, ...],
    # which silently breaks "open at matched page" until the user clears the
    # cache. Treat such entries as a miss and re-extract.
    is_pdf = Path(fp).suffix.lower() == ".pdf"
    _cached = _cache_get(fp)
    if _cached is not None:
        _lines, _page_nums = _cached
        has_pages = bool(_page_nums) and any(p > 0 for p in _page_nums)
        if has_pages:
            _pdf_page_map[fp] = _page_nums
        if has_pages or not is_pdf:
            return _lines
        # PDF cached without page info — fall through to re-extract.

    ext = Path(fp).suffix.lower()
    fn = _EXT_MAP.get(ext, _extract_plain)
    lines = fn(fp)
    if lines is not None:
        page_nums = _pdf_page_map.get(fp, [0] * len(lines))
        _cache_put(fp, lines, page_nums)
    return lines

# ── Arabic text normalization ──────────────────────────────────────────────────
# Preference order: native C extension (_ar_norm) > pyarabic > pure-Python regex.
# The C extension is ~10x faster and is loaded from the directory containing
# this script (see native/ar_normalize.c, build with `make build-native`).


# Make the script's directory importable so the .so can be found regardless of cwd.
_script_dir = str(Path(__file__).resolve().parent)
if _script_dir not in sys.path:
    sys.path.insert(0, _script_dir)

# Default landing zone for everything fuzzer (or Claude via chat tools) writes:
# exports, chat-generated files, PDF highlight copies. Relative paths handed to
# the chat tools are resolved against this directory. Set per user preference.
_PROJECT_DIR = Path(_script_dir).resolve()

try:
    import _ar_norm  # type: ignore[import-not-found]

    def _normalize_arabic(s: str) -> str:
        """C-accelerated: strip diacritics + tatweel, normalize alef/yeh."""
        return _ar_norm.normalize(s)

except ImportError:
    _AR_DIACRITICS = re.compile(r"[ً-ْٰـ]")
    _ALEF_VARIANTS = str.maketrans(
        {"أ": "ا", "إ": "ا", "آ": "ا", "ٱ": "ا"})
    _YEH_VARIANTS = str.maketrans({"ى": "ي", "ئ": "ي"})

    def _normalize_arabic(s: str) -> str:
        s = _AR_DIACRITICS.sub("", s)
        return s.translate(_ALEF_VARIANTS).translate(_YEH_VARIANTS)

# ── native-call instrumentation (toggleable at runtime via the GUI) ──────────
# When debug mode is ON, every call to _normalize_arabic is recorded into
# _NORM_CALLS so the GUI's "Native debug" panel can show it.
# --test on the command line just starts the GUI with debug mode ON.
_DEBUG_NATIVE = "--test" in sys.argv
if _DEBUG_NATIVE:
    sys.argv = [a for a in sys.argv if a != "--test"]

# (ts, input, output, µs)
_NORM_CALLS: List[Tuple[float, str, str, float]] = []
_NORM_CALLS_MAX = 500
_orig_normalize_arabic = _normalize_arabic


def _dbg_wrapped_normalize(s: str) -> str:
    import time as _t
    t0 = _t.perf_counter()
    out = _orig_normalize_arabic(s)
    _NORM_CALLS.append((_t.time(), s, out, (_t.perf_counter() - t0) * 1e6))
    if len(_NORM_CALLS) > _NORM_CALLS_MAX:
        del _NORM_CALLS[: len(_NORM_CALLS) - _NORM_CALLS_MAX]
    return out


def _set_debug_native(enable: bool) -> None:
    """Install or uninstall the recording wrapper. Toggleable from the GUI."""
    global _normalize_arabic, _DEBUG_NATIVE
    _normalize_arabic = _dbg_wrapped_normalize if enable else _orig_normalize_arabic
    _DEBUG_NATIVE = enable


if _DEBUG_NATIVE:
    _set_debug_native(True)

_TOKEN_RE = re.compile(r"[؀-ۿa-zA-Z0-9]+")


def _tokenize(s: str, min_len: int = 2) -> set:
    """Tokenize a string into normalized words ≥ min_len chars."""
    return {t for t in _TOKEN_RE.findall(_normalize_arabic(s)) if len(t) >= min_len}

# ── sentence extraction ────────────────────────────────────────────────────────


_SENTENCE_END = re.compile(r"(?<=[.!?])\s+")


def extract_sentence(full_text: str, char_offset: int) -> str:
    """Return the sentence that contains char_offset in full_text."""
    # find start: last sentence-end before offset
    start = 0
    for m in _SENTENCE_END.finditer(full_text):
        if m.start() < char_offset:
            start = m.end()
        else:
            break
    # find end: next sentence-end after offset
    end_match = _SENTENCE_END.search(full_text, char_offset)
    end = end_match.start() + 1 if end_match else len(full_text)
    sentence = full_text[start:end].strip()
    return sentence or full_text[max(0, char_offset - 120): char_offset + 120].strip()

# ── fuzzy matching ─────────────────────────────────────────────────────────────


def _levenshtein(a: str, b: str) -> int:
    if len(a) > len(b):
        a, b = b, a
    row = list(range(len(a) + 1))
    for c2 in b:
        prev, row[0] = row[0], row[0] + 1
        for j, c1 in enumerate(a):
            prev, row[j + 1] = row[j + 1], min(
                row[j + 1] + 1, row[j] + 1, prev + (c1 != c2)
            )
    return row[-1]


def _builtin_ratio(a: str, b: str) -> int:
    dist = _levenshtein(a, b)
    total = len(a) + len(b)
    return int((1 - dist / total) * 100) if total else 100


try:
    from rapidfuzz import fuzz as _rf_fuzz
    def _RATIO_FN(a, b): return int(_rf_fuzz.ratio(a, b))
    def _PARTIAL_FN(a, b): return int(_rf_fuzz.partial_ratio(a, b))
    def _TOKEN_FN(a, b): return int(_rf_fuzz.token_set_ratio(a, b))
except ImportError:
    try:
        from thefuzz import fuzz as _tf_fuzz
        _PARTIAL_FN = _tf_fuzz.partial_ratio
        _TOKEN_FN = _tf_fuzz.token_set_ratio
    except ImportError:
        _RATIO_FN = _builtin_ratio
        _PARTIAL_FN = None  # type: ignore[assignment]
        _TOKEN_FN = None  # type: ignore[assignment]


def fuzzy_score(pattern: str, line: str) -> int:
    """Best similarity score (0-100) of pattern against tokens in line."""
    words = line.split()
    pw = pattern.split()
    n = len(pw)
    best = 0

    if n == 1:
        for w in words:
            best = max(best, _RATIO_FN(pattern, w))
    else:
        for i in range(max(1, len(words) - n + 1)):
            window = " ".join(words[i: i + n])
            best = max(best, _RATIO_FN(pattern, window))
        if _PARTIAL_FN:
            best = max(best, _PARTIAL_FN(pattern, line))
        if _TOKEN_FN:
            best = max(best, _TOKEN_FN(pattern, line))

    return best

# ── core search ────────────────────────────────────────────────────────────────


def search_file(
    fp: str,
    pattern: str,
    *,
    case_sensitive: bool,
    threshold: int,
) -> Tuple[List[str], List[Match]]:
    """Search ``fp`` for ``pattern`` (substring + fuzzy fallback)."""
    lines = read_lines(fp)
    if lines is None:
        return [], []

    matches: List[Match] = []
    _pages = _pdf_page_map.get(fp, [])

    pat = pattern if case_sensitive else pattern.lower()

    def _is_hit(line: str) -> bool:
        cmp = line if case_sensitive else line.lower()
        return pat in cmp

    pat_lower = pattern if case_sensitive else pattern.lower()
    for i, line in enumerate(lines, start=1):
        pg = _pages[i - 1] if i - 1 < len(_pages) else 0
        if _is_hit(line):
            matches.append(Match(fp, i, line, 100, pg))
            continue
        cmp = line if case_sensitive else line.lower()
        sc = fuzzy_score(pat_lower, cmp)
        if sc >= threshold:
            matches.append(Match(fp, i, line, sc, pg))

    return lines, matches

# ── rga (ripgrep-all) backend ────────────────────────────────────────────────
# Optional external engine. When `rga` is on PATH and the user opts in via the
# GUI checkbox, search is delegated to rga so we get text extraction for docx,
# epub, xlsx, sqlite, mkv subtitles, etc. for free. Trade-off: substring-only,
# no fuzzy fallback.
import shutil as _shutil
_RGA_PATH = _shutil.which("rga")


def rga_search_file(
    fp: str,
    pattern: str,
    *,
    case_sensitive: bool,
    threshold: int,  # unused — rga is substring-only
) -> Tuple[List[str], List[Match]]:
    """Search a single file via rga --json. On any failure (rga missing,
    spawn error, parse error) falls back to the in-process search_file().
    Returns (lines, matches); lines is empty for formats fuzzer can't read
    natively (docx/epub/sqlite) — the GUI only relies on Match.line for those.
    """
    if not _RGA_PATH or not pattern:
        return search_file(fp, pattern,
                           case_sensitive=case_sensitive,
                           threshold=threshold)
    import subprocess as _sub
    import json as _json
    args = [_RGA_PATH, "--json", "--no-config",
            "--fixed-strings", "--no-messages"]
    if not case_sensitive:
        args.append("--ignore-case")
    args.extend(["--", pattern, fp])
    try:
        proc = _sub.run(args, capture_output=True, text=True, timeout=60,
                        encoding="utf-8", errors="replace")
    except (_sub.TimeoutExpired, OSError):
        return search_file(fp, pattern,
                           case_sensitive=case_sensitive,
                           threshold=threshold)

    matches: List[Match] = []
    # rga's PDF adapter prefixes each emitted line with "Page N:" (e.g.
    # "Page 7: matched content..."). Parse the prefix into Match.page_num
    # and strip it off the displayed text so snippets show the actual content
    # rather than the page marker.
    _page_prefix_re = re.compile(r"^Page\s+(\d+):\s*(.*)$")
    for ln in proc.stdout.splitlines():
        if not ln:
            continue
        try:
            obj = _json.loads(ln)
        except (_json.JSONDecodeError, ValueError):
            continue
        if obj.get("type") != "match":
            continue
        data = obj.get("data") or {}
        line_text = (data.get("lines") or {}).get("text") or ""
        line_text = line_text.rstrip("\r\n")
        line_num = int(data.get("line_number") or 0) or 1
        page = 0
        m_page = _page_prefix_re.match(line_text)
        if m_page:
            page = int(m_page.group(1))
            line_text = m_page.group(2)
        matches.append(Match(fp, line_num, line_text, 100, page))
    # Try to also collect plain-text lines so the snippet builder works the
    # same as the native path. For formats fuzzer can't read directly we
    # return an empty list — _append_file_results only uses Match.line.
    lines = read_lines(fp) or []
    return lines, matches

# ── export ─────────────────────────────────────────────────────────────────────


def _build_rows(
    results: Dict[str, Tuple[List[str], List[Match]]],
) -> List[Dict[str, object]]:
    rows: List[Dict[str, object]] = []
    for fp, (lines, matches) in results.items():
        full_text = "\n".join(lines)
        for m in matches:
            if m.score == 100:
                match_type = "exact"
                score_val: object = 100
            else:
                match_type = "fuzzy"
                score_val = m.score

            row: Dict[str, object] = {
                "file": fp,
                "line": m.line_num,
                "page": m.page_num if m.page_num else "",
                "match_type": match_type,
                "score": score_val,
                "content": m.line,
            }
            offset = sum(len(l) + 1 for l in lines[:m.line_num - 1])
            row["sentence"] = extract_sentence(
                full_text, offset + max(0, len(m.line) // 2)
            )
            rows.append(row)
    return rows


_DEFAULT_EXPORT_FIELDS = ["file", "line", "match_type", "score", "content"]


def _fields_for(rows: List[Dict[str, object]]) -> List[str]:
    return list(rows[0].keys()) if rows else list(_DEFAULT_EXPORT_FIELDS)


def _export_csv(rows: List[Dict[str, object]], out_path: str, delim: str) -> None:
    import csv
    fields = _fields_for(rows)
    with open(out_path, "w", encoding="utf-8", newline="") as f:
        w = csv.DictWriter(f, fieldnames=fields, delimiter=delim)
        w.writeheader()
        w.writerows(rows)


def _export_json(rows: List[Dict[str, object]], out_path: str) -> None:
    import json
    with open(out_path, "w", encoding="utf-8") as f:
        json.dump(rows, f, ensure_ascii=False, indent=2)


def _export_xlsx(rows: List[Dict[str, object]], out_path: str) -> bool:
    try:
        from openpyxl import Workbook
        from openpyxl.styles import Font
        from openpyxl.utils import get_column_letter
    except ImportError:
        _err("Excel export requires openpyxl — pip install openpyxl")
        return False
    wb = Workbook()
    ws = wb.active
    assert ws is not None
    ws.title = "fuzzer results"
    fields = _fields_for(rows)
    ws.append(fields)
    for cell in ws[1]:
        cell.font = Font(bold=True)
    for row in rows:
        ws.append([row.get(k, "") for k in fields])
    for col_idx, name in enumerate(fields, start=1):
        max_len = max([len(str(name))] + [len(str(r.get(name, "")))
                      for r in rows])
        ws.column_dimensions[get_column_letter(
            col_idx)].width = min(max_len + 2, 80)
    wb.save(out_path)
    return True


def _txt_tag(row: Dict[str, object]) -> str:
    if row["match_type"] == "fuzzy":
        return f" [~{row['score']}%]"
    return ""


def _export_txt(rows: List[Dict[str, object]], out_path: str) -> None:
    with open(out_path, "w", encoding="utf-8") as f:
        current_file: Optional[str] = None
        for r in rows:
            if r["file"] != current_file:
                current_file = str(r["file"])
                f.write(f"\n{current_file}\n")
            f.write(f"  {r['line']}: {r['content']}{_txt_tag(r)}\n")
            if "sentence" in r:
                f.write(f"     {r['sentence']}\n")


def export_results(
    results: Dict[str, Tuple[List[str], List[Match]]],
    out_path: str,
) -> None:
    rows = _build_rows(results)
    ext = Path(out_path).suffix.lower()

    if ext in (".csv", ".tsv"):
        _export_csv(rows, out_path, "\t" if ext == ".tsv" else ",")
    elif ext == ".json":
        _export_json(rows, out_path)
    elif ext in (".xlsx", ".xls"):
        if not _export_xlsx(rows, out_path):
            return
    else:
        _export_txt(rows, out_path)

    print(
        f"{_c(_CYN)}exported {len(rows)} rows to {out_path}{_r()}",
        file=sys.stderr,
    )

# ── file collection ────────────────────────────────────────────────────────────


def collect_files(paths: List[str], recursive: bool) -> List[str]:
    out: List[str] = []
    for p in paths:
        path = Path(p)
        if path.is_dir():
            if recursive:
                out.extend(
                    str(f)
                    for f in sorted(path.rglob("*"))
                    if f.is_file() and f.suffix.lower() in _EXT_MAP
                )
            else:
                _err(f"{p} is a directory — use -r to search recursively")
        elif path.is_file():
            out.append(str(path))
        else:
            _err(f"{p}: not found")
    return out

