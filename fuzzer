    def _run_elevated(command: str, working_dir: str) -> Tuple[int, str]:
        """Run a command elevated via UAC (Windows) / sudo prompt (Unix).
        Returns (exit_code, combined_output). Output capture from the elevated
        process is done via a temp file."""
        import subprocess
        import tempfile
        out_tmp = tempfile.mktemp(suffix=".txt")
        try:
            if sys.platform == "win32":
                # Wrap command so its output lands in out_tmp, then UAC-elevate
                ps_inner = command.replace("'", "''")
                ps_script = (
                    f"Set-Location '{working_dir.replace(chr(39), chr(39)*2)}'; "
                    f"& cmd /c '{ps_inner}' 2>&1 | Out-File -FilePath '{out_tmp}' -Encoding UTF8"
                )
                ps_script_escaped = ps_script.replace('"', '\\"')
                outer = (
                    f'Start-Process powershell -ArgumentList '
                    f'"-NoProfile -Command \\"{ps_script_escaped}\\"" '
                    f'-Verb RunAs -Wait'
                )
                r = subprocess.run(
                    ["powershell", "-Command", outer],
                    capture_output=True, text=True, timeout=120,
                )
                try:
                    output = Path(out_tmp).read_text(
                        encoding="utf-8", errors="replace")
                except OSError:
                    output = r.stderr or "(no output captured)"
                return r.returncode, output
            else:
                parts = ["sudo", "--", "sh", "-c", command]
                r = subprocess.run(
                    parts, capture_output=True, text=True,
                    timeout=120, cwd=working_dir,
                )
                return r.returncode, (r.stdout + r.stderr).strip()
        except Exception as e:
            return 1, str(e)
        finally:
            with contextlib.suppress(OSError):
                Path(out_tmp).unlink()

