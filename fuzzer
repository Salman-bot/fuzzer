        dbg_list.bind("<<ListboxSelect>>", _on_list_click)

        # Click-to-inspect: selecting a row in the main results tree runs the
        # text through _normalize_arabic (recording a call) and pins the result
        # so you can examine what was processed.
        def _on_tree_select(_event: object) -> None:
            sel = tree.selection()
            if not sel:
