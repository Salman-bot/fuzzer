        "\n"
        "From the terminal:  transcribe … --model <name>")

    def _set_selected_preview_from_iid(iid: str) -> None:
        vals = tree.item(iid, "values")
        if not vals:
            _set_selected_preview("")
            return

        filepath = _row_paths.get(iid, "")
        filename = os.path.basename(filepath) if filepath else str(
            vals[0]) if len(vals) > 0 else ""

        # values order: (file, line, page, match, score, content)
        try:
            line_num = int(vals[1])
        except Exception:
            line_num = 1

        page_text = str(vals[2]) if len(vals) > 2 else ""
        match_type = str(vals[3]) if len(vals) > 3 else ""
        score_text = str(vals[4]) if len(vals) > 4 else ""

        score_suffix = ""
        if match_type == "fuzzy" and score_text:
            score_suffix = f" {score_text}%"

        page_suffix = f" (page {page_text})" if page_text else ""

        # Use the unmarked full line (not the cell's marked snippet) so we
        # can compute clean character ranges for the yellow `match` tag.
        full_line = _row_full_lines.get(iid, "").replace("\n", " ").strip()
        prefix = f"{filename}:{line_num} {match_type}{score_suffix}{page_suffix} — "
        text = prefix + full_line
        ranges = _find_match_ranges(
            full_line, pattern_var.get(),
            use_smart=smart_var.get(),
            case_sensitive=case_var.get(),
            whole_word=whole_word_var.get(),
        )
        # Shift ranges by the prefix length since they were computed against
        # `full_line` but applied against `prefix + full_line`.
        shift = len(prefix)
        shifted = [(s + shift, e + shift) for (s, e) in ranges]
        _set_selected_preview(text, shifted)

    def on_tree_select(_event: object = None) -> None:
        sel = tree.selection()
        if not sel:
            return
        _set_selected_preview_from_iid(str(sel[0]))

    def copy_selected(_event: object = None) -> str:
        sel = tree.selection()
        if not sel:
            return "break"
        iid = str(sel[0])

        filepath = _row_paths.get(iid, "")
        vals = tree.item(iid, "values")
        if not vals:
            return "break"

        try:
            line_num = int(vals[1])
        except Exception:
            line_num = 1

        page_text = str(vals[2]) if len(vals) > 2 else ""
        match_type = str(vals[3]) if len(vals) > 3 else ""
        score_text = str(vals[4]) if len(vals) > 4 else ""
        content = str(vals[5]) if len(vals) > 5 else ""

        score_suffix = ""
        if match_type == "fuzzy" and score_text:
            score_suffix = f" {score_text}%"

        page_suffix = f" (page {page_text})" if page_text else ""
        text = (
            f"{filepath}:{line_num}{page_suffix}\n"
            f"[{match_type}{score_suffix}]\n"
            f"{content}"
        )

        root.clipboard_clear()
        root.clipboard_append(text)
        status_var.set("Copied selected match")
        return "break"

