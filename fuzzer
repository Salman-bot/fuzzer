    def _allowed_paths() -> set:
        """Paths Claude is permitted to read/write: current results + selected
        files/folders. Folders allow any file *within* them."""
        roots = set()
        roots.update(state.get("results", {}).keys())  # type: ignore[union-attr]
        roots.update(parse_files_field(files_var.get()))
        return roots

    def _path_allowed(p: str) -> bool:
        try:
            rp = Path(p).resolve()
        except Exception:
            return False
        for root_p in _allowed_paths():
            try:
                root_resolved = Path(root_p).resolve()
            except Exception:
                continue
            if rp == root_resolved:
                return True
            if root_resolved.is_dir() and root_resolved in rp.parents:
                return True
        return False

    def _tool_list_results() -> str:
        results = state.get("results", {})  # type: ignore[assignment]
        if not results:
            return ("No search results loaded. Run a search first "
                    "(the user can do this; you cannot trigger it).")
        out = []
        for fp, (_lines, matches) in results.items():  # type: ignore[misc]
            sample = []
            for m in matches[:5]:
                pg = f" p.{m.page_num}" if m.page_num else ""
                sample.append(f"L{m.line_num}{pg} (score={m.score}): "
                              f"{m.line.strip()[:120]}")
            out.append({
                "path":        fp,
                "match_count": len(matches),
                "samples":     sample,
            })
        import json as _json
        return _json.dumps(out, ensure_ascii=False, indent=2)

    def _tool_read_chunk(path: str, start_line: int = 1, max_lines: int = 200) -> str:
        if not path:
            return "error: path is required"
        if not _path_allowed(path):
            return (f"error: {path!r} is outside the current search-results / "
                    f"selected-files scope. The user must select it first.")
        max_lines = max(1, min(int(max_lines or 200), 1000))
        start_line = max(1, int(start_line or 1))
        try:
            with open(path, encoding="utf-8", errors="replace") as f:
                all_lines = f.readlines()
        except Exception as e:
            return f"error reading {path}: {type(e).__name__}: {e}"
        chunk = all_lines[start_line - 1 : start_line - 1 + max_lines]
        if not chunk:
            return (f"(empty slice — file has {len(all_lines)} lines, "
                    f"requested start_line={start_line})")
        body = "".join(f"{start_line + i}: {ln}" for i, ln in enumerate(chunk))
        suffix = ""
        if start_line - 1 + max_lines < len(all_lines):
            suffix = f"\n… (file has {len(all_lines)} lines total)"
        return body + suffix

    def _tool_write(path: str, content: str, append: bool = False) -> str:
        if not path:
            return "error: path is required"
        if not _path_allowed(path):
            # Allow writing NEW files inside an allowed directory.
            parent_ok = False
            try:
                parent = Path(path).resolve().parent
                for root_p in _allowed_paths():
                    root_resolved = Path(root_p).resolve()
                    if root_resolved.is_dir() and (root_resolved == parent
                                                   or root_resolved in parent.parents):
                        parent_ok = True; break
            except Exception:
                pass
            if not parent_ok:
                return (f"error: {path!r} is outside the allowed scope. Write "
                        f"under a selected file or folder.")
        try:
            mode = "a" if append else "w"
            with open(path, mode, encoding="utf-8") as f:
                f.write(content)
            return (f"{'appended' if append else 'wrote'} {len(content)} chars "
                    f"to {path}")
        except Exception as e:
            return f"error writing {path}: {type(e).__name__}: {e}"

    def _dispatch_tool(name: str, args: dict) -> str:
        if name == "list_results":
            return _tool_list_results()
        if name == "read_file_chunk":
            return _tool_read_chunk(
                args.get("path", ""),
                args.get("start_line", 1),
                args.get("max_lines", 200),
            )
        if name == "write_file":
            return _tool_write(args.get("path", ""), args.get("content", ""),
                               append=False)
        if name == "append_to_file":
            return _tool_write(args.get("path", ""), args.get("content", ""),
                               append=True)
        return f"unknown tool: {name}"

