    def _wire_text_shortcuts(widget: tk.Widget, *,
                             allow_edit: bool = True) -> None:
        """Add Cmd/Ctrl+A select-all and a right-click context menu so the
        widget feels like a normal OS text box. Works on tk.Text (including
        state="disabled" — temporarily flips state for selection), tk.Entry,
        and ttk.Combobox/Spinbox."""
        is_text = isinstance(widget, tk.Text)

        def _select_all(_e: object = None) -> str:
            with contextlib.suppress(Exception):
                if is_text:
                    was_disabled = str(widget.cget("state")) == "disabled"
                    if was_disabled:
                        widget.configure(state="normal")
                    widget.tag_add("sel", "1.0", "end-1c")
                    widget.mark_set("insert", "end-1c")
                    if was_disabled:
                        widget.configure(state="disabled")
                else:
                    widget.select_range(0, "end")
                    widget.icursor("end")
            return "break"

        widget.bind("<Command-a>", _select_all)
        widget.bind("<Command-A>", _select_all)
        widget.bind("<Control-a>", _select_all)
        widget.bind("<Control-A>", _select_all)

        menu = tk.Menu(widget, tearoff=False)
        menu.add_command(
            label="Copy",
            command=lambda: widget.event_generate("<<Copy>>"))
        if allow_edit:
            menu.add_command(
                label="Cut",
                command=lambda: widget.event_generate("<<Cut>>"))
            menu.add_command(
                label="Paste",
                command=lambda: widget.event_generate("<<Paste>>"))
        menu.add_separator()
        menu.add_command(label="Select All", command=_select_all)

        def _show_menu(e: object) -> str:
            try:
                menu.tk_popup(int(e.x_root), int(e.y_root))  # type: ignore[attr-defined]
            finally:
                menu.grab_release()
            return "break"

        widget.bind("<Button-2>", _show_menu)
        widget.bind("<Button-3>", _show_menu)
        widget.bind("<Control-Button-1>", _show_menu)

