    def _build_highlighted_pdf(fp: str, matches: List[Match]) -> str:
        """Highlight matched lines in a PDF copy. For complex layouts (RTL,
        multi-column), the dict and text outputs from PyMuPDF reorder words
        differently, so we match by normalized token overlap rather than
        positional indexing. Falls back to query-token search when the matched
        line is a long concatenation of many visual lines."""
        try:
            import fitz as _fitz
            from difflib import SequenceMatcher
            _tmp_dir = Path.home() / ".fuzzer_tmp"
            _tmp_dir.mkdir(exist_ok=True)
            _doc = _fitz.open(fp)

            # Group matches by page number (1-based)
            _page_ms: Dict[int, List[Match]] = {}
            for m in matches:
                _page_ms.setdefault(m.page_num or 1, []).append(m)

            for _pn, _ms in _page_ms.items():
                if not (1 <= _pn <= len(_doc)):
                    continue
                _pg = _doc[_pn - 1]

                # Collect all dict lines (text + bbox) in sorted order
                _pg_dict: dict = _pg.get_text("dict", sort=True)  # type: ignore[assignment]
                _dict_lines: List[tuple] = []  # (text, bbox)
                for _blk in _pg_dict.get("blocks", []):
                    if _blk.get("type") != 0:
                        continue
                    for _ln in _blk.get("lines", []):
                        _lt = "".join(s.get("text", "") for s in _ln.get("spans", []))
                        _dict_lines.append((_lt.strip(), _ln.get("bbox")))

                # Pre-tokenize + normalize dict lines once per page
                _dict_lines_aug = [
                    (_t, _b, _tokenize(_t), _normalize_arabic(_t))
                    for (_t, _b) in _dict_lines
                ]
                _q_norm = _normalize_arabic(pattern_var.get().strip())

                for m in _ms:
                    _q_line = m.line.strip()
                    _q_tokens = _tokenize(_q_line)
                    _added = False

                    # Strategy 1: token-overlap match against full matched line.
                    # Order-independent — handles RTL/Arabic where dict and text
                    # outputs reorder words. Picks the dict line(s) covering
                    # ≥60% of the query line's tokens.
                    if _q_tokens:
                        _hits: List = []
                        for _dt, _db, _d_tokens, _d_norm in _dict_lines_aug:
                            if not _d_tokens:
                                continue
                            _coverage = len(_q_tokens & _d_tokens) / len(_q_tokens)
                            if _coverage >= 0.60:
                                _hits.append((_coverage, _db))
                        if _hits:
                            _hits.sort(reverse=True, key=lambda x: x[0])
                            _top = _hits[0][0]
                            for _cov, _bb in _hits:
                                if _cov >= _top - 0.05:
                                    _pg.add_highlight_annot(_fitz.Rect(_bb))
                                    _added = True

                    # Strategy 2: per-token fuzzy match against the query.
                    # For PDFs with broken character encoding (e.g. ا+م+ل swap),
                    # strict substring fails. Use the same per-token fuzzy
                    # comparison the search itself uses — find dict lines with
                    # any token at ≥70% similarity to the normalized query.
                    if not _added and _q_norm:
                        for _dt, _db, _d_tokens, _d_norm in _dict_lines_aug:
                            for _tok in _d_tokens:
                                if SequenceMatcher(None, _q_norm, _tok).ratio() >= 0.70:
                                    _pg.add_highlight_annot(_fitz.Rect(_db))
                                    _added = True
                                    break

                    # Strategy 3: SequenceMatcher fuzzy fallback against the
                    # full query line, normalized
                    if not _added and _q_line:
                        _qs_norm = _normalize_arabic(_q_line)
                        _best, _best_bbox = 0.55, None
                        for _dt, _db, _d_tokens, _d_norm in _dict_lines_aug:
                            if not _d_norm:
                                continue
                            _r = SequenceMatcher(None, _qs_norm, _d_norm).ratio()
                            if _r > _best:
                                _best, _best_bbox = _r, _db
                        if _best_bbox:
                            _pg.add_highlight_annot(_fitz.Rect(_best_bbox))

            _tmp = str(_tmp_dir / f"fuzzer_{os.getpid()}_{id(_doc)}.pdf")
            _doc.save(_tmp)
            _doc.close()
            return _tmp
        except Exception as _e:
            status_var.set(f"Highlight failed: {_e}")
            return fp

    def populate(results: Dict[str, Tuple[List[str], List[Match]]]) -> None:
        _row_paths.clear()
        _highlighted_pdfs.clear()
        total = 0
        for fp, (_, matches) in results.items():
            display_name = _fix_arabic(os.path.basename(fp))
            for m in matches:
                if m.score == 100:
                    match_type, score_text = "exact", "100"
                elif m.score == -1:
                    match_type, score_text = "ai", ""
                else:
                    match_type, score_text = "fuzzy", str(m.score)
                page_text = str(m.page_num) if m.page_num else ""
                _tag = "odd" if total % 2 else "even"
                _snippet = _line_context(m.line, pattern_var.get())
                iid = tree.insert("", "end", values=(
                    display_name, m.line_num, page_text, match_type, score_text,
                    _fix_arabic(_snippet)), tags=(_tag,))
                _row_paths[iid] = fp
                total += 1
            # Pre-build highlighted copy for every PDF in results
            if Path(fp).suffix.lower() == ".pdf":
                _highlighted_pdfs[fp] = _build_highlighted_pdf(fp, matches)

        n_files = len(results)
        status_var.set(
            f"{total} match{'es' if total != 1 else ''} "
            f"in {n_files} file{'s' if n_files != 1 else ''}"
        )

    def poll_queue() -> None:
        try:
            while True:
                kind, payload = msg_q.get_nowait()
                if kind == "status":
                    status_var.set(str(payload))
                elif kind == "done":
                    state["results"] = payload  # type: ignore[assignment]
                    state["searching"] = False
                    search_btn.config(state="normal", text="Search")
                    if payload:
                        populate(payload)  # type: ignore[arg-type]
                        export_btn.config(state="normal")
                    else:
                        status_var.set("No matches found.")
                        export_btn.config(state="disabled")
                elif kind == "error":
                    state["searching"] = False
                    search_btn.config(state="normal", text="Search")
                    status_var.set(f"Error: {payload}")
                    messagebox.showerror("fuzzer", str(payload))
        except queue.Empty:
            pass
        root.after(100, poll_queue)

    def clear_results() -> None:
        tree.delete(*tree.get_children())
        _row_paths.clear()
        state["results"] = {}
        export_btn.config(state="disabled")
        status_var.set("Ready")

    def export_to_file() -> None:
        results = state["results"]
        if not results:
            return
        path = filedialog.asksaveasfilename(
            title="Export results",
            defaultextension=".xlsx",
            filetypes=[
                ("Excel workbook", "*.xlsx"),
                ("CSV", "*.csv"),
                ("TSV", "*.tsv"),
                ("JSON", "*.json"),
                ("Text", "*.txt"),
                ("All files", "*.*"),
            ],
        )
        if not path:
            return
        try:
            export_results(results, path, verbose=verbose_var.get())  # type: ignore[arg-type]
            status_var.set(f"Exported to {path}")
        except Exception as e:
            messagebox.showerror("fuzzer", f"Export failed: {e}")

    _editor_exts = {'.txt', '.md', '.py', '.js', '.ts', '.jsx', '.tsx',
                    '.json', '.xml', '.html', '.htm', '.rst', '.csv',
                    '.log', '.yaml', '.yml', '.toml', '.ini', '.cfg'}

    def open_selected(event: object = None) -> None:
        # Resolve iid: try click position first (reliable on double-click),
        # then fall back to current selection.
        iid = ""
        if event is not None and hasattr(event, "y"):
            iid = tree.identify_row(event.y) or ""  # type: ignore[attr-defined]
        if not iid:
            sel = tree.selection()
            iid = sel[0] if sel else ""
        if not iid:
            return

        filepath = _row_paths.get(iid, "")
        if not filepath:
            return

        vals = tree.item(iid, "values")
        # values order: (file, line, page, match, score, content)
        try:
            line_num = int(vals[1])
        except (ValueError, IndexError):
            line_num = 1
        try:
            page_num = int(vals[2]) if vals[2] else 0
        except (ValueError, IndexError):
            page_num = 0

        import subprocess, shutil
        ext = Path(filepath).suffix.lower()
        try:
            if ext == ".pdf":
                open_page = page_num or 1
                # Use the pre-built highlighted copy from populate(); fall back
                # to original if not available (e.g. fitz not installed).
                _tmp_path = _highlighted_pdfs.get(filepath, filepath)
                _esc = _tmp_path.replace("\\", "\\\\").replace('"', '\\"')

                # Open + resize + navigate via ⌘⌥G keyboard shortcut
                _script = "\n".join([
                    'tell application "Preview"',
                    '  activate',
                    f'  open POSIX file "{_esc}"',
                    'end tell',
                    'delay 0.35',
                    'try',
                    '  tell application "System Events"',
                    '    tell process "Preview"',
                    '      tell front window',
                    '        if value of attribute "AXMinimized" is true then',
                    '          set value of attribute "AXMinimized" to false',
                    '        end if',
                    '        set position to {120, 80}',
                    '        set size to {1000, 720}',
                    '      end tell',
                    '    end tell',
                    '  end tell',
                    'end try',
                    f'if {open_page} > 1 then',
                    '  tell application "System Events"',
                    '    tell process "Preview"',
                    '      keystroke "g" using {command down, option down}',
                    '      set n to 0',
                    '      repeat',
                    '        delay 0.06',
                    '        set n to n + 1',
                    '        if n > 30 then exit repeat',
                    '        try',
                    '          tell sheet 1 of front window',
                    f'            set value of text field 1 to "{open_page}"',
                    '            click button "OK"',
                    '          end tell',
                    '          exit repeat',
                    '        end try',
                    '      end repeat',
                    '    end tell',
                    '  end tell',
                    'end if',
                ])
                _as_proc = subprocess.run(
                    ["osascript", "-e", _script],
                    capture_output=True, text=True
                )
                if _as_proc.returncode != 0:
                    _as_err = (_as_proc.stderr or _as_proc.stdout).strip()
                    status_var.set(f"Open failed — {_as_err[:80]}")
                    messagebox.showerror("fuzzer – open PDF", f"AppleScript error: {_as_err}")
                else:
                    hl_note = "" if _tmp_path != filepath else " (no highlight — fitz missing?)"
                    status_var.set(f"Opened page {open_page} — {os.path.basename(filepath)}{hl_note}")
            elif ext in _editor_exts:
                if shutil.which("code"):
                    subprocess.Popen(["code", "--goto", f"{filepath}:{line_num}"])
                elif shutil.which("cursor"):
                    subprocess.Popen(["cursor", "--goto", f"{filepath}:{line_num}"])
                elif shutil.which("subl"):
                    subprocess.Popen(["subl", f"{filepath}:{line_num}"])
                else:
                    subprocess.Popen(["open", filepath])
                status_var.set(f"Opened line {line_num} — {os.path.basename(filepath)}")
            else:
                subprocess.Popen(["open", filepath])
                status_var.set(f"Opened {os.path.basename(filepath)}")
        except Exception as _ex:
            status_var.set(f"Open failed: {_ex}")
            messagebox.showerror("fuzzer", f"Could not open:\n{_ex}")

    def set_api_key() -> None:
        dlg = tk.Toplevel(root)
        dlg.title("Claude API Key")
        dlg.resizable(False, False)
        dlg.grab_set()
        ttk.Label(dlg, text="Paste your Anthropic API key:").pack(padx=16, pady=(12, 4))
        key_var = tk.StringVar(value=str(_gui_state.get("api_key", "")))
        key_entry = ttk.Entry(dlg, textvariable=key_var, width=52, show="*")
        key_entry.pack(padx=16, pady=4)
        show_var = tk.BooleanVar()
        def _toggle_show() -> None:
            key_entry.config(show="" if show_var.get() else "*")
        ttk.Checkbutton(dlg, text="Show key", variable=show_var,
                        command=_toggle_show).pack(anchor="w", padx=16)
        def _save() -> None:
            k = key_var.get().strip()
            _gui_state["api_key"] = k
            _save_state(_gui_state)
            os.environ["ANTHROPIC_API_KEY"] = k
            dlg.destroy()
            _update_chat_state()
        btn_row = ttk.Frame(dlg)
        btn_row.pack(pady=(8, 12))
        ttk.Button(btn_row, text="Save", command=_save).pack(side="left", padx=4)
        ttk.Button(btn_row, text="Cancel", command=dlg.destroy).pack(side="left", padx=4)
        key_entry.focus_set()
        dlg.bind("<Return>", lambda _e: _save())

    search_btn.config(command=start_search)
    clear_btn.config(command=clear_results)
    export_btn.config(command=export_to_file)
    apikey_btn.config(command=set_api_key)
    tree.bind("<Double-1>", open_selected)
    tree.bind("<Return>", open_selected)
    pattern_entry.bind("<Return>", lambda _e: start_search())
    files_entry.bind("<Return>", lambda _e: start_search())

    pattern_entry.focus_set()
    root.after(100, poll_queue)
    root.mainloop()
    return 0

# ── CLI ────────────────────────────────────────────────────────────────────────

def main(argv: Optional[List[str]] = None) -> int:
    global _color_on

    raw_argv = sys.argv[1:] if argv is None else argv
    if not raw_argv or "--gui" in raw_argv:
        return run_gui()

    ap = argparse.ArgumentParser(
        prog="fuzzer",
        description=(
            "Search file contents for a word or phrase.\n"
            "Case-insensitive and fuzzy matching are ON by default.\n"
            "Supported: .txt .md .pdf .docx .doc .csv .log .json .xml .html .rst"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  fuzzer "climate change" report.pdf
  fuzzer -v "global warming" thesis.pdf          full sentence around match
  fuzzer -k "CaseSensitive" notes.txt            case-sensitive mode
  fuzzer -e "exact phrase" notes.txt             exact match (no fuzzy)
  fuzzer -t 70 "aproximate" *.txt                lower fuzzy threshold
  fuzzer -C 2 "keyword" chapter.txt              2 lines of context
  fuzzer -r "topic" ./docs/                      recursive search
  fuzzer -a "renewable energy trends" paper.pdf  AI semantic search
  fuzzer -o hits.csv  "topic" *.pdf              export to CSV
  fuzzer -o hits.xlsx "topic" *.pdf              export to Excel
  fuzzer -o hits.json "topic" *.pdf              export to JSON
  fuzzer --gui                                   launch graphical interface
  fuzzer                                         (no args also launches the GUI)
""",
    )
    ap.add_argument("pattern", help="word or phrase to search for")
    ap.add_argument("files", nargs="+", metavar="FILE",
                    help="files or directories to search")

    grp = ap.add_argument_group("matching options")
    grp.add_argument("-k", "--case-sensitive", action="store_true",
                     help="case-sensitive search (default: ignore case)")
    grp.add_argument("-e", "--exact", action="store_true",
                     help="exact match only — disable fuzzy")
    grp.add_argument("-t", "--threshold", type=int, default=80, metavar="N",
                     help="fuzzy similarity threshold 0-100 (default: 80)")
    grp.add_argument("-a", "--ai", action="store_true",
                     help="AI semantic search via Claude (needs ANTHROPIC_API_KEY)")

    grp2 = ap.add_argument_group("output options")
    grp2.add_argument("-v", "--verbose", action="store_true",
                      help="show full sentence containing each match")
    grp2.add_argument("-C", "--context", type=int, default=0, metavar="N",
                      help="lines of context around each match (default: 0)")
    grp2.add_argument("-l", "--files-only", action="store_true",
                      help="print only filenames with matches")
    grp2.add_argument("-n", "--no-line-numbers", action="store_true",
                      help="suppress line numbers")
    grp2.add_argument("-r", "--recursive", action="store_true",
                      help="recurse into directories")
    grp2.add_argument("--no-color", action="store_true",
                      help="disable coloured output")
    grp2.add_argument("-o", "--output", metavar="FILE",
                      help="export results to FILE "
                           "(format auto-detected: .csv .tsv .json .txt .xlsx)")

    args = ap.parse_args(argv)

    if not 0 <= args.threshold <= 100:
        ap.error("--threshold must be 0-100")

    _color_on = not args.no_color and sys.stdout.isatty()

    files = collect_files(args.files, args.recursive)
    if not files:
        print("error: no files to search", file=sys.stderr)
        return 2

    results: Dict[str, Tuple[List[str], List[Match]]] = {}

    for fp in files:
        if args.ai:
            lines, matches = ai_search_file(fp, args.pattern)
        else:
            lines, matches = search_file(
                fp, args.pattern,
                case_sensitive=args.case_sensitive,
                exact_only=args.exact,
                threshold=args.threshold,
            )
        if matches:
            results[fp] = (lines, matches)

    if not results:
        print(_c(_YEL) + "no matches found" + _r(), file=sys.stderr)
        return 1

    total = print_results(
        results,
        pattern=args.pattern,
        case_sensitive=args.case_sensitive,
        files_only=args.files_only,
        show_nums=not args.no_line_numbers,
        context_lines=args.context,
        verbose=args.verbose,
        ai_mode=args.ai,
    )

    if args.output:
        export_results(results, args.output, verbose=args.verbose)

    n_files = len(results)
    summary = (
        f"\n{total} match{'es' if total != 1 else ''} "
        f"in {n_files} file{'s' if n_files != 1 else ''}"
    )
    print(_c(_CYN) + summary + _r(), file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
