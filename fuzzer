    # ── hover tooltip for full "Content" text ───────────────────────────
    _hover_tip: List[Optional[tk.Toplevel]] = [None]
    _hover_label: List[Optional[ttk.Label]] = [None]
    _hover_iid: List[str] = [""]

    def _hide_hover_tooltip() -> None:
        if _hover_tip[0] is not None:
            with contextlib.suppress(Exception):
                _hover_tip[0].destroy()
            _hover_tip[0] = None
            _hover_label[0] = None
        _hover_iid[0] = ""

    def _ensure_hover_tip() -> None:
        if _hover_tip[0] is not None:
            return
        _hover_tip[0] = tk.Toplevel(root)
        _hover_tip[0].wm_overrideredirect(True)
        _hover_tip[0].attributes("-topmost", True)
        _hover_label[0] = ttk.Label(
            _hover_tip[0],
            background=_T["TIP_BG"],
            foreground=_T["TIP_FG"],
            relief="solid",
            borderwidth=1,
            padding=(6, 3),
            wraplength=720,
        )
        _hover_label[0].pack(fill="both", expand=True)

    def _on_tree_motion(event: object = None) -> None:
        if event is None:
            return
        # Treeview x/y are widget-relative
        x = getattr(event, "x", 0)
        y = getattr(event, "y", 0)

        col = tree.identify_column(x)  # e.g. "#6"
        # content column index is 6 (("file","line","page","match","score","content"))
        if col != "#6":
            _hide_hover_tooltip()
            return

        iid = tree.identify_row(y)
        if not iid:
            _hide_hover_tooltip()
            return

        text = _row_full_lines.get(iid, "")
        if not text:
            _hide_hover_tooltip()
            return

        if _hover_tip[0] is None:
            _ensure_hover_tip()

        if iid != _hover_iid[0]:
            _hover_iid[0] = iid
            # Build a source header so the user knows where this snippet came
            # from without selecting the row. Format: "<basename>  ·  line 42
            # · page 7" (page omitted for non-PDF files).
            src_path = _row_paths.get(iid, "")
            vals = tree.item(iid, "values")
            try:
                _line_no = str(vals[1])
            except (IndexError, TypeError):
                _line_no = ""
            try:
                _page_no = str(vals[2]) if vals[2] else ""
            except (IndexError, TypeError):
                _page_no = ""
            _src_bits = []
            if src_path:
                _src_bits.append(os.path.basename(src_path))
            if _line_no:
                _src_bits.append(f"line {_line_no}")
            if _page_no:
                _src_bits.append(f"page {_page_no}")
            header = "  ·  ".join(_src_bits)
            tip_text = f"{header}\n\n{text}" if header else text
            if _hover_label[0] is not None:
                _hover_label[0].config(text=tip_text)

        # position tooltip near cursor
        tip_x = tree.winfo_rootx() + x + 16
        tip_y = tree.winfo_rooty() + y + 20
        if _hover_tip[0] is not None:
            _hover_tip[0].wm_geometry(f"+{tip_x}+{tip_y}")

    def _on_tree_leave(_event: object = None) -> None:
        _hide_hover_tooltip()

