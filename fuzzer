    # ── Transcribe: docx-of-links → batch of PDFs via sibling `transcribe` ──
    # Matches the CLI invocation the user runs by hand:
    #   transcribe path/to/links.docx -o output_dir/ --model large \
    #              --cookies chrome --also txt
    # Spawned in a background thread so the GUI stays responsive; stdout
    # lines stream into the activity log.
    _transcribe_state = {"running": False}

    def _run_transcribe() -> None:
        if _transcribe_state["running"]:
            messagebox.showinfo(
                "fuzzer – Transcribe",
                "A transcription is already running. Wait for it to finish "
                "or stop it from the terminal.")
            return
        src = filedialog.askopenfilename(
            title="STEP 1/2 — Pick the SOURCE .docx (contains YouTube links)",
            initialdir=str(_PROJECT_DIR),
            filetypes=[
                ("Word document", "*.docx"),
                ("All files", "*.*"),
            ],
        )
        if not src:
            return
        # Default output dir = "<docx-stem>_transcripts" next to the source.
        # Folder picker lets the user override.
        _src_path = Path(src)
        _default_out = _src_path.parent / f"{_src_path.stem}_transcripts"
        outdir = filedialog.askdirectory(
            title=(
                "STEP 2/2 — Pick the OUTPUT folder "
                "(transcribed PDFs will be written here). "
                "Cancel = use default next to the source."),
            initialdir=str(_src_path.parent),
            mustexist=False,
        )
        if not outdir:
            outdir = str(_default_out)
        Path(outdir).mkdir(parents=True, exist_ok=True)

        # Resolve the sibling `transcribe` script. fuzzer's shebang pins
        # /opt/homebrew/bin/python3, so we run the script directly and let
        # its own shebang choose its interpreter.
        _transcribe_path = Path(__file__).resolve().parent / "transcribe"
        if not _transcribe_path.exists():
            messagebox.showerror(
                "fuzzer – Transcribe",
                f"`transcribe` not found next to fuzzer at {_transcribe_path}")
            return

        # Whisper model download check — the first time the user picks a
        # given model, it pulls a few hundred MB to a few GB from the
        # Hugging Face cache. Warn explicitly so the long pause on the
        # first run doesn't look like a hang.
        _model = transcribe_model_var.get() or "large"
        _hf_cache = Path.home() / ".cache" / "huggingface" / "hub"
        _whisper_cache = Path.home() / ".cache" / "whisper"
        # Heuristic: any directory mentioning whisper-{model} (mlx OR
        # openai cache) counts as "already downloaded".
        _have = False
        with contextlib.suppress(Exception):
            for _d in list(_hf_cache.glob(f"models--*whisper-{_model}*")) + \
                     list(_whisper_cache.glob(f"{_model}*.pt")):
                if _d.exists():
                    _have = True
                    break
        if not _have:
            _sizes = {
                "tiny": "~75 MB", "base": "~150 MB", "small": "~500 MB",
                "medium": "~1.5 GB", "large": "~3 GB", "turbo": "~1.5 GB",
            }
            _size = _sizes.get(_model, "a few hundred MB")
            _ok = messagebox.askokcancel(
                "fuzzer – Transcribe",
                f"First run with the '{_model}' model.\n\n"
                f"Whisper will download the model file ({_size}) on this "
                f"first run — this can take a few minutes depending on your "
                f"network. After that, every run uses the cached copy and "
                f"starts instantly.\n\n"
                f"Continue?",
            )
            if not _ok:
                return

        _cmd = [
            str(_transcribe_path), str(_src_path),
            "-o", str(outdir),
            "--model", _model,
            "--cookies", "chrome",
            "--also", "txt",
        ]
        _transcribe_state["running"] = True
        transcribe_btn.config(text="Transcribing…", state="disabled")
        transcribe_model_cb.config(state="disabled")
        status_var.set(
            f"Transcribing {_src_path.name} → {Path(outdir).name}/")
        _log_activity(
            f"Transcribe start: {_src_path.name} → {outdir} "
            f"(model={_model}, cookies=chrome, also=txt)")
        # Initial progress: 0%, label "Preparing…". The bar reveals itself
        # via _progress_show and disappears in _done().
        root.after(0, lambda: _progress_set(0, "Preparing…"))

        # Patterns to drive the progress bar from streamed stdout:
        #   batch row tag      e.g. "[03/12] https://…"
        #   yt-dlp download    e.g. "[download]  17.4% of 12.34MiB at …"
        _ROW_TAG_RE = re.compile(r"\[(\d+)/(\d+)\]")
        _DL_PCT_RE = re.compile(r"\[download\]\s+(\d+\.\d+)%")
        _row_state: Dict[str, float] = {"row": 0, "total": 0, "row_inner": 0}

        def _push_progress() -> None:
            total = _row_state["total"] or 1
            # Each row contributes 1/total of the overall bar; the inner
            # download percentage (0..100) advances us within that slot.
            completed = max(0, _row_state["row"] - 1)
            base = (completed / total) * 100.0
            inner = (_row_state["row_inner"] / total)
            overall = base + inner
            label = (
                f"row {int(_row_state['row'])}/{int(total)}"
                if _row_state["row"] else "Starting…")
            root.after(
                0, lambda v=overall, t=label: _progress_set(v, t))

        def _worker() -> None:
            import subprocess as _sp
            rc = 1
            try:
                # Pipe stdout+stderr line-by-line so progress shows in the
                # activity log instead of buffering until the very end.
                proc = _sp.Popen(
                    _cmd, stdout=_sp.PIPE, stderr=_sp.STDOUT,
                    text=True, bufsize=1,
                )
                assert proc.stdout is not None
                for line in proc.stdout:
                    line = line.rstrip("\n")
                    if not line:
                        continue
                    # Most-recent message → status; full trail → activity log.
                    root.after(
                        0, lambda ln=line: status_var.set(ln[:160]))
                    root.after(0, lambda ln=line: _log_activity(ln[:200]))
                    # Progress parsing — outer row tags first (per-video
                    # boundaries reset the inner download counter to 0).
                    m_row = _ROW_TAG_RE.search(line)
                    if m_row:
                        _row_state["row"] = float(m_row.group(1))
                        _row_state["total"] = float(m_row.group(2))
                        _row_state["row_inner"] = 0.0
                        _push_progress()
                        continue
                    m_dl = _DL_PCT_RE.search(line)
                    if m_dl:
                        _row_state["row_inner"] = float(m_dl.group(1))
                        _push_progress()
                rc = proc.wait()
            except Exception as e:
                root.after(0, lambda _e=e: messagebox.showerror(
                    "fuzzer – Transcribe", f"Failed to run transcribe: {_e}"))
                root.after(0, lambda _e=e: _log_activity(
                    f"Transcribe error: {_e}"))
            finally:
                def _done() -> None:
                    _transcribe_state["running"] = False
                    transcribe_btn.config(text="Transcribe…", state="normal")
                    transcribe_model_cb.config(state="readonly")
                    _progress_hide()
                    if rc == 0:
                        status_var.set(
                            f"{_EXPORT_PREFIX}{outdir}")
                        _log_activity(
                            f"Transcribe done: {_src_path.name} → {outdir} "
                            "(click status to reveal)")
                    else:
                        status_var.set(
                            f"Transcribe failed (rc={rc}) — see activity log")
                        _log_activity(
                            f"Transcribe failed: rc={rc}")
                root.after(0, _done)

        threading.Thread(target=_worker, daemon=True).start()

    transcribe_btn.config(command=_run_transcribe)
    _Tooltip(
        transcribe_btn,
        "Transcribe a .docx of YouTube links to PDFs (one per link + a\n"
