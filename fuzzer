        # Live hex memory view — shows the actual bytes py_normalize reads
        # on the latest call, with highlighting:
        #   red    = byte will be DROPPED (diacritic / tatweel / superscript-alef)
        #   yellow = byte will be SUBSTITUTED (alef-variant → ا, yeh-variant → ي)
        #   plain  = passes through unchanged
        #
        # The C function classifies by 2-byte UTF-8 codepoint. We mirror its
        # rules below to colorize the input hex dump.
        def _classify(raw: bytes) -> List[str]:
            """Return per-byte tag: 'drop' / 'sub' / '' (one entry per byte)."""
            tags = [""] * len(raw)
            i = 0
            while i < len(raw):
                b = raw[i]
                if b < 0x80:
                    i += 1
                    continue
                if (b & 0xE0) == 0xC0 and i + 1 < len(raw):
                    cp = ((b & 0x1F) << 6) | (raw[i + 1] & 0x3F)
                    if (0x064B <= cp <= 0x0652) or cp == 0x0670 or cp == 0x0640:
                        tags[i] = tags[i + 1] = "drop"
                    elif cp in (0x0623, 0x0625, 0x0622, 0x0671,
                                0x0649, 0x0626):
                        tags[i] = tags[i + 1] = "sub"
                    i += 2
                    continue
                if (b & 0xF0) == 0xE0:
                    i += 3
                    continue
                if (b & 0xF8) == 0xF0:
                    i += 4
                    continue
                i += 1
            return tags

        def _insert_hex(widget: tk.Text, raw: bytes, tags: List[str]) -> None:
            widget.config(state="normal")
            widget.delete("1.0", "end")
            for idx, b in enumerate(raw[:96]):
                widget.insert("end", f"{b:02x} ", tags[idx] or ())
                if (idx + 1) % 16 == 0:
                    widget.insert("end", "\n")
            if len(raw) > 96:
                widget.insert("end", f"  … (+{len(raw) - 96} B)")
            widget.config(state="disabled")

        def _mk_hex(parent: tk.Misc, label: str) -> tk.Text:
            row = ttk.Frame(parent)
            row.pack(fill="x", pady=(2, 0))
            ttk.Label(row, text=label, width=8,
                      font=("Menlo", 11, "bold")).pack(side="left", anchor="n")
            t = tk.Text(row, height=4, font=("Menlo", 11), wrap="none",
                        bg="#1e1e1e", fg="#d4d4d4",
                        insertbackground="#d4d4d4")
            t.tag_configure("drop", background="#5a1d1d", foreground="#ff8a8a")
            t.tag_configure("sub", background="#5a4a1d", foreground="#ffd66b")
            t.pack(side="left", fill="x", expand=True)
            t.config(state="disabled")
            return t

        dbg_in_hex = _mk_hex(dbg_frame, "INPUT")
        dbg_out_hex = _mk_hex(dbg_frame, "OUTPUT")

        # Clickable recent-calls list. Single-click pins to that call (which
        # implicitly freezes the hex view); click again or press Unpin to
        # resume live following.
        dbg_row = ttk.Frame(dbg_frame)
        dbg_row.pack(fill="x", expand=False, pady=(4, 0))
        ttk.Label(dbg_row, text="CALLS", width=8,
                  font=("Menlo", 11, "bold")).pack(side="left", anchor="n")
        dbg_list = tk.Listbox(dbg_row, height=5, font=("Menlo", 11),
                              bg="#1e1e1e", fg="#9cdcfe",
                              selectbackground="#264f78", selectforeground="#ffffff",
                              activestyle="none", exportselection=False)
        dbg_list.pack(side="left", fill="x", expand=True)

        def _render() -> None:
            """Repaint hex panes + stats line based on pause/pin state."""
            pin = _dbg_pin[0]
            if pin is not None:
                raw_in, raw_out, label = pin
                dbg_stats_var.set(
                    f"calls={len(_NORM_CALLS)}   "
                    f"PINNED: {label}   "
                    f"in {len(raw_in)}B → out {len(raw_out)}B   "
                    f"Δ={len(raw_out) - len(raw_in):+d}B"
                )
            elif _NORM_CALLS:
                ts, inp, out, dt = _NORM_CALLS[-1]
                raw_in = inp.encode("utf-8")
                raw_out = out.encode("utf-8")
                state = "PAUSED" if _dbg_paused[0] else "live"
                dbg_stats_var.set(
                    f"calls={len(_NORM_CALLS)}   last={dt:.1f}µs   "
                    f"in@0x{id(inp):x} ({len(raw_in)}B) → "
                    f"out@0x{id(out):x} ({len(raw_out)}B)   "
                    f"Δ={len(raw_out) - len(raw_in):+d}B   {state}"
                )
            else:
                dbg_stats_var.set("calls=0   waiting for first call…   live")
                raw_in = raw_out = b""
            _insert_hex(dbg_in_hex, raw_in, _classify(raw_in))
            _insert_hex(dbg_out_hex, raw_out, [""] * len(raw_out))

        def _refill_listbox() -> None:
            """Repopulate the listbox to reflect the latest _NORM_CALLS slice."""
            dbg_list.delete(0, "end")
            recent = _NORM_CALLS[-12:]
            for ts, inp, out, dt in recent:
                tm = _dbg_time.strftime("%H:%M:%S", _dbg_time.localtime(ts))
                dbg_list.insert("end",
                                f"[{tm}] {dt:6.1f}µs  {inp[:24]!r:26s} → {out[:24]!r}")

        def _on_list_click(_event: object) -> None:
            sel = dbg_list.curselection()
            if not sel:
                return
            recent = _NORM_CALLS[-12:]
            idx = sel[0]
            if idx >= len(recent):
                return
            ts, inp, out, dt = recent[idx]
            _dbg_pin[0] = (inp.encode("utf-8"), out.encode("utf-8"),
                           f"[{_dbg_time.strftime('%H:%M:%S', _dbg_time.localtime(ts))}] "
                           f"{inp[:24]!r}")
            unpin_btn.state(["!disabled"])
            _render()

        dbg_list.bind("<<ListboxSelect>>", _on_list_click)

        # Click-to-inspect: selecting a row in the main results tree runs the
        # text through _normalize_arabic (recording a call) and pins the result
        # so you can examine what was processed.
        def _on_tree_select(_event: object) -> None:
            sel = tree.selection()
            if not sel:
                return
            row = tree.item(sel[0])
            vals = row.get("values") or []
            # columns: ("file", "line", "page", "match", "score", "content")
            content = str(vals[5]) if len(vals) > 5 else ""
            if not content:
                return
            normalized = _normalize_arabic(content)  # records into _NORM_CALLS
            _dbg_pin[0] = (content.encode("utf-8"), normalized.encode("utf-8"),
                           f"row: {content[:24]!r}")
            unpin_btn.state(["!disabled"])
            _render()

        tree.bind("<<TreeviewSelect>>", _on_tree_select, add="+")

        _dbg_seen = [0]

        def _dbg_tick() -> None:
            n = len(_NORM_CALLS)
            if n != _dbg_seen[0]:
                _refill_listbox()
                if not _dbg_paused[0] and _dbg_pin[0] is None:
                    _render()
                _dbg_seen[0] = n
            root.after(150, _dbg_tick)

        root.after(150, _dbg_tick)
        _render()

