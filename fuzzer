    # Mutable text/value cache so a <Configure> resize can redraw without
    # losing the most-recent state.
    _progress_state: Dict[str, object] = {"value": 0.0, "text": ""}

    def _progress_redraw(_e: object = None) -> None:
        with contextlib.suppress(Exception):
            _progress_canvas.delete("all")
            w = max(1, _progress_canvas.winfo_width())
            h = max(1, _progress_canvas.winfo_height())
            v = float(_progress_state["value"])
            # Fill rectangle — purple accent so the bar stands out on dark.
            fill_w = int(w * (v / 100.0))
            if fill_w > 0:
                _progress_canvas.create_rectangle(
                    0, 0, fill_w, h,
                    fill=_T["ACCENT"], outline="",
                )
            txt = str(_progress_state["text"])
            label = f"{txt}  ·  {int(v)}%" if txt else f"{int(v)}%"
            # Drop-shadow trick: draw the text twice (1px offset, darker)
            # so it stays readable both over the filled portion and the
            # empty trough.
            _progress_canvas.create_text(
                w // 2 + 1, h // 2 + 1,
                text=label, fill="#0e0814",
                font=("Menlo", 11, "bold"),
            )
            _progress_canvas.create_text(
                w // 2, h // 2,
                text=label, fill="#ffffff",
                font=("Menlo", 11, "bold"),
            )
    _progress_canvas.bind("<Configure>", _progress_redraw)

