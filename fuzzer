    def _auto_fit(grow_only: bool = True) -> None:
        """Resize the window to fit its requested content.
        With grow_only=True, only enlarge — never shrink past the user's size.
        """
        root.update_idletasks()
        w_req, h_req = root.winfo_reqwidth(), root.winfo_reqheight()
        w_cur, h_cur = root.winfo_width(), root.winfo_height()
        new_w = max(w_req, w_cur) if grow_only else w_req
        new_h = max(h_req, h_cur) if grow_only else h_req
        if (new_w, new_h) != (w_cur, h_cur):
            root.geometry(f"{new_w}x{new_h}")

