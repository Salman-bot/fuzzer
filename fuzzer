    # ── hover tooltip for full "Content" text ───────────────────────────
    _hover_tip: List[Optional[tk.Toplevel]] = [None]
    _hover_label: List[Optional[ttk.Label]] = [None]
    _hover_iid: List[str] = [""]

    def _hide_hover_tooltip() -> None:
        if _hover_tip[0] is not None:
            with contextlib.suppress(Exception):
                _hover_tip[0].destroy()
            _hover_tip[0] = None
            _hover_label[0] = None
        _hover_iid[0] = ""

    def _ensure_hover_tip() -> None:
        if _hover_tip[0] is not None:
            return
        _hover_tip[0] = tk.Toplevel(root)
        _hover_tip[0].wm_overrideredirect(True)
        _hover_tip[0].attributes("-topmost", True)
        _hover_label[0] = ttk.Label(
            _hover_tip[0],
            background="#ffffc0",
            relief="solid",
            borderwidth=1,
            padding=(6, 3),
            wraplength=720,
        )
        _hover_label[0].pack(fill="both", expand=True)

    def _on_tree_motion(event: object = None) -> None:
        if event is None:
            return
        # Treeview x/y are widget-relative
        x = getattr(event, "x", 0)
        y = getattr(event, "y", 0)

        col = tree.identify_column(x)  # e.g. "#6"
        # content column index is 6 (("file","line","page","match","score","content"))
        if col != "#6":
            _hide_hover_tooltip()
            return

        iid = tree.identify_row(y)
        if not iid:
            _hide_hover_tooltip()
            return

        text = _row_full_lines.get(iid, "")
        if not text:
            _hide_hover_tooltip()
            return

        if _hover_tip[0] is None:
            _ensure_hover_tip()

        if iid != _hover_iid[0]:
            _hover_iid[0] = iid
            if _hover_label[0] is not None:
                _hover_label[0].config(text=text)

        # position tooltip near cursor
        tip_x = tree.winfo_rootx() + x + 16
        tip_y = tree.winfo_rooty() + y + 20
        if _hover_tip[0] is not None:
            _hover_tip[0].wm_geometry(f"+{tip_x}+{tip_y}")

    def _on_tree_leave(_event: object = None) -> None:
        _hide_hover_tooltip()

    tree.bind("<Motion>", _on_tree_motion, add="+")
    tree.bind("<Leave>", _on_tree_leave, add="+")

    tree.bind("<Double-1>", open_selected)
    tree.bind("<Return>", open_selected)
    pattern_entry.bind("<Return>", lambda _e: start_search())
    files_entry.bind("<Return>", lambda _e: start_search())

