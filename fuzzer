    def copy_selected(_event: object = None) -> str:
        sel = tree.selection()
        if not sel:
            return "break"
        iid = str(sel[0])

        filepath = _row_paths.get(iid, "")
        vals = tree.item(iid, "values")
        if not vals:
            return "break"

        try:
            line_num = int(vals[1])
        except Exception:
            line_num = 1

        page_text = str(vals[2]) if len(vals) > 2 else ""
        match_type = str(vals[3]) if len(vals) > 3 else ""
        score_text = str(vals[4]) if len(vals) > 4 else ""
        content = str(vals[5]) if len(vals) > 5 else ""

        score_suffix = ""
        if match_type == "fuzzy" and score_text:
            score_suffix = f" {score_text}%"

        page_suffix = f" (page {page_text})" if page_text else ""
        text = (
            f"{filepath}:{line_num}{page_suffix}\n"
