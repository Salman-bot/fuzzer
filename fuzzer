    # ── argument parsing for the files field ─────────────────────────────────
    import shlex

    def parse_files_field(text: str) -> List[str]:
        text = text.strip()
        if not text:
            return []
        try:
            return shlex.split(text)
        except ValueError:
            return [t for t in text.split() if t]

    # ── search worker ────────────────────────────────────────────────────────
    def worker(pattern: str, paths: List[str], case_sensitive: bool,
               threshold: int,
               recursive: bool, rga: bool = False,
               whole_word: bool = False, use_smart: bool = False) -> None:
        try:
            files = collect_files(paths, recursive)
            if not files:
                msg_q.put(("error", "No files to search."))
                return
            for i, fp in enumerate(files, 1):
                # Honour Stop button between files. (Mid-file cancellation
                # isn't supported — the current file finishes first.)
                if state.get("cancel_search"):
                    msg_q.put(("done",))
                    return
                msg_q.put(("status", f"Searching {i}/{len(files)}: {fp}"))
                if rga and _RGA_PATH:
                    lines, matches = rga_search_file(
                        fp, pattern,
                        case_sensitive=case_sensitive,
                        threshold=threshold,
                        whole_word=whole_word,
                        use_smart=use_smart,
                    )
                else:
                    lines, matches = search_file(
                        fp, pattern,
                        case_sensitive=case_sensitive,
                        threshold=threshold,
                        whole_word=whole_word,
                        use_smart=use_smart,
                    )
                if matches:
                    # Stream each file's results immediately so the GUI stays
                    # live and results are not lost if a later file crashes.
                    msg_q.put(("match", fp, lines, matches))
            msg_q.put(("done",))
        except Exception as e:
            msg_q.put(("error", f"{type(e).__name__}: {e}"))

    def start_search() -> None:
        if state["searching"]:
