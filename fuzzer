    _row_paths: Dict[str, str] = {}  # iid → full file path
    _row_full_lines: Dict[str, str] = {}  # iid → full match text for tooltips
    # original path → highlighted copy path
    _highlighted_pdfs: Dict[str, str] = {}

    # Monotonic counter so each highlighted-copy filename is unique. We used to
    # use id(_doc) here, but CPython reuses object IDs after the doc is closed
    # and GC'd — that caused two different searches to write the same tmp path,
    # which made Preview show its cached first-open page on subsequent opens.
    import itertools as _itertools
    _tmp_counter = _itertools.count(1)

    def _build_highlighted_pdf(fp: str, matches: List[Match]) -> str:
        """Highlight query matches in a PDF copy.

        Strategy in two layers, weakest-to-strongest:
          1. PyMuPDF's exact search_for() for both the original and normalized
             query — fast path that handles ligatures via PyMuPDF flags.
          2. Word-level normalized comparison via page.get_text("words") —
             catches Arabic matches where the PDF text has diacritics or
             alef variants that the user's query didn't (the common case the
             fuzzy search picked up but exact search_for missed).
        """
        try:
            import fitz as _fitz
            _tmp_dir = _PROJECT_DIR / ".fuzzer_tmp"
            _tmp_dir.mkdir(exist_ok=True)
            _doc = _fitz.open(fp)

            _query = pattern_var.get().strip()
            _query_norm = _normalize_arabic(_query)
            _use_smart = bool(smart_var.get())
            _case = bool(case_var.get())
            _whole_word = bool(whole_word_var.get())
            # Parse the Smart query once so each per-page pass can pull
            # positive terms (negatives are never highlighted).
            _smart_parsed = (
                _parse_smart_query(_query) if _use_smart
                else {"required": [], "excluded": []})
            # Flatten Smart positive terms into a single list for pass 1
            # literal highlighting.
            _smart_positive_terms: List[str] = []
            if _use_smart:
                _seen_pos: set = set()
                for _og in _smart_parsed["required"]:
                    for _t in _og:  # type: ignore[union-attr]
                        if _t and _t not in _seen_pos:
                            _seen_pos.add(_t)
                            _smart_positive_terms.append(_t)
            # Unique literal search terms for pass 1. In smart mode we use
            # the parsed positive terms; in default mode the raw query +
            # its Arabic-normalized form.
            _terms = (
                list(_smart_positive_terms) if _use_smart
                else list(dict.fromkeys(t for t in [_query, _query_norm] if t))
            )

            # Pages that actually had matches
            _hit_pages = set(m.page_num or 1 for m in matches)
            # Per-word normalized tokens for the word-level pass. In smart
            # mode use the parsed positive terms; in default mode split
            # the raw query.
            _query_words = (
                [_normalize_arabic(t) for t in _smart_positive_terms if t]
                if _use_smart
                else [_normalize_arabic(w)
                      for w in _query.split() if w.strip()])

            import string as _string
            # ASCII punctuation that PyMuPDF's search_for tends to normalize
            # differently than get_text returns (curly vs straight quotes,
            # smart dashes, etc.). Stripping these from the end of a regex
            # match before retrying recovers cases like `H"` where the raw
            # pattern won't match but the alphanumeric core will.
            _strip_chars = _string.punctuation

            def _search_with_fallback(_pg_obj: object, _term: str) -> int:
                """Add highlight annotations for `_term` on the page. Returns
                the number of annotations added. If the direct search_for
                returns no quads, retries with leading/trailing punctuation
                stripped."""
                _added = 0
                for _q in _pg_obj.search_for(_term, quads=True):  # type: ignore[attr-defined]
                    _pg_obj.add_highlight_annot(_q)  # type: ignore[attr-defined]
                    _added += 1
                if _added:
                    return _added
                _stripped = _term.strip(_strip_chars)
                if _stripped and _stripped != _term:
                    for _q in _pg_obj.search_for(_stripped, quads=True):  # type: ignore[attr-defined]
                        _pg_obj.add_highlight_annot(_q)  # type: ignore[attr-defined]
                        _added += 1
                return _added

            for _pn in _hit_pages:
                if not (1 <= _pn <= len(_doc)):
                    continue
                _pg = _doc[_pn - 1]
                _highlighted_any = False
                # Smart mode's positive terms ARE literal substrings (quoted
                # phrases + bare words), so they go straight into the same
                # search_for pass as the default-mode terms. The regex
                # finditer + collection step we used to need is no longer
                # required.
                _regex_terms: List[str] = list(_terms) if _use_smart else []
                # Pass 1 (literal): exact substring search via PyMuPDF
                for _term in _terms:
                    if _search_with_fallback(_pg, _term) > 0:
                        _highlighted_any = True
                # Pass 2: normalized word match. Always runs (cheap) so we
                # catch additional hits the exact pass missed — e.g. words
                # with fatha/damma/kasra or أ/إ/ا differences AND words
                # where search_for failed because of CMap / punctuation
                # aliasing (regex mode adds the matched substrings to the
                # per-word check too).
                _regex_terms_norm = [
                    _normalize_arabic(_t).lower() for _t in _regex_terms]
                with contextlib.suppress(Exception):
                    _words = _pg.get_text("words")  # [(x0,y0,x1,y1,word,...)]
                    for _w in _words:
                        if len(_w) < 5:
                            continue
                        _word_text = str(_w[4])
                        _word_norm = _normalize_arabic(_word_text)
                        if not _word_norm:
                            continue
                        _word_norm_lower = _word_norm.lower()
                        _hit = any(qw and qw in _word_norm
                                   for qw in _query_words)
                        if not _hit and _regex_terms_norm:
                            _hit = any(rt and rt in _word_norm_lower
                                       for rt in _regex_terms_norm)
                        if _hit:
                            _rect = _fitz.Rect(_w[0], _w[1], _w[2], _w[3])
                            _pg.add_highlight_annot(_rect)
                            _highlighted_any = True
                if not _highlighted_any:
                    _log_activity(
                        f"PDF highlight: no match on page {_pn} of "
                        f"{os.path.basename(fp)}")

            import time as _t
            _tmp = str(
                _tmp_dir
                / f"fuzzer_{os.getpid()}_{next(_tmp_counter)}_{_t.time_ns()}.pdf"
            )
            _doc.save(_tmp)
            _doc.close()
            _log_activity(f"PDF highlighted: {os.path.basename(fp)}")
            return _tmp
        except Exception as _e:
            status_var.set(f"Highlight failed: {_e}")
            _log_activity(f"Highlight failed for {os.path.basename(fp)}: {_e}")
            return fp

    def _append_file_results(fp: str, matches: List[Match]) -> None:
        """Add one file's matches to the tree and pre-build its PDF highlight."""
        display_name = _fix_arabic(os.path.basename(fp))
        row_index = len(_row_paths)
        for m in matches:
            if m.score == 100:
                match_type, score_text = "exact", "100"
            elif m.score == -1:
                match_type, score_text = "ai", ""
            else:
                match_type, score_text = "fuzzy", str(m.score)
            page_text = str(m.page_num) if m.page_num else ""
            _tag = "odd" if row_index % 2 else "even"
            # Anchor the snippet on the *actual* regex/literal match
            # position when we can find one — `_line_context`'s fuzzy-token
            # heuristic otherwise crops long joined lines (e.g. multi-column
            # PDFs where PyMuPDF's sort=True merges two columns) before
            # reaching the match, leaving the ‹…› markers nowhere to land.
            _full_ranges = _find_match_ranges(
                m.line, pattern_var.get(),
                use_smart=smart_var.get(),
                case_sensitive=case_var.get(),
                whole_word=whole_word_var.get(),
            )
            if _full_ranges:
                # Window of ~120 chars centered on the first match.
                _ms, _me = _full_ranges[0]
                _win_half = 60
                _ws = max(0, _ms - _win_half)
                _we = min(len(m.line), _me + _win_half)
                _snippet = m.line[_ws:_we]
                if _ws > 0:
                    _snippet = "… " + _snippet
                if _we < len(m.line):
                    _snippet = _snippet + " …"
                # Re-compute ranges in the trimmed snippet coordinates.
                _snippet_ranges = _find_match_ranges(
                    _snippet, pattern_var.get(),
                    use_smart=smart_var.get(),
                    case_sensitive=case_var.get(),
                    whole_word=whole_word_var.get(),
                )
            else:
                _snippet = _line_context(m.line, pattern_var.get())
                _snippet_ranges = _find_match_ranges(
                    _snippet, pattern_var.get(),
                    use_smart=smart_var.get(),
                    case_sensitive=case_var.get(),
                    whole_word=whole_word_var.get(),
                )
            # Mark the matched substring(s) inside the snippet so the user
            # can see *where* the hit is — Tk's Treeview cells can't paint
            # per-substring backgrounds, so we wrap with ‹…› guillemets.
            # The yellow-bg highlight lives in the selected-row preview
            # below the table (a tk.Text widget supports per-range tags).
            _snippet_marked = _wrap_marks(_snippet, _snippet_ranges)
            iid = tree.insert("", "end", values=(
                display_name, m.line_num, page_text, match_type, score_text,
                _fix_arabic(_snippet_marked)), tags=(_tag,))
            _row_paths[iid] = fp
            _row_full_lines[iid] = _fix_arabic(m.line)
            row_index += 1
        if Path(fp).suffix.lower() == ".pdf":
            _highlighted_pdfs[fp] = _build_highlighted_pdf(fp, matches)

    def _refresh_status() -> None:
        results = state["results"]
        total = sum(len(m) for _, m in results.values())
        n_files = len(results)
        status_var.set(
            f"{total} match{'es' if total != 1 else ''} "
            f"in {n_files} file{'s' if n_files != 1 else ''}"
        )

    def populate(results: Dict[str, Tuple[List[str], List[Match]]]) -> None:
        """Rebuild tree from scratch (used for cancel/error replay)."""
        _row_paths.clear()
        _highlighted_pdfs.clear()
        tree.delete(*tree.get_children())
        for fp, (_, matches) in results.items():
            _append_file_results(fp, matches)
        _refresh_status()

    def stop_search() -> None:
        if not state["searching"]:
            return
        state["cancel_search"] = True
        stop_btn.config(state="disabled")
        status_var.set("Cancelling… (current file will finish first)")

    def poll_queue() -> None:
        with contextlib.suppress(queue.Empty):
            while True:
                msg = msg_q.get_nowait()
                kind = msg[0]
                if kind == "status":
                    status_var.set(str(msg[1]))
                elif kind == "match":
                    _, fp, lines, matches = msg
                    # type: ignore[index]
                    state["results"][fp] = (lines, matches)
                    _append_file_results(fp, matches)
                    export_btn.config(state="normal")
                    _refresh_status()
                elif kind == "done":
                    was_cancelled = state.get("cancel_search", False)
                    state["searching"] = False
                    state["cancel_search"] = False
                    search_btn.config(text="Search", cursor="hand2")
                    _apply_search_btn_colors()
                    stop_btn.config(state="disabled")
                    results = state["results"]
                    if results:
                        # type: ignore[union-attr]
                        _n = sum(len(m) for _, m in results.items())
                        if was_cancelled:
                            status_var.set(
                                f"Stopped — {_n} match(es) in {len(results)} file(s)")
                            _log_activity(
                                f"Search cancelled — {_n} match(es) collected")
                        else:
                            _refresh_status()
                            _log_activity(
                                f"Done — {_n} match(es) in {len(results)} file(s)")
                    else:
                        status_var.set(
                            "Stopped — no results yet" if was_cancelled
                            else "No matches found.")
                        export_btn.config(state="disabled")
                        _log_activity(
                            "Search cancelled — no results" if was_cancelled
                            else "Done — no matches found")
                elif kind == "error":
                    state["searching"] = False
                    state["cancel_search"] = False
                    search_btn.config(text="Search", cursor="hand2")
                    _apply_search_btn_colors()
                    stop_btn.config(state="disabled")
                    status_var.set(f"Error: {msg[1]}")
                    _log_activity(f"Error: {str(msg[1])[:120]}")
                    messagebox.showerror("fuzzer", str(msg[1]))
        root.after(100, poll_queue)

    def clear_results() -> None:
        tree.delete(*tree.get_children())
        _row_paths.clear()
        _row_full_lines.clear()
        state["results"] = {}
        export_btn.config(state="disabled")
        status_var.set("Ready")
        _log_activity("Results cleared")

    def export_to_file() -> None:
        results = state["results"]
        if not results:
            return
        # Suggest a filename built from the active query + result count +
        # timestamp so back-to-back exports don't all collide on the same
        # name (the OS otherwise re-uses the last-used name).
        import datetime as _dt
        _pat_raw = (pattern_var.get() or "search").strip()
        _pat_safe = re.sub(r"[^A-Za-z0-9._-]+", "-", _pat_raw).strip("-_.")[:32] or "search"
        _n_total = sum(
            len(m) for _, m in results.values())  # type: ignore[attr-defined]
        _ts = _dt.datetime.now().strftime("%Y%m%d-%H%M")
        _default_name = f"fuzzer-{_pat_safe}-{_n_total}m-{_ts}.xlsx"
        path = filedialog.asksaveasfilename(
            title="Export results",
            defaultextension=".xlsx",
            initialdir=str(_PROJECT_DIR),
            initialfile=_default_name,
            filetypes=[
                ("Excel workbook", "*.xlsx"),
                ("CSV", "*.csv"),
                ("TSV", "*.tsv"),
                ("JSON", "*.json"),
                ("Text", "*.txt"),
                ("All files", "*.*"),
            ],
        )
        if not path:
            return
        try:
            # type: ignore[arg-type]
            export_results(results, path)
            status_var.set(f"Exported to {path}")
            _log_activity(f"Exported to {os.path.basename(path)}")
        except Exception as e:
            messagebox.showerror("fuzzer", f"Export failed: {e}")
            _log_activity(f"Export failed: {e}")

    _editor_exts = {'.txt', '.md', '.py', '.js', '.ts', '.jsx', '.tsx',
                    '.json', '.xml', '.html', '.htm', '.rst', '.csv',
                    '.log', '.yaml', '.yml', '.toml', '.ini', '.cfg'}

    def open_selected(event: object = None) -> None:
        # The single-click already selected the row; use that as primary source.
        # identify_row is unreliable on Windows (DPI scaling, scrolled views).
        sel = tree.selection()
        iid = str(sel[0]) if sel else ""
        if not iid and event is not None and hasattr(event, "y"):
            # type: ignore[attr-defined]
            iid = tree.identify_row(event.y) or ""
        if not iid:
            return

        filepath = _row_paths.get(iid, "")
        if not filepath:
            return

        vals = tree.item(iid, "values")
        # values order: (file, line, page, match, score, content)
        try:
            line_num = int(vals[1])
        except (ValueError, IndexError):
            line_num = 1
        try:
            page_num = int(vals[2]) if vals[2] else 0
        except (ValueError, IndexError):
            page_num = 0

        import shutil
        import subprocess
        ext = Path(filepath).suffix.lower()

        def _open_default(path: str) -> None:
            subprocess.Popen(["open", path])

        try:
            if ext == ".pdf":
                open_page = page_num or 1
                # Use the pre-built highlighted copy from populate(); fall back
                # to original if not available (e.g. fitz not installed).
                _tmp_path = _highlighted_pdfs.get(filepath, filepath)
                hl_note = "" if _tmp_path != filepath else " (no highlight — fitz missing?)"

                # Snap fuzzer to the left half and target the PDF viewer at
                # the right half, so the user sees both panes side-by-side
                # without manually arranging windows. macOS reserves the top
                # ~30 px for the menu bar; we leave a similar margin at the
                # bottom for the Dock.
                _screen_w = root.winfo_screenwidth()
                _screen_h = root.winfo_screenheight()
                _margin = 30
                _half = _screen_w // 2
                _viewer_top = _margin
                _viewer_left = _half
                _viewer_right = _screen_w
                _viewer_bottom = _screen_h - _margin
                with contextlib.suppress(Exception):
                    root.geometry(
                        f"{_half}x{_screen_h - _margin * 2}+0+{_margin}")

                _esc = _tmp_path.replace("\\", "\\\\").replace('"', '\\"')
                # Prefer Skim when installed — its AppleScript dictionary has
                # first-class `go to page N` and reliable annotation viewing.
                # Preview is the fallback; it requires fragile UI scripting
                # (Cmd+Opt+G → text-field-in-sheet) for page nav.
                _skim_installed = os.path.isdir("/Applications/Skim.app")
                if _skim_installed:
                    _script = "\n".join([
                        'tell application "Skim"',
                        '  activate',
                        f'  set d to open POSIX file "{_esc}"',
                        f'  try',
                        f'    set bounds of window 1 to '
                        f'{{{_viewer_left}, {_viewer_top}, '
                        f'{_viewer_right}, {_viewer_bottom}}}',
                        f'  end try',
                        f'  try',
                        f'    tell d to go to page {open_page}',
                        f'  end try',
                        'end tell',
                    ])
                    _viewer_name = "Skim"
                else:
                    _script = "\n".join([
                        'tell application "Preview"',
                        '  activate',
                        f'  open POSIX file "{_esc}"',
                        'end tell',
                        'delay 0.35',
                        'try',
                        '  tell application "System Events"',
                        '    tell process "Preview"',
                        '      tell front window',
                        '        if value of attribute "AXMinimized" is true then',
                        '          set value of attribute "AXMinimized" to false',
                        '        end if',
                        f'        set position to {{{_viewer_left}, {_viewer_top}}}',
                        f'        set size to {{{_viewer_right - _viewer_left}, '
                        f'{_viewer_bottom - _viewer_top}}}',
                        '      end tell',
                        '    end tell',
                        '  end tell',
                        'end try',
                        f'if {open_page} > 1 then',
                        '  tell application "System Events"',
                        '    tell process "Preview"',
                        '      keystroke "g" using {command down, option down}',
                        '      set n to 0',
                        '      repeat',
                        '        delay 0.06',
                        '        set n to n + 1',
                        '        if n > 30 then exit repeat',
                        '        try',
                        '          tell sheet 1 of front window',
                        f'            set value of text field 1 to "{open_page}"',
                        '            click button "OK"',
                        '          end tell',
                        '          exit repeat',
                        '        end try',
                        '      end repeat',
                        '    end tell',
                        '  end tell',
                        'end if',
                    ])
                    _viewer_name = "Preview"
                _as_proc = subprocess.run(
                    ["osascript", "-e", _script],
                    capture_output=True, text=True
                )
                if _as_proc.returncode != 0:
                    _as_err = (_as_proc.stderr or _as_proc.stdout).strip()
                    status_var.set(f"Open failed — {_as_err[:80]}")
                    messagebox.showerror(
                        "fuzzer – open PDF", f"AppleScript error: {_as_err}")
                    return

                status_var.set(
                    f"Opened page {open_page} — {os.path.basename(filepath)}{hl_note}")
                _log_activity(
                    f"Opened PDF '{os.path.basename(filepath)}' page {open_page} "
                    f"in {_viewer_name}"
                    + (" (highlighted)" if _tmp_path != filepath else " (no highlight)"))

            elif ext in _editor_exts:
                if shutil.which("code"):
                    subprocess.Popen(
                        ["code", "--goto", f"{filepath}:{line_num}"])
                elif shutil.which("cursor"):
                    subprocess.Popen(
                        ["cursor", "--goto", f"{filepath}:{line_num}"])
                elif shutil.which("subl"):
                    subprocess.Popen(["subl", f"{filepath}:{line_num}"])
                else:
                    _open_default(filepath)
                status_var.set(
                    f"Opened line {line_num} — {os.path.basename(filepath)}")
                _log_activity(
                    f"Opened '{os.path.basename(filepath)}' line {line_num}")
            else:
                _open_default(filepath)
                status_var.set(f"Opened {os.path.basename(filepath)}")
                _log_activity(f"Opened '{os.path.basename(filepath)}'")
        except Exception as _ex:
            status_var.set(f"Open failed: {_ex}")
            messagebox.showerror("fuzzer", f"Could not open:\n{_ex}")

