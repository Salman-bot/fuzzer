    _WS_RUN = re.compile(r"\s+")
    _HAS_ARABIC = re.compile(r"[؀-ۿ]")
    # Mirror pairs — bidi RTL rendering flips these visually. Pre-swap them in
    # the logical string so the rendered output reads correctly left-to-right.
    _BIDI_MIRROR = str.maketrans({"(": ")", ")": "(", "[": "]", "]": "[",
                                  "{": "}", "}": "{", "<": ">", ">": "<"})
    # Some Arabic PDFs encode the definite article ال as ا+م+ل (positions 1-2
    # swapped). Detect at word start and swap back. ا (0x627) is matched, but
    # not أ/إ/آ — those are different alef variants for which "أم"/"إم" are
    # legitimate word starts.
    _AL_SWAP = re.compile(r"(?<![ء-ي])امل")

    def _fix_arabic(text: str) -> str:
        if not text:
            return text
        # Collapse runs of whitespace — PyMuPDF sort=True often inserts
        # huge stretches of spaces between visually-separated segments,
        # which creates ugly leading gaps in the Treeview content column.
        text = _WS_RUN.sub(" ", text).strip()
        # Fix broken-encoding ا+م+ل → ا+ل+م at word starts
        text = _AL_SWAP.sub("الم", text)
        if _platform.system() == "Darwin":
            # PyMuPDF returns logical-order Unicode; CoreText + Geeza Pro
            # handles RTL shaping and bidi rendering natively in tkinter.
            # For mixed Arabic text, pre-swap mirror pairs so brackets read
            # visually correct after bidi mirroring.
            if _HAS_ARABIC.search(text):
                text = text.translate(_BIDI_MIRROR)
            return text
        else:
            reshaped = _arabic_reshaper.reshape(text) if _arabic_reshaper else text
            return _bidi_display(reshaped, base_dir='R') if _bidi_display else reshaped

    def _line_context(line: str, query: str, around: int = 6) -> str:
        """Return a snippet of `line` centered on the token best matching
        `query`. PyMuPDF's sort=True extraction can lump text from many
        visual lines into one logical line; this trims the displayed
        content down to the matched word plus N tokens on each side."""
        from difflib import SequenceMatcher as _SM
        if not line:
            return line
        tokens = line.split()
        if not tokens:
            return line
        q_norm = _normalize_arabic((query or "").strip())
        if not q_norm:
            return " ".join(tokens)
        best_idx, best_score = 0, 0.0
        for i, t in enumerate(tokens):
            s = _SM(None, q_norm, _normalize_arabic(t)).ratio()
            if s > best_score:
                best_idx, best_score = i, s
        if best_score < 0.4:
            # No clear match — fall back to a leading chunk
            return " ".join(tokens[: around * 2 + 1]) + (" …" if len(tokens) > around * 2 + 1 else "")
        lo = max(0, best_idx - around)
        hi = min(len(tokens), best_idx + around + 1)
        snippet = " ".join(tokens[lo:hi])
        if lo > 0:
            snippet = "… " + snippet
        if hi < len(tokens):
            snippet += " …"
        return snippet

