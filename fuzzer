        def _on_drop(event: object) -> str:
            raw = getattr(event, "data", "") or ""
            # tk's "files" payload is space-separated, with braces around paths
            # containing spaces. tk.splitlist handles both.
            try:
                paths = list(root.tk.splitlist(raw))
            except Exception:
                paths = [raw]
            if not paths:
                return "break"
            quoted = " ".join(f'"{p}"' for p in paths)
            existing = files_var.get().strip()
            files_var.set(f"{existing} {quoted}".strip()
                          if existing else quoted)
            # If any dropped path is a directory, default to recursive
