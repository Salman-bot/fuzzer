    # Animated "claude is thinking…" indicator. Insert returns a handle; pass
    # it back to _stop_thinking() to remove the line when the response lands.
    _thinking_handles: Dict[str, dict] = {}

    _thinking_counter = [0]

    def _start_thinking(label: str = "claude is thinking") -> str:
        _thinking_counter[0] += 1
        handle_id = f"thk_{_thinking_counter[0]}"
        chat_log.config(state="normal")
        start_idx = chat_log.index("end-1c")
        chat_log.insert("end", f"{label}\n", "thinking")
        chat_log.config(state="disabled")
        chat_log.see("end")
        info = {"start": start_idx, "label": label, "alive": True, "dots": 0}
        _thinking_handles[handle_id] = info
        def _tick():
            if not info["alive"]:
                return
            info["dots"] = (info["dots"] + 1) % 4
            dots = "." * info["dots"] + " " * (3 - info["dots"])
            chat_log.config(state="normal")
            line_end = f"{info['start']} lineend"
            chat_log.delete(info["start"], line_end)
            chat_log.insert(info["start"], f"{label}{dots}", "thinking")
            chat_log.config(state="disabled")
            root.after(350, _tick)
        root.after(350, _tick)
        return handle_id

    def _stop_thinking(handle_id: str) -> None:
        info = _thinking_handles.pop(handle_id, None)
        if not info:
            return
        info["alive"] = False
        try:
            chat_log.config(state="normal")
            # Remove the entire line (the indicator + its trailing newline).
            chat_log.delete(info["start"], f"{info['start']} lineend +1c")
            chat_log.config(state="disabled")
        except Exception:
            pass

    def _update_chat_context_label() -> None:
        included = chat_state["context_files"]  # type: ignore[index]
        chars = int(chat_state["context_chars"])  # type: ignore[arg-type]
        if included:
            names = ", ".join(os.path.basename(p) for p in included[:3])  # type: ignore[union-attr]
            if len(included) > 3:  # type: ignore[arg-type]
                names += f" + {len(included) - 3} more"  # type: ignore[arg-type]
            chat_context_var.set(f"Context: {names}  ·  {chars/1000:.1f}k chars")
        else:
            chat_context_var.set("Context: (none — add files above to ground answers)")

    def _build_chat_context(paths: List[str], recursive: bool
                            ) -> Tuple[str, List[str], int]:
        """Read the user's selected files into one numbered text blob for Claude.
        Returns (body, included_paths, total_chars). Truncates at _CHAT_CONTEXT_BUDGET."""
        files = collect_files(paths, recursive)
        chunks: List[str] = []
        included: List[str] = []
        used = 0
        for fp in files:
            if used >= _CHAT_CONTEXT_BUDGET:
                break
            lines = read_lines(fp)
            if not lines:
                continue
            pg_map = _pdf_page_map.get(fp, [])
            body_lines: List[str] = []
            for i, line in enumerate(lines, 1):
                pg = pg_map[i - 1] if pg_map and i - 1 < len(pg_map) else 0
                tag = f"[p.{pg} L{i}]" if pg else f"[L{i}]"
                body_lines.append(f"{tag} {line}")
            section = f"=== {os.path.basename(fp)} ({fp}) ===\n" + "\n".join(body_lines)
            if used + len(section) > _CHAT_CONTEXT_BUDGET:
                section = section[: _CHAT_CONTEXT_BUDGET - used] + "\n…[truncated]"
            chunks.append(section)
            included.append(fp)
            used += len(section)
        return "\n\n".join(chunks), included, used

    def _reset_chat(_event: object = None) -> None:
        chat_state["messages"] = []
        chat_state["files_sig"] = ""
        chat_state["context_files"] = []
        chat_state["context_chars"] = 0
        chat_log.config(state="normal")
        chat_log.delete("1.0", "end")
        chat_log.config(state="disabled")
        _update_chat_context_label()
        _append_chat("sys", "system", "Conversation reset.")

    def _send_chat(_event: object = None) -> None:
        msg = chat_entry.get().strip()
        if not msg:
            return
        api_key = str(_gui_state.get("api_key") or os.environ.get("ANTHROPIC_API_KEY") or "")
        if not api_key:
            return
        chat_entry.delete(0, "end")
        _append_chat("you", "you", msg)
        chat_entry.config(state="disabled")
        chat_send_btn.config(state="disabled")
        chat_reset_btn.config(state="disabled")

        # If the Files/folders selection changed (or this is the first turn
        # with files), rebuild file context and reset the conversation.
        paths = parse_files_field(files_var.get())
        sig = "\0".join(sorted(paths))
        if paths and sig != chat_state["files_sig"]:
            _append_chat("sys", "system", "Loading files into context…")
            body, included, used = _build_chat_context(paths, recursive_var.get())
            chat_state["files_sig"] = sig
            chat_state["context_files"] = included
            chat_state["context_chars"] = used
            if body:
                chat_state["messages"] = [
                    {
                        "role": "user",
                        "content": (
                            "I'll ask you questions about the files below. When you "
                            "quote or reference specific passages, cite the line tags "
                            "like [L42] or [p.3 L42] so I can jump to the spot.\n\n"
                            + body
                        ),
                    },
                    {
                        "role": "assistant",
                        "content": f"Loaded {len(included)} file(s) ({used:,} chars). Ask away.",
                    },
                ]
            else:
                chat_state["messages"] = []
            _update_chat_context_label()

        # Build the request payload (cap history but always keep the leading
        # context turn pair so file content stays available across many turns).
        history = list(chat_state["messages"])  # type: ignore[arg-type]
        if chat_state["context_files"]:
            head = history[:2]
            tail = history[2:][-_CHAT_MAX_HISTORY:]
            messages = head + tail + [{"role": "user", "content": msg}]
        else:
            tail = history[-_CHAT_MAX_HISTORY:]
            messages = tail + [{"role": "user", "content": msg}]

        def _worker() -> None:
            try:
                import anthropic as _ant
                client = _ant.Anthropic(api_key=api_key)
                system_prompt = (
                    "You are a research assistant embedded in a file-search tool.\n\n"
                    "When the user has loaded files, ground every answer in their "
                    "content and cite line tags like [L42] or [p.3 L42] when "
                    "quoting specific passages.\n\n"
                    "Tools available:\n"
                    "  • list_results — see files the user's last (non-AI) search hit\n"
                    "  • read_file_chunk — read a slice of a file (text only)\n"
                    "  • write_file — overwrite a file (e.g. summaries, extracts)\n"
                    "  • append_to_file — add to a file\n\n"
                    "Use tools when the user asks you to inspect, transform, or "
                    "produce files from the search results. Read before you "
                    "write. If a question can be answered from the in-context "
                    "files alone, answer directly without using tools."
                )

                current = list(messages)
                final_text_parts: List[str] = []
                think_box = {"id": None}  # mutable so the lambda below can read it

                def _begin_think(label: str) -> None:
                    think_box["id"] = _start_thinking(label)

                def _end_think() -> None:
                    if think_box["id"]:
                        _stop_thinking(think_box["id"])
                        think_box["id"] = None

                for _round in range(_CHAT_TOOL_ROUNDS):
                    label = ("claude is thinking" if _round == 0
                             else f"claude is working (round {_round + 1})")
                    root.after(0, _begin_think, label)

                    # Streaming state for this round
                    text_for_round: List[str] = []
                    text_turn_open = [False]
                    thinking_turn_open = [False]

                    def _close_open_turns() -> None:
                        if thinking_turn_open[0]:
                            _chat_end_turn("thinking")
                            thinking_turn_open[0] = False
                        if text_turn_open[0]:
                            _chat_end_turn("claude")
                            text_turn_open[0] = False

                    # Try with extended thinking enabled; if the SDK or model
                    # rejects it, fall back to a plain streaming call.
                    def _open_stream(with_thinking: bool):
                        kwargs = dict(
                            model="claude-sonnet-4-6",
                            max_tokens=4096,
                            system=system_prompt,
                            tools=_CHAT_TOOLS,
                            messages=current,
                        )
                        if with_thinking:
                            kwargs["thinking"] = {"type": "enabled", "budget_tokens": 4000}
                        return client.messages.stream(**kwargs)

                    try:
                        stream_ctx = _open_stream(with_thinking=True)
                    except Exception:
                        stream_ctx = _open_stream(with_thinking=False)

                    try:
                        with stream_ctx as stream:
                            for event in stream:
                                etype = getattr(event, "type", None)
                                if etype == "content_block_start":
                                    cb = getattr(event, "content_block", None)
                                    cbt = getattr(cb, "type", None)
                                    if cbt == "thinking":
                                        root.after(0, _end_think)
                                        root.after(0, _chat_begin_turn,
                                                   "thinking", "💭 thinking")
                                        thinking_turn_open[0] = True
                                    elif cbt == "text":
                                        root.after(0, _end_think)
                                        if thinking_turn_open[0]:
                                            root.after(0, _chat_end_turn, "thinking")
                                            thinking_turn_open[0] = False
                                        root.after(0, _chat_begin_turn,
                                                   "claude", "claude")
                                        text_turn_open[0] = True
                                elif etype == "content_block_delta":
                                    delta = getattr(event, "delta", None)
                                    dtype = getattr(delta, "type", None)
                                    if dtype == "text_delta":
                                        t = delta.text or ""
                                        text_for_round.append(t)
                                        root.after(0, _chat_append_text, "claude", t)
                                    elif dtype == "thinking_delta":
                                        t = getattr(delta, "thinking", "") or ""
                                        root.after(0, _chat_append_text, "thinking", t)
                                elif etype == "content_block_stop":
                                    if thinking_turn_open[0]:
                                        root.after(0, _chat_end_turn, "thinking")
                                        thinking_turn_open[0] = False
                            final_msg = stream.get_final_message()
                    finally:
                        root.after(0, _end_think)
                        # Always close any open turn so the next prefix lands fresh
                        root.after(0, _close_open_turns)

                    # Reconstruct assistant block list for the next round's request.
                    tool_uses: List[object] = []
                    assistant_blocks: List[dict] = []
                    for b in final_msg.content:
                        btype = getattr(b, "type", None)
                        if btype == "text":
                            assistant_blocks.append({"type": "text", "text": b.text})
                        elif btype == "tool_use":
                            tool_uses.append(b)
                            assistant_blocks.append({
                                "type":  "tool_use",
                                "id":    b.id,
                                "name":  b.name,
                                "input": b.input,
                            })
                        elif btype == "thinking":
                            # Required by the API to be echoed back in subsequent
                            # turns when interleaved thinking is in use.
                            assistant_blocks.append({
                                "type":      "thinking",
                                "thinking":  getattr(b, "thinking", ""),
                                "signature": getattr(b, "signature", ""),
                            })

                    full_text = "".join(text_for_round).strip()
                    if full_text:
                        final_text_parts.append(full_text)

                    if final_msg.stop_reason != "tool_use" or not tool_uses:
                        break

                    # Execute tools and feed results back. Show each call AND
                    # a brief preview of its result so the user can see progress.
                    current.append({"role": "assistant", "content": assistant_blocks})
                    tool_results = []
                    for tu in tool_uses:
                        tu_input = getattr(tu, "input", {}) or {}
                        preview_args = ", ".join(
                            f"{k}={str(v)[:60]!r}" + ("…" if len(str(v)) > 60 else "")
                            for k, v in tu_input.items()
                        )
                        root.after(0, lambda n=tu.name, p=preview_args:
                                   _append_chat("tool", "→ tool", f"{n}({p})"))
                        try:
                            result = _dispatch_tool(tu.name, tu_input)
                        except Exception as te:
                            result = f"error in tool {tu.name}: {type(te).__name__}: {te}"
                        # First-line preview for the chat; full result still goes to Claude.
                        first_line = result.splitlines()[0] if result else "(empty)"
                        preview = first_line[:160] + ("…" if len(first_line) > 160 else "")
                        if "\n" in result:
                            preview += f"  (+{result.count(chr(10))} more lines)"
                        root.after(0, lambda r=preview:
                                   _append_chat("tool_result", "← result", r))
                        # Cap tool output so we don't blow context.
                        if len(result) > 12_000:
                            result = result[:12_000] + f"\n… (+{len(result) - 12_000} chars)"
                        tool_results.append({
                            "type":        "tool_result",
                            "tool_use_id": tu.id,
                            "content":     result,
                        })
                    current.append({"role": "user", "content": tool_results})
                else:
                    root.after(0, _end_think)
                    root.after(0, lambda: _append_chat(
                        "sys", "system",
                        f"(stopped after {_CHAT_TOOL_ROUNDS} tool rounds)"))

                final_reply = "\n\n".join(final_text_parts)

                def _commit() -> None:
                    msgs = list(chat_state["messages"])  # type: ignore[arg-type]
                    msgs.append({"role": "user", "content": msg})
                    msgs.append({"role": "assistant", "content": final_reply or "(no text reply)"})
                    chat_state["messages"] = msgs
                root.after(0, _commit)
            except Exception as exc:
                root.after(0, lambda: _append_chat("err", "error", str(exc)))
            finally:
                root.after(0, _update_chat_state)

        threading.Thread(target=_worker, daemon=True).start()

    chat_send_btn.config(command=_send_chat)
    chat_reset_btn.config(command=_reset_chat)
    chat_entry.bind("<Return>", _send_chat)
    _update_chat_state()
    _update_chat_context_label()

    # ── argument parsing for the files field ─────────────────────────────────
    import shlex

    def parse_files_field(text: str) -> List[str]:
        text = text.strip()
        if not text:
            return []
        try:
            return shlex.split(text)
        except ValueError:
            return [t for t in text.split() if t]

    # ── search worker ────────────────────────────────────────────────────────
    def _chat_log_fn(tag: str, prefix: str, text: str) -> None:
        """Thread-safe bridge: schedule _append_chat on the main thread."""
        root.after(0, lambda t=tag, p=prefix, x=text: _append_chat(t, p, x))

    def worker(pattern: str, paths: List[str], case_sensitive: bool,
               exact: bool, threshold: int, recursive: bool, ai: bool) -> None:
        try:
            files = collect_files(paths, recursive)
            if not files:
                msg_q.put(("error", "No files to search."))
                return
            results: Dict[str, Tuple[List[str], List[Match]]] = {}
            for i, fp in enumerate(files, 1):
                # Honour Stop button between files. (Mid-file cancellation
                # isn't supported — the current file finishes first.)
                if state.get("cancel_search"):
                    msg_q.put(("cancelled", results))
                    return
                msg_q.put(("status", f"Searching {i}/{len(files)}: {fp}"))
                if ai:
                    _api_key = str(_gui_state.get("api_key") or os.environ.get("ANTHROPIC_API_KEY") or "")
                    lines, matches = ai_search_file(fp, pattern, log_fn=_chat_log_fn, api_key=_api_key)
                else:
                    lines, matches = search_file(
                        fp, pattern,
                        case_sensitive=case_sensitive,
                        exact_only=exact,
                        threshold=threshold,
                    )
                if matches:
                    results[fp] = (lines, matches)
            msg_q.put(("done", results))
        except Exception as e:
            msg_q.put(("error", f"{type(e).__name__}: {e}"))

    def start_search() -> None:
        if state["searching"]:
            return
        pat = pattern_var.get().strip()
        if not pat:
            messagebox.showwarning("fuzzer", "Enter a search pattern.")
            return
        paths = parse_files_field(files_var.get())
        if not paths:
            messagebox.showwarning("fuzzer", "Pick at least one file or folder.")
            return

        thr = threshold_var.get()
        if not 0 <= thr <= 100:
            messagebox.showwarning("fuzzer", "Threshold must be 0-100.")
            return

        _gui_state["last_files"] = files_var.get()
        # Prepend to history, deduplicate, cap at 30
        if pat in _search_history:
            _search_history.remove(pat)
        _search_history.insert(0, pat)
        del _search_history[30:]
        pattern_entry.config(values=_search_history)
        _gui_state["search_history"] = _search_history
        # Persist option flags
        _gui_state["case_sensitive"] = case_var.get()
        _gui_state["exact_only"]     = exact_var.get()
        _gui_state["recursive"]      = recursive_var.get()
        _gui_state["ai_mode"]        = ai_var.get()
        _gui_state["verbose"]        = verbose_var.get()
        _gui_state["threshold"]      = threshold_var.get()
        _save_state(_gui_state)
        state["searching"] = True
        state["cancel_search"] = False
        state["results"] = {}
        state["pattern"] = pat
        search_btn.config(state="disabled", text="Searching…")
        stop_btn.config(state="normal")
        export_btn.config(state="disabled")
        tree.delete(*tree.get_children())
        status_var.set("Starting…")

        t = threading.Thread(
            target=worker,
            args=(pat, paths, case_var.get(), exact_var.get(),
                  threshold_var.get(), recursive_var.get(), ai_var.get()),
            daemon=True,
        )
        t.start()

    _row_paths: Dict[str, str] = {}       # iid → full file path
    _row_full_lines: Dict[str, str] = {}  # iid → full match text for tooltips
    _highlighted_pdfs: Dict[str, str] = {}  # original path → highlighted copy path

    # Monotonic counter so each highlighted-copy filename is unique. We used to
    # use id(_doc) here, but CPython reuses object IDs after the doc is closed
    # and GC'd — that caused two different searches to write the same tmp path,
    # which made Preview show its cached first-open page on subsequent opens.
    import itertools as _itertools
    _tmp_counter = _itertools.count(1)

    def _build_highlighted_pdf(fp: str, matches: List[Match]) -> str:
        """Highlight matched lines in a PDF copy. For complex layouts (RTL,
        multi-column), the dict and text outputs from PyMuPDF reorder words
        differently, so we match by normalized token overlap rather than
        positional indexing. Falls back to query-token search when the matched
        line is a long concatenation of many visual lines."""
        try:
            import fitz as _fitz
            from difflib import SequenceMatcher
            _tmp_dir = Path.home() / ".fuzzer_tmp"
            _tmp_dir.mkdir(exist_ok=True)
            _doc = _fitz.open(fp)

            # Group matches by page number (1-based)
            _page_ms: Dict[int, List[Match]] = {}
            for m in matches:
                _page_ms.setdefault(m.page_num or 1, []).append(m)

            for _pn, _ms in _page_ms.items():
                if not (1 <= _pn <= len(_doc)):
                    continue
                _pg = _doc[_pn - 1]

                # Collect all dict lines (text + bbox) in sorted order
                _pg_dict: dict = _pg.get_text("dict", sort=True)  # type: ignore[assignment]
                _dict_lines: List[tuple] = []  # (text, bbox)
                for _blk in _pg_dict.get("blocks", []):
                    if _blk.get("type") != 0:
                        continue
                    for _ln in _blk.get("lines", []):
                        _lt = "".join(s.get("text", "") for s in _ln.get("spans", []))
                        _dict_lines.append((_lt.strip(), _ln.get("bbox")))

                # Pre-tokenize + normalize dict lines once per page
                _dict_lines_aug = [
                    (_t, _b, _tokenize(_t), _normalize_arabic(_t))
                    for (_t, _b) in _dict_lines
                ]
                _q_norm = _normalize_arabic(pattern_var.get().strip())

                for m in _ms:
                    _q_line = m.line.strip()
                    _q_tokens = _tokenize(_q_line)
                    _added = False

                    # Strategy 1: token-overlap match against full matched line.
                    # Order-independent — handles RTL/Arabic where dict and text
                    # outputs reorder words. Picks the dict line(s) covering
                    # ≥60% of the query line's tokens.
                    if _q_tokens:
                        _hits: List = []
                        for _dt, _db, _d_tokens, _d_norm in _dict_lines_aug:
                            if not _d_tokens:
                                continue
                            _coverage = len(_q_tokens & _d_tokens) / len(_q_tokens)
                            if _coverage >= 0.60:
                                _hits.append((_coverage, _db))
                        if _hits:
                            _hits.sort(reverse=True, key=lambda x: x[0])
                            _top = _hits[0][0]
                            for _cov, _bb in _hits:
                                if _cov >= _top - 0.05:
                                    _pg.add_highlight_annot(_fitz.Rect(_bb))
                                    _added = True

                    # Strategy 2: per-token fuzzy match against the query.
                    # For PDFs with broken character encoding (e.g. ا+م+ل swap),
                    # strict substring fails. Use the same per-token fuzzy
                    # comparison the search itself uses — find dict lines with
                    # any token at ≥70% similarity to the normalized query.
                    if not _added and _q_norm:
                        for _dt, _db, _d_tokens, _d_norm in _dict_lines_aug:
                            for _tok in _d_tokens:
                                if SequenceMatcher(None, _q_norm, _tok).ratio() >= 0.70:
                                    _pg.add_highlight_annot(_fitz.Rect(_db))
                                    _added = True
                                    break

                    # Strategy 3: SequenceMatcher fuzzy fallback against the
                    # full query line, normalized
                    if not _added and _q_line:
                        _qs_norm = _normalize_arabic(_q_line)
                        _best, _best_bbox = 0.55, None
                        for _dt, _db, _d_tokens, _d_norm in _dict_lines_aug:
                            if not _d_norm:
                                continue
                            _r = SequenceMatcher(None, _qs_norm, _d_norm).ratio()
                            if _r > _best:
                                _best, _best_bbox = _r, _db
                        if _best_bbox:
                            _pg.add_highlight_annot(_fitz.Rect(_best_bbox))

            import time as _t
            _tmp = str(
                _tmp_dir
                / f"fuzzer_{os.getpid()}_{next(_tmp_counter)}_{_t.time_ns()}.pdf"
            )
            _doc.save(_tmp)
            _doc.close()
            return _tmp
        except Exception as _e:
            status_var.set(f"Highlight failed: {_e}")
            return fp

    def populate(results: Dict[str, Tuple[List[str], List[Match]]]) -> None:
        _row_paths.clear()
        _highlighted_pdfs.clear()
        total = 0
        for fp, (_, matches) in results.items():
            display_name = _fix_arabic(os.path.basename(fp))
            for m in matches:
                if m.score == 100:
                    match_type, score_text = "exact", "100"
                elif m.score == -1:
                    match_type, score_text = "ai", ""
                else:
                    match_type, score_text = "fuzzy", str(m.score)
                page_text = str(m.page_num) if m.page_num else ""
                _tag = "odd" if total % 2 else "even"
                _snippet = _line_context(m.line, pattern_var.get())
                iid = tree.insert("", "end", values=(
                    display_name, m.line_num, page_text, match_type, score_text,
                    _fix_arabic(_snippet)), tags=(_tag,))
                _row_paths[iid] = fp
                _row_full_lines[iid] = _fix_arabic(m.line)
                total += 1
            # Pre-build highlighted copy for every PDF in results
            if Path(fp).suffix.lower() == ".pdf":
                _highlighted_pdfs[fp] = _build_highlighted_pdf(fp, matches)

        n_files = len(results)
        status_var.set(
            f"{total} match{'es' if total != 1 else ''} "
            f"in {n_files} file{'s' if n_files != 1 else ''}"
        )

    def stop_search() -> None:
        if not state["searching"]:
            return
        state["cancel_search"] = True
        stop_btn.config(state="disabled")
        status_var.set("Cancelling… (current file will finish first)")

    def poll_queue() -> None:
        with contextlib.suppress(queue.Empty):
            while True:
                kind, payload = msg_q.get_nowait()
                if kind == "status":
                    status_var.set(str(payload))
                elif kind == "done":
                    state["results"] = payload  # type: ignore[assignment]
                    state["searching"] = False
                    state["cancel_search"] = False
                    search_btn.config(state="normal", text="Search")
                    stop_btn.config(state="disabled")
                    if payload:
                        populate(payload)  # type: ignore[arg-type]
                        export_btn.config(state="normal")
                    else:
                        status_var.set("No matches found.")
                        export_btn.config(state="disabled")
                elif kind == "cancelled":
                    state["results"] = payload  # type: ignore[assignment]
                    state["searching"] = False
                    state["cancel_search"] = False
                    search_btn.config(state="normal", text="Search")
                    stop_btn.config(state="disabled")
                    if payload:
                        populate(payload)  # type: ignore[arg-type]
                        export_btn.config(state="normal")
                        status_var.set(f"Stopped — {sum(len(m) for _, m in payload.values())} "  # type: ignore[union-attr]
                                       f"match(es) in {len(payload)} file(s) before cancel")
                    else:
                        status_var.set("Stopped — no results yet")
                elif kind == "error":
                    state["searching"] = False
                    state["cancel_search"] = False
                    search_btn.config(state="normal", text="Search")
                    stop_btn.config(state="disabled")
                    status_var.set(f"Error: {payload}")
                    messagebox.showerror("fuzzer", str(payload))
        root.after(100, poll_queue)

    def clear_results() -> None:
        tree.delete(*tree.get_children())
        _row_paths.clear()
        _row_full_lines.clear()
        state["results"] = {}
        export_btn.config(state="disabled")
        status_var.set("Ready")

    def export_to_file() -> None:
        results = state["results"]
        if not results:
            return
        path = filedialog.asksaveasfilename(
            title="Export results",
            defaultextension=".xlsx",
            filetypes=[
                ("Excel workbook", "*.xlsx"),
                ("CSV", "*.csv"),
                ("TSV", "*.tsv"),
                ("JSON", "*.json"),
                ("Text", "*.txt"),
                ("All files", "*.*"),
            ],
        )
        if not path:
            return
        try:
            export_results(results, path, verbose=verbose_var.get())  # type: ignore[arg-type]
            status_var.set(f"Exported to {path}")
        except Exception as e:
            messagebox.showerror("fuzzer", f"Export failed: {e}")

    _editor_exts = {'.txt', '.md', '.py', '.js', '.ts', '.jsx', '.tsx',
                    '.json', '.xml', '.html', '.htm', '.rst', '.csv',
                    '.log', '.yaml', '.yml', '.toml', '.ini', '.cfg'}

    def open_selected(event: object = None) -> None:
        # Resolve iid: try click position first (reliable on double-click),
        # then fall back to current selection.
        iid = ""
        if event is not None and hasattr(event, "y"):
            iid = tree.identify_row(event.y) or ""  # type: ignore[attr-defined]
        if not iid:
            sel = tree.selection()
            iid = sel[0] if sel else ""
        if not iid:
            return

        filepath = _row_paths.get(iid, "")
        if not filepath:
            return

        vals = tree.item(iid, "values")
        # values order: (file, line, page, match, score, content)
        try:
            line_num = int(vals[1])
        except (ValueError, IndexError):
            line_num = 1
        try:
            page_num = int(vals[2]) if vals[2] else 0
        except (ValueError, IndexError):
            page_num = 0

        import subprocess, shutil
        ext = Path(filepath).suffix.lower()
        try:
            if ext == ".pdf":
                open_page = page_num or 1
                # Use the pre-built highlighted copy from populate(); fall back
                # to original if not available (e.g. fitz not installed).
                _tmp_path = _highlighted_pdfs.get(filepath, filepath)
                _esc = _tmp_path.replace("\\", "\\\\").replace('"', '\\"')

                # Open + resize + navigate via ⌘⌥G keyboard shortcut
                _script = "\n".join([
                    'tell application "Preview"',
                    '  activate',
                    f'  open POSIX file "{_esc}"',
                    'end tell',
                    'delay 0.35',
                    'try',
                    '  tell application "System Events"',
                    '    tell process "Preview"',
                    '      tell front window',
                    '        if value of attribute "AXMinimized" is true then',
                    '          set value of attribute "AXMinimized" to false',
                    '        end if',
                    '        set position to {120, 80}',
                    '        set size to {1000, 720}',
                    '      end tell',
                    '    end tell',
                    '  end tell',
                    'end try',
                    f'if {open_page} > 1 then',
                    '  tell application "System Events"',
                    '    tell process "Preview"',
                    '      keystroke "g" using {command down, option down}',
                    '      set n to 0',
                    '      repeat',
                    '        delay 0.06',
                    '        set n to n + 1',
                    '        if n > 30 then exit repeat',
                    '        try',
                    '          tell sheet 1 of front window',
                    f'            set value of text field 1 to "{open_page}"',
                    '            click button "OK"',
                    '          end tell',
                    '          exit repeat',
                    '        end try',
                    '      end repeat',
                    '    end tell',
                    '  end tell',
                    'end if',
                ])
                _as_proc = subprocess.run(
                    ["osascript", "-e", _script],
                    capture_output=True, text=True
                )
                if _as_proc.returncode != 0:
                    _as_err = (_as_proc.stderr or _as_proc.stdout).strip()
                    status_var.set(f"Open failed — {_as_err[:80]}")
                    messagebox.showerror("fuzzer – open PDF", f"AppleScript error: {_as_err}")
                else:
                    hl_note = "" if _tmp_path != filepath else " (no highlight — fitz missing?)"
                    status_var.set(f"Opened page {open_page} — {os.path.basename(filepath)}{hl_note}")
            elif ext in _editor_exts:
                if shutil.which("code"):
                    subprocess.Popen(["code", "--goto", f"{filepath}:{line_num}"])
                elif shutil.which("cursor"):
                    subprocess.Popen(["cursor", "--goto", f"{filepath}:{line_num}"])
                elif shutil.which("subl"):
                    subprocess.Popen(["subl", f"{filepath}:{line_num}"])
                else:
                    subprocess.Popen(["open", filepath])
                status_var.set(f"Opened line {line_num} — {os.path.basename(filepath)}")
            else:
                subprocess.Popen(["open", filepath])
                status_var.set(f"Opened {os.path.basename(filepath)}")
        except Exception as _ex:
            status_var.set(f"Open failed: {_ex}")
            messagebox.showerror("fuzzer", f"Could not open:\n{_ex}")

    def set_api_key() -> None:
        dlg = tk.Toplevel(root)
        dlg.title("Claude API Key")
        dlg.resizable(False, False)
        dlg.grab_set()
        ttk.Label(dlg, text="Paste your Anthropic API key:").pack(padx=16, pady=(12, 4))
