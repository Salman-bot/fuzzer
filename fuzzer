        def _compute_disasm() -> str:
            so = Path(__file__).resolve().parent / \
                "_ar_norm.cpython-314-darwin.so"
            if not so.exists():
                return f"(no .so found at {so})"
            try:
                r = _dbg_sp.run(["otool", "-tV", str(so)],
                                capture_output=True, text=True, timeout=10)
                if r.returncode != 0:
                    return f"otool failed: {r.stderr}"
                out, in_fn = [], False
                for ln in r.stdout.splitlines():
                    if "_py_normalize:" in ln or "py_normalize:" in ln:
                        in_fn = True
                        out.append(ln)
                        continue
                    if in_fn:
                        if ln and not ln.startswith((" ", "\t")) and ln.endswith(":"):
                            break
                        out.append(ln)
                return "\n".join(out[:60]) if out else "(py_normalize symbol not found)"
