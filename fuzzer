        def _log_activity(msg: str) -> None:
            """Append a timestamped line to the activity log (thread-safe)."""
            ts = _dbg_time.strftime("%H:%M:%S")

            def _write() -> None:
                dbg_act_log.config(state="normal")
                dbg_act_log.insert("end", f"[{ts}] {msg}\n")
                n = int(dbg_act_log.index("end-1c").split(".")[0])
                if n > _ACT_LOG_MAX + 20:
                    dbg_act_log.delete("1.0", f"{n - _ACT_LOG_MAX}.0")
                dbg_act_log.see("end")
                dbg_act_log.config(state="disabled")

            root.after(0, _write)

