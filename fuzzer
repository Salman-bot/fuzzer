            try:
                import anthropic as _ant
                client = _ant.Anthropic(api_key=api_key)
                resp = client.messages.create(
                    model="claude-sonnet-4-6",
                    max_tokens=2048,
                    messages=[{"role": "user", "content": msg}],
                )
                from anthropic.types import TextBlock as _TB
                reply = next((b.text for b in resp.content if isinstance(b, _TB)), "")
                root.after(0, lambda: _append_chat("claude", "claude", reply))
            except Exception as exc:
                root.after(0, lambda: _append_chat("err", "error", str(exc)))
            finally:
                root.after(0, _update_chat_state)

        threading.Thread(target=_worker, daemon=True).start()

