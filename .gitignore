.pytest_cache/
.claude/
.vscode/
*.pyc
.DS_Store

# Test PDF corpus — fetched on demand with `make test-corpus`.
# (Tarball lives outside the repo; pattern guards against accidental drops.)
test_pdfs/
test_pdfs.tar.gz

# Local tool / editor state, not shared.
.sixth/

# Per-search highlighted PDF copies (regenerated on every search).
